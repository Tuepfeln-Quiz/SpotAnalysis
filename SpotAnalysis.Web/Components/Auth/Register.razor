@page "/register"
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using System.Text.RegularExpressions
@using SpotAnalysis.Services.DTOs
@using SpotAnalysis.Services.Services
@using SpotAnalysis.Data.Models.Identity
@inject NavigationManager NavigationManager;
@inject AuthenticationStateProvider AuthStateProvider
@inject IHttpContextAccessor HttpContextAccessor;
@inject IUserService UserService;

<div class="row">
    <div class="col-lg-4 offset-lg-4 pt-4 pb-4 border">
        <EditForm Model="@LoginVM" OnValidSubmit="Authenticate" FormName="RegForm">
            <DataAnnotationsValidator />

            <div class="mb-3 text-center flex-column">
                <img src="/images/avatar.png" id="SignPic" class="img-fluid" />
                <h3>Register</h3>
            </div>

            <div class="mb-4">
                    <UsernameGenerator @bind-Value="LoginVM.UserName" />
                    <label class="username-label text-gray"><b>* generate username</b></label>
                <ValidationMessage For="() => LoginVM.UserName" />

            </div>

            <div class="mb-3">
                @* <label>Password</label> *@
                <InputText @bind-Value="LoginVM.Password" placeholder="Password" type="password" class="form-control" />
                <ValidationMessage For="() => LoginVM.Password" />
            </div>

            <div class="mb-3">
                @* <label>Confirm Password</label> *@
                <InputText @bind-Value="ConfirmPassword" placeholder="Confirm Password" type="password" class="form-control" />
                <ValidationMessage For="() => ConfirmPassword" />
            </div>

            <div class="mb-3 text-center">
                <span class="text-danger">@ErrorMessage</span>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Register</button>
            </div>
        </EditForm>
       <div class="mt-3 text-center">
            <p>Already have an account? <a href="/login">Login here</a></p>
       </div>
    </div>
</div>

<style>
    .form-control {
    text-align: center;
}

.form-control::placeholder {
    text-align: center;
}

/* Browser-Kompatibilität */
.form-control::-webkit-input-placeholder {
    text-align: center;
}
.form-control:-moz-placeholder {
    text-align: center;
}
.form-control:-ms-input-placeholder {
    text-align: center;
}

.username-label {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.25rem;
    font-size: 0.875rem;
}
</style>

@code {


    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    public LoginDTO LoginVM { get; set; } = new() { UserName = string.Empty, Password = string.Empty };

    public string ConfirmPassword { get; set; } = string.Empty;
    private string? ErrorMessage { get; set; }

    private async Task Authenticate()
    {
        ErrorMessage = null;
        Console.WriteLine("Authenticate method called with username: " + LoginVM.UserName + " and password: " + LoginVM.Password + " and confirm password: " + ConfirmPassword);

        if (!isValid(LoginVM.Password))
        {
            ErrorMessage = "Passwort muss:\nmin.8 Zeichen lang sein\nmin. 1 Großbuchstabe\nmin.1 Kleinbuchstabe\nmin.1 Zahl und 1 Sonderzeichen enthalten.";
            return;
        }
        if(LoginVM.Password != ConfirmPassword)
        {
            ErrorMessage = "Passwörter stimmen nicht überein.";
            return;
        }

        try
        {
            await UserService.Register(LoginVM.UserName, LoginVM.Password);
            NavigationManager.NavigateTo("/login");
        }
        catch (Exception e)
        {
            // TODO
        }
    }

    private bool isValid(string? pw)
    {
        if (string.IsNullOrEmpty(pw))
            return false;

        var isv = Regex.IsMatch(pw,
        @"^(?=.*[a-z])      # mind. 1 Kleinbuchstabe
              (?=.*[A-Z])      # mind. 1 Großbuchstabe
              (?=.*\d)         # mind. 1 Zahl
              (?=.*[^a-zA-Z\d])# mind. 1 Sonderzeichen
              .{8,}$           # mindestens 8 Zeichen
            ", RegexOptions.IgnorePatternWhitespace);

        return isv;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            // Schon eingeloggt → zur Dashboard-Seite weiterleiten
            NavigationManager.NavigateTo("/");
        }
    }
}
