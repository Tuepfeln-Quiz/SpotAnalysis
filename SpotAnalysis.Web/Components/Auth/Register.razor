@page "/register"
@using Microsoft.AspNetCore.Components.Authorization
@using System.Text.RegularExpressions

@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

@attribute [AllowAnonymous]

<div class="row justify-content-center min-vh-100 align-items-center p-4">
    <div class="col-lg-4 col-md-6 col-sm-10 pt-4 pb-4 border border-secondary rounded">
        <form action="/api/auth/register" method="post" @onsubmit="ValidateBeforeSubmit" @onsubmit:preventDefault="_preventSubmit">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <div class="mb-3 text-center flex-column">
                <h3>Register</h3>
            </div>

            <div class="mb-4">
                <UsernameGenerator @bind-Value="_userName" />
                <label class="username-label text-gray"><b>* generiere einen Benutzernamen.</b></label>
            </div>

            <input type="hidden" name="userName" value="@_userName" />

            <div class="mb-3">
                <input type="password" name="password" @bind="_password" placeholder="Password" class="form-control" />
            </div>

            <div class="mb-3">
                <input type="password" @bind="_confirmPassword" placeholder="Confirm Password" class="form-control" />
            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage)) {
                <div class="mb-3 text-center">
                    <span class="text-danger">@ErrorMessage</span>
                </div>
            }

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Register</button>
            </div>
        </form>
        <div class="mt-3 text-center">
            <p>Already have an account? <a href="/login@(string.IsNullOrEmpty(ReturnUrl) ? "" : $"?returnUrl={Uri.EscapeDataString(ReturnUrl)}")">Login here</a></p>
        </div>
    </div>
</div>

<style>
    .form-control {
    text-align: center;
}

.form-control::placeholder {
    text-align: center;
}

/* Browser-Kompatibilität */
.form-control::-webkit-input-placeholder {
    text-align: center;
}
.form-control:-moz-placeholder {
    text-align: center;
}
.form-control:-ms-input-placeholder {
    text-align: center;
}

.username-label {
    display: flex;
    justify-content: flex-start;
    margin-top: 0.25rem;
    font-size: 0.875rem;
}
</style>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorMessage { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string _userName = string.Empty;
    private string _password = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _preventSubmit;

    private void ValidateBeforeSubmit()
    {
        _preventSubmit = false;

        if (!IsValidPassword(_password))
        {
            ErrorMessage = "Passwort muss min. 8 Zeichen, 1 Großbuchstabe, 1 Kleinbuchstabe, 1 Zahl und 1 Sonderzeichen enthalten.";
            _preventSubmit = true;
            return;
        }

        if (_password != _confirmPassword)
        {
            ErrorMessage = "Passwörter stimmen nicht überein.";
            _preventSubmit = true;
            return;
        }

        ErrorMessage = null;
    }

    private static bool IsValidPassword(string? pw)
    {
        if (string.IsNullOrEmpty(pw)) return false;
        return Regex.IsMatch(pw,
            @"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^a-zA-Z\d]).{8,}$");
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo("/");
        }
    }
}
