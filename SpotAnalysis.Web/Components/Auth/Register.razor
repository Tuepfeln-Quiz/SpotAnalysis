@page "/register"
@using Microsoft.AspNetCore.Components.Authorization

@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

@attribute [AllowAnonymous]

<div class="login-page">
    <div class="login-card">
        <div class="login-body">
            <h1 class="login-title">Registrieren</h1>

            <form action="/api/auth/register" method="post" class="login-form">
                <AntiforgeryToken />
                <input type="hidden" name="returnUrl" value="@ReturnUrl" />

                <div class="login-field">
                    <UsernameGenerator @bind-Value="_userName" InputName="userName" />
                    <label class="username-label text-gray"><b>* Benutzername generieren</b></label>
                </div>

                <div class="login-field">
                    <input type="password" name="password" @bind="_password" class="form-control input-custom" placeholder="Passwort" required />
                </div>

                <div class="login-field">
                    <input type="password" name="confirmPassword" @bind="_confirmPassword" class="form-control input-custom" placeholder="Passwort bestätigen" required />
                </div>

                @if (!string.IsNullOrEmpty(DisplayErrorMessage)) {
                    <div class="login-error">
                        <span>@DisplayErrorMessage</span>
                    </div>
                }

                <div class="login-actions">
                    <button type="submit" class="btn btn-primary-purple btn-lg login-submit">Registrieren</button>
                </div>
            </form>

            <div class="login-footer-link">
                <span>Bereits ein Konto?</span>
                <a href="/login@(string.IsNullOrEmpty(ReturnUrl) ? "" : $"?returnUrl={Uri.EscapeDataString(ReturnUrl)}")">Zum Login</a>
            </div>
        </div>
    </div>
    <div class="login-copy">© @DateTime.Now.Year – SpotAnalysis</div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorMessage { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string _userName = string.Empty;
    private string _password = string.Empty;
    private string _confirmPassword = string.Empty;
    private string? DisplayErrorMessage => ErrorMessage switch
    {
        "InvalidUserName" => "Der generierte Benutzername ist ungültig. Bitte erneut generieren.",
        "WeakPassword" => "Passwort muss min. 8 Zeichen, 1 Großbuchstabe, 1 Kleinbuchstabe, 1 Zahl und 1 Sonderzeichen enthalten.",
        "UserNameTaken" => "Dieser Benutzername ist bereits vergeben. Bitte erneut generieren.",
        "PasswordsDoNotMatch" => "Passwörter stimmen nicht überein.",
        "RegistrationFailed" => "Registrierung fehlgeschlagen. Bitte erneut versuchen.",
        null or "" => null,
        _ => ErrorMessage
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo("/");
        }
    }
}
