@page "/reset-password"
@attribute [Authorize]
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using System.Text.RegularExpressions
@using SpotAnalysis.Services.Services
@using Microsoft.AspNetCore.Components.Authorization
@using SpotAnalysis.Services.DTOs
@inject IUserService UserService;
@inject NavigationManager NavigationManager;
@inject IHttpContextAccessor HttpContextAccessor;
@inject AuthenticationStateProvider AuthStateProvider;

<div class="login-page">
    <div class="login-card">
        <div class="login-body">
            <h1 class="login-title">Passwort zurücksetzen</h1>

            <EditForm Model="@ResetVM" OnValidSubmit="HandleResetPassword" FormName="ResetForm" class="login-form">
                <DataAnnotationsValidator />

                <div class="login-field">
                    <UsernameGenerator @bind-Value="ResetVM.UserName" AutoGenerate="false" />
                    <label class="username-label text-gray"><b>* optional: neuen Benutzernamen generieren</b></label>
                    <ValidationMessage For="() => ResetVM.UserName" />
                </div>

                <div class="login-field">
                    <InputText @bind-Value="ResetVM.newPassword" placeholder="Neues Passwort" type="password" class="form-control input-custom" />
                    <ValidationMessage For="() => ResetVM.newPassword" />
                </div>

                <div class="login-field">
                    <InputText @bind-Value="ConfirmPassword" placeholder="Passwort bestätigen" type="password" class="form-control input-custom" />
                </div>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="login-error">
                        <span>@ErrorMessage</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(SuccessMessage))
                {
                    <div class="login-success">
                        <span>@SuccessMessage</span>
                    </div>
                }

                <div class="login-actions">
                    <button type="submit" class="btn btn-primary-purple btn-lg login-submit" disabled="@IsLoading">
                        @(IsLoading ? "Wird zurückgesetzt..." : "Passwort zurücksetzen")
                    </button>
                </div>
            </EditForm>

            <div class="login-footer-link">
                <span>Zurück zum</span>
                <a href="/login">Login</a>
            </div>
        </div>
    </div>
    <div class="login-copy">© @DateTime.Now.Year – SpotAnalysis</div>
</div>

<style>
    .login-success {
        text-align: center;
        color: #15803d;
        font-size: 0.88rem;
        margin: 0.25rem 0;
    }
</style>

@code {
    public ResetPasswordDto ResetVM { get; set; } =  new() { UserName = string.Empty, newPassword = string.Empty };
    public string ConfirmPassword { get; set; } = string.Empty;

    private string? ErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }
    private bool IsLoading { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userName = authState.User.Identity?.Name;

        if (!string.IsNullOrEmpty(userName))
        {
            ResetVM.UserName = userName;
        }

        await InvokeAsync(StateHasChanged);
    }
    private async Task HandleResetPassword()
    {
        ErrorMessage = null;
        SuccessMessage = null;
        if (string.IsNullOrEmpty(ResetVM.UserName))
        {
            ErrorMessage = "Benutzername ist erforderlich.";
            return;
        }
        if (!IsValidPassword(ResetVM.newPassword))
        {
            ErrorMessage = "Passwort muss min. 8 Zeichen, 1 Großbuchstabe, 1 Kleinbuchstabe, 1 Zahl und 1 Sonderzeichen enthalten.";
            return;
        }
        if (ResetVM.newPassword != ConfirmPassword)
        {
            ErrorMessage = "Passwörter stimmen nicht überein.";
            return;
        }
        IsLoading = true;
        try
        {
            var user = await UserService.ChangePassword(ResetVM.UserName, ResetVM.newPassword);
            if (user != null)
            {
                SuccessMessage = "Passwort erfolgreich zurückgesetzt! Du wirst zum Login weitergeleitet.";
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                ErrorMessage = "Benutzer nicht gefunden.";
            }
        }
        catch (Exception)
        {
            ErrorMessage = "Ein Fehler ist aufgetreten. Bitte erneut versuchen.";
        }
        finally
        {
            IsLoading = false;
        }
    }
    private bool IsValidPassword(string? pw)
    {
        if (string.IsNullOrEmpty(pw)) return false;
        return Regex.IsMatch(pw,
            @"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^a-zA-Z\d]).{8,}$",
            RegexOptions.None);
    }

}
