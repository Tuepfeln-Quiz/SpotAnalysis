@page "/reset-password"
@attribute [Authorize]
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using System.Text.RegularExpressions
@using SpotAnalysis.Services.Services
@using Microsoft.AspNetCore.Components.Authorization
@using SpotAnalysis.Services.DTOs
@inject IUserService UserService;
@inject NavigationManager NavigationManager;
@inject IHttpContextAccessor HttpContextAccessor;
@inject AuthenticationStateProvider AuthStateProvider;

 <div class="row justify-content-center min-vh-100 align-items-center p-4">
    <div class="col-lg-4 col-md-6 col-sm-10 pt-4 pb-4 border border-secondary rounded">
        <EditForm Model="@ResetVM" OnValidSubmit="HandleResetPassword" FormName="ResetForm">
            <DataAnnotationsValidator />
            <div class="mb-3 text-center flex-column">
                <h3>Reset Password</h3>
            </div>
            <div class="mb-3 text-center">
                <UsernameGenerator @bind-Value="ResetVM.UserName" AutoGenerate="false" />
                <label class="username-label text-gray"><b>* optional: generate new username</b></label>
                <ValidationMessage For="() => ResetVM.UserName" />
                
            </div>
            <div class="mb-3">
                <InputText @bind-Value="ResetVM.newPassword" placeholder="New Password" type="password" class="form-control" />
                <ValidationMessage For="() => ResetVM.newPassword" />
            </div>
            <div class="mb-3">
                <InputText @bind-Value="ConfirmPassword" placeholder="Confirm Password" type="password" class="form-control" />
            </div>
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger">@ErrorMessage</div>
            }
            
            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <div class="alert alert-success">@SuccessMessage</div>
            }
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary" disabled="@IsLoading">
                    @(IsLoading ? "Resetting..." : "Reset Password")
                </button>
            </div>
        </EditForm>
        <div class="mt-3 text-center">
            <a href="/login">Back to Login</a>
        </div>
    </div>
</div>

<style>
    .username-label {
        display: flex;
        justify-content: flex-end;
        margin-top: 0.25rem;
        font-size: 0.875rem;
    }
</style>

@code {
    public ResetPasswordDto ResetVM { get; set; } =  new() { UserName = string.Empty, newPassword = string.Empty };
    public string ConfirmPassword { get; set; } = string.Empty;
    
    private string? ErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }
    private bool IsLoading { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userName = authState.User.Identity?.Name;
    
        if (!string.IsNullOrEmpty(userName))
        {
            ResetVM.UserName = userName;
        }

        await InvokeAsync(StateHasChanged);
    }
    private async Task HandleResetPassword()
    {
        ErrorMessage = null;
        SuccessMessage = null;
        if (string.IsNullOrEmpty(ResetVM.UserName))
        {
            ErrorMessage = "Username is required.";
            return;
        }
        if (!IsValidPassword(ResetVM.newPassword))
        {
            ErrorMessage = "Password must be at least 8 characters with uppercase, lowercase, number and special character.";
            return;
        }
        if (ResetVM.newPassword != ConfirmPassword)
        {
            ErrorMessage = "Passwords do not match.";
            return;
        }
        IsLoading = true;
        try
        {
            var user = await UserService.ChangePassword(ResetVM.UserName, ResetVM.newPassword);
            if (user != null)
            {
                SuccessMessage = "Password reset successfully! You can now login.";
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                ErrorMessage = "User not found.";
            }
        }
        catch (Exception)
        {
            ErrorMessage = "An error occurred. Please try again.";
        }
        finally
        {
            IsLoading = false;
        }
    }
    private bool IsValidPassword(string? pw)
    {
        if (string.IsNullOrEmpty(pw)) return false;
        return Regex.IsMatch(pw,
            @"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^a-zA-Z\d]).{8,}$",
            RegexOptions.None);
    }
    
}
