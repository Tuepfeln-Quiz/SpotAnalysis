@using SpotAnalysis.Services.Services;

<div class="input-group">
    <InputText @bind-Value="Value" class="form-control" />
    <button type="button" class="btn btn-outline-secondary" @onclick="Generate">
        🎲
    </button>
</div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    [Inject] public IUsernameService UsernameService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Value))
            await Generate();
    }

    private async Task Generate()
    {
        var name = UsernameService.Generate();
        Value = name; // Update the local value
        await ValueChanged.InvokeAsync(name);
    }
}