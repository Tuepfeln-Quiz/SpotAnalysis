@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager NavigationManager

<div class="navbar-container">
    <div class="navbar-header">
        <button class="burger-btn" @onclick="ToggleMenu">
            <i class="bi @(IsMenuOpen ? "bi-x-lg" : "bi-list")"></i>
        </button>
        <button class="home-btn" @onclick="NavigateAndCloseMenu">
            <i class="bi bi-house"></i>
        </button>

        <div class="user-greeting">
            <AuthorizeView>
                <Authorized>
                    <span>Willkommen, <b class="text-warning cursor-pointer" @onclick="ToggleDropdown">@context.User.Identity?.Name</b></span>
                </Authorized>
                <NotAuthorized>
                    <span>Willkommen, <b class="text-warning">Tüpfler</b></span>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <div class="relative" @onclick:stopPropagation>
            <AuthorizeView>
                <Authorized>
                    <button class="btn-user" type="button" @onclick="ToggleDropdown">
                        <img src="/images/science.svg" class="user-avatar" />
                    </button>

                    @if (IsDropdownOpen)
                    {
                        <div class="fixed inset-0 z-10" @onclick="CloseAll"></div>

                        <ul class="dropdown-menu show dropdown-menu-end z-20" style="position:absolute; padding: 28px; right:0; top:100%">
                            <li><span class="dropdown-item-text">@context.User.Identity?.Name</span></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="btn btn-outline-warning mb-2" href="/reset-password">Change Password</a></li>
                            <li>
                                <form method="post" action="/api/auth/logout">
                                   <button type="submit" class="btn btn-outline-danger w-100">
                                        <i class="bi bi-box-arrow-left"></i> Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    }
                </Authorized>
                <NotAuthorized>
                    <NavLink href="/login" class="btn btn-primary w-100" @onclick="CloseAll">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>

    
    <div class="nav-menu @(IsMenuOpen ? "open" : "")">
        <div class="nav-links">
            <NavLink class="nav-link-item" href="/" Match="NavLinkMatch.Prefix" @onclick="CloseAll">
                <i class="bi bi-lightbulb"></i> Quizzes
            </NavLink>
            <NavLink class="nav-link-item" href="/statistics" Match="NavLinkMatch.Prefix" @onclick="CloseAll">
                <i class="bi bi-bar-chart"></i> Statistiken
            </NavLink>
        </div>
        <div class="nav-auth">
            <AuthorizeView>
                <Authorized>
                    <form method="post" action="/api/auth/logout">
                        <button type="submit" class="btn btn-outline-danger w-100">
                            <i class="bi bi-box-arrow-left"></i> Logout
                        </button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <NavLink href="/login" class="btn btn-primary w-100" @onclick="CloseAll">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</div>

<style>
navbar-user {
    margin-left: auto;
}
.cursor-pointer {
    cursor: pointer;
}
.user-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;  
}
.user-avatar:hover {
    transform: scale(1.15);
}
.btn-user {
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
}

.dropdown-menu-end {
    right: 0;
    left: auto;
}

.dropdown-menu .dropdown-item-text {
    display: block;
    text-align: center;
    font-weight: 800;
    margin-bottom: 0.5rem;
}
</style>
@if (IsMenuOpen || IsDropdownOpen)
{
    <div class="nav-overlay" @onclick="CloseAll"></div>
}


@code {
    private bool IsMenuOpen = false;
    private bool IsDropdownOpen = false;

    private void ToggleMenu() => IsMenuOpen = !IsMenuOpen;
    private void ToggleDropdown() => IsDropdownOpen = !IsDropdownOpen;
    private void CloseAll() { IsMenuOpen = false; IsDropdownOpen = false; }

    private void NavigateAndCloseMenu()
    {
        CloseAll();
        NavigationManager.NavigateTo("/");
    }
}