@page "/admin/{userId:guid}/edit"
@rendermode InteractiveServer
@using SpotAnalysis.Data.Enums
@using SpotAnalysis.Services.DTOs
@using SpotAnalysis.Services.Services

@attribute [Authorize(Roles = "Admin")]

<AuthorizeView Roles="Admin">
    <NotAuthorized>
        <PageTitle>Zugriff verweigert</PageTitle>

        <div class="container py-4 flex-grow-1">
            <div class="alert alert-danger text-center" role="alert">
                <i class="bi bi-x-circle me-2"></i>
                Sie haben keinen Zugriff auf diesen Bereich.
            </div>
        </div>
    </NotAuthorized>
    <Authorized>
        <PageTitle>Nutzer bearbeiten – Tüpfeln Digital</PageTitle>

        <div class="container py-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold mb-0">Nutzer bearbeiten</h4>
            </div>

            @if (_user is null)
            {
                <p class="text-muted">Laden...</p>
            }
            else
            {
                <div class="card-form">
                    <div class="mb-4">
                        <label class="form-label-custom">Nutzername</label>
                        <input type="text" class="form-control input-custom"
                               value="@_user.UserName" readonly />
                    </div>

                    <div class="mb-4">
                        <label class="form-label-custom">Rollen</label>
                        <p class="hint-text">Bestimmt, welche Bereiche der Nutzer aufrufen darf</p>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var role in _availableRoles)
                            {
                                <label class="btn btn-pill @(role.IsAssigned ? "active" : "")"
                                       style="cursor: pointer;">
                                    <input type="checkbox" class="d-none"
                                           checked="@role.IsAssigned"
                                           @onchange="e => role.IsAssigned = (bool)(e.Value ?? false)" />
                                    @role.Role
                                </label>
                            }
                        </div>
                    </div>

                    @if (_errorMessage is not null)
                    {
                        <div class="alert alert-danger">@_errorMessage</div>
                    }

                    <div class="d-flex gap-3 justify-content-end">
                        <button class="btn btn-secondary" @onclick="NavigateBack">Abbrechen</button>
                        <button class="btn btn-primary-purple" @onclick="Update" disabled="@_saving">
                            @(_saving ? "Speichern..." : "Aktualisieren")
                        </button>
                    </div>
                </div>
            }
        </div>
    </Authorized>
</AuthorizeView>

@code {
    [Parameter] public required Guid UserId { get; set; }

    [Inject] private IAdminService AdminService { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;

    private ConfigUserDto? _user;
    private bool _saving;
    private string? _errorMessage;

    private readonly List<AssignableRole> _availableRoles = Enum.GetValues<Role>()
        .Select(role => new AssignableRole { Role = role, IsAssigned = false })
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        var user = await AdminService.GetUser(UserId);
        foreach (var role in user.Roles)
        {
            var slot = _availableRoles.SingleOrDefault(x => x.Role == role);
            if (slot is not null) slot.IsAssigned = true;
        }
        _user = user;
    }

    private async Task Update()
    {
        if (_user is null) return;

        _errorMessage = null;

        var assigned = _availableRoles.Where(x => x.IsAssigned).Select(x => x.Role).ToList();
        if (assigned.Count == 0)
        {
            _errorMessage = "Mindestens eine Rolle ist erforderlich.";
            return;
        }

        var rolesToAdd = assigned.Except(_user.Roles).ToList();
        var rolesToRemove = _user.Roles.Except(assigned).ToList();

        _saving = true;
        try
        {
            foreach (var role in rolesToAdd)
            {
                await AdminService.AddRoleToUser(UserId, role);
            }
            foreach (var role in rolesToRemove)
            {
                await AdminService.RemoveRoleFromUser(UserId, role);
            }
            NavigateBack();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void NavigateBack() => NavManager.NavigateTo("/admin/overview");

    private class AssignableRole
    {
        public Role Role { get; set; }
        public bool IsAssigned { get; set; }
    }
}
