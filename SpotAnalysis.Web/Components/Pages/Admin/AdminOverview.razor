@page "/admin/overview"
@rendermode InteractiveServer
@using SpotAnalysis.Data.Enums
@using SpotAnalysis.Services.DTOs
@using SpotAnalysis.Services.Services

<AuthorizeView Roles="Admin">
    <NotAuthorized>
        <PageTitle>Zugriff verweigert</PageTitle>

        <div class="container py-4 flex-grow-1">
            <div class="alert alert-danger text-center" role="alert">
                <i class="bi bi-x-circle me-2"></i>
                Sie haben keinen Zugriff auf diesen Bereich.
            </div>
        </div>
    </NotAuthorized>
    <Authorized>
        <PageTitle>Nutzerverwaltung – Tüpfeln Digital</PageTitle>

        <div class="container py-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold mb-0">Nutzerverwaltung</h4>
            </div>

            @* Filter Bar *@
            <div class="d-flex gap-2 mb-3 align-items-center flex-wrap">
                <input type="text" class="form-control input-custom flex-grow-1"
                       placeholder="Suchen (Nutzername)..."
                       @bind="_searchTerm" @bind:event="oninput" />
                <button class="btn btn-pill @(_roleFilter is null ? "active" : "")"
                        @onclick="() => _roleFilter = null">Alle</button>
                <button class="btn btn-pill @(_roleFilter == Role.Admin ? "active" : "")"
                        @onclick="() => _roleFilter = Role.Admin">Admin</button>
                <button class="btn btn-pill @(_roleFilter == Role.Teacher ? "active" : "")"
                        @onclick="() => _roleFilter = Role.Teacher">Teacher</button>
                <button class="btn btn-pill @(_roleFilter == Role.Student ? "active" : "")"
                        @onclick="() => _roleFilter = Role.Student">Student</button>
            </div>

            @if (_users is null)
            {
                <p class="text-muted">Laden...</p>
            }
            else if (_users.Count == 0)
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-people" style="font-size: 2.5rem;"></i>
                    <p class="mt-2">Keine Nutzer gefunden.</p>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-2">
                    @foreach (var u in FilteredUsers)
                    {
                        <div class="list-row">
                            <div class="flex-grow-1">
                                <div class="fw-semibold">@u.UserName</div>
                                <div class="d-flex gap-1 flex-wrap mt-1">
                                    @foreach (var role in u.Roles)
                                    {
                                        <span class="badge-role @RoleBadgeClass(role)">@role</span>
                                    }
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-edit"
                                        @onclick="() => EditUser(u.Id)">Bearbeiten</button>
                                <button class="btn btn-sm btn-delete"
                                        @onclick="() => ConfirmDelete(u)">Löschen</button>
                            </div>
                        </div>
                    }
                </div>
            }

            @* Delete Confirmation Modal *@
            @if (_userToDelete is not null)
            {
                <div class="modal-backdrop show"></div>
                <div class="modal d-block" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content" style="border-radius: var(--card-radius);">
                            <div class="modal-header border-0">
                                <h5 class="modal-title fw-bold">Nutzer löschen?</h5>
                            </div>
                            <div class="modal-body">
                                <p>
                                    Möchtest du den Nutzer <strong>"@_userToDelete.UserName"</strong> wirklich löschen?
                                </p>
                                <p class="text-danger small mb-0">
                                    <i class="bi bi-exclamation-triangle me-1"></i>
                                    Dabei werden auch alle Quiz-Versuche dieses Nutzers gelöscht.
                                </p>
                            </div>
                            <div class="modal-footer border-0">
                                <button class="btn btn-secondary" @onclick="CancelDelete">Abbrechen</button>
                                <button class="btn btn-danger" @onclick="DeleteUser">Löschen</button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (_errorMessage is not null)
            {
                <div class="alert alert-danger mt-3">@_errorMessage</div>
            }
        </div>
    </Authorized>
</AuthorizeView>

@code {
    [Inject] private IAdminService AdminService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private List<UserDto>? _users;
    private string _searchTerm = "";
    private Role? _roleFilter;
    private UserDto? _userToDelete;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var perRole = await Task.WhenAll(
            AdminService.GetUsersByRole(Role.Admin),
            AdminService.GetUsersByRole(Role.Teacher),
            AdminService.GetUsersByRole(Role.Student));

        _users = perRole.SelectMany(x => x)
            .DistinctBy(u => u.Id)
            .OrderBy(u => u.UserName, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private IEnumerable<UserDto> FilteredUsers =>
        _users?.Where(u =>
            (_roleFilter is null || u.Roles.Contains(_roleFilter.Value.ToString())) &&
            (string.IsNullOrEmpty(_searchTerm) ||
             u.UserName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
        ) ?? [];

    private static string RoleBadgeClass(string role) => role switch
    {
        nameof(Role.Admin) => "badge-admin",
        nameof(Role.Teacher) => "badge-teacher",
        nameof(Role.Student) => "badge-student",
        _ => ""
    };

    private void EditUser(Guid userId) =>
        Navigation.NavigateTo($"/admin/{userId}/edit");

    private void ConfirmDelete(UserDto u) => _userToDelete = u;
    private void CancelDelete() => _userToDelete = null;

    private async Task DeleteUser()
    {
        if (_userToDelete is null) return;
        _errorMessage = null;
        try
        {
            await AdminService.DeleteUser(_userToDelete.Id);
            _users?.RemoveAll(x => x.Id == _userToDelete.Id);
            _userToDelete = null;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _userToDelete = null;
        }
    }
}
