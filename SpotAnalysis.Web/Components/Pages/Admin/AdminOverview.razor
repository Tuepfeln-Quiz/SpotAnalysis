@page "/admin/overview"
@inject IAdminService AdminService

<div class="h-100">
    <div class="card card-body h-20 mb-2 border border-2">
            <form class="row" method="get" asp-page="/Search">
                <div class="search-container col-12">
                    <div class="row">
                        <button class="btn btn-primary col-2">Add</button>
                        <input type="text"
                               asp-for="SearchQuery"
                               placeholder="Search..."
                               class="search-input col-8" />
                        <button type="submit" class="search-btn col-2">&#128269</button>
                    </div>
                </div>
            </form>
    </div>
    <div class="card card-body h-50 mb-2 border border-2">
            <table class="table table-dark table-striped table-hover">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Rolle</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="12"><a class="btn btn-secondary" href="admin-overview/create">Create New Teacher</a></td>
                    </tr>

                    @foreach(var users in _users)
                    {
                        <tr>
                            <td>@users.UserName</td>
                            <td>@(string.Join(", ", users.Roles))</td>
                            <td>
                                <a class="btn btn-info" href="/admin/@users.Id/edit">Edit</a>
                                <button class="btn btn-danger" @onclick="() => Delete(users.Id)">Remove</button>
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
    </div>
</div>




@code {

    private readonly List<UserDto> _users = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Only load user list on first load. After that db loading is not needed anymore.
        if (!firstRender)
        {
            return;
        }
        
        var admins = await AdminService.GetUsersByRole(Role.Admin);
        _users.AddRange(admins);
        await InvokeAsync(StateHasChanged);
        
        var teachers = await AdminService.GetUsersByRole(Role.Teacher);
        _users.AddRange(teachers.ExceptBy(_users.Select(x => x.Id), x => x.Id));
        await InvokeAsync(StateHasChanged);
        
        var students = await AdminService.GetUsersByRole(Role.Student);
        _users.AddRange(students.ExceptBy(_users.Select(x => x.Id), x => x.Id));
        await InvokeAsync(StateHasChanged);
    }


    private async Task Delete(Guid userId)
    {
        await AdminService.DeleteUser(userId);
        _users.RemoveAll(a => a.Id == userId);
    }

}
