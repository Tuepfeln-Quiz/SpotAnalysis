@using SpotAnalysis.Services.DTOs;

@page "/admin-overview"

<div class="h-100">
    <div class="card card-body h-20 mb-2 border border-2">
            <form class="row" method="get" asp-page="/Search">
                <div class="search-container col-12">
                    <div class="row">
                        <button class="btn btn-primary col-2">Add</button>
                        <input type="text"
                               asp-for="SearchQuery"
                               placeholder="Search..."
                               class="search-input col-8" />
                        <button type="submit" class="search-btn col-2">&#128269</button>
                    </div>
                </div>
            </form>
    </div>
    <div class="card card-body h-50 mb-2 border border-2">
            <table class="table table-dark table-striped table-hover">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Rolle</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><a class="btn btn-secondary" href="admin-overview/create">Create New Teacher></a></td>
                    </tr>
                    <tr>
                        @foreach(var a in adminlist)
                        {
                            <td>@a.UserName</td>
                            <td>@a.Roles</td>
                            <td>
                                <a class="btn btn-info" href="admin-overview/edit">Edit</a>
                                <button class="btn btn-danger">Remove</button>
                            </td>
                        }
                    </tr>
                </tbody>
            </table>
            
    </div>
@*     <div class="h-20">
        <div class="row col-12">
            <button class="btn btn-danger col-6">Abandon Class</button>
            <button class="btn btn-success col-6">Save Class</button>
        </div>

    </div> *@

</div>




@code {

    List<TeacherAdminDto> adminlist = new List<TeacherAdminDto>();
}
