@page "/admin/groups/{Id:int}"
@rendermode InteractiveServer

@attribute [Authorize(Roles = "Admin")]

<PageTitle>Gruppendetails – Tüpfeln Digital</PageTitle>

@if (_userId != Guid.Empty)
{
    <GroupDetailPanel UserId="_userId" GroupId="Id" BaseRoute="/admin/groups" />
}

@code {
    [Parameter] public int Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;
    private Guid _userId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        _userId = Guid.Parse(auth.User.FindFirst(ClaimTypes.NameIdentifier)!.Value);
    }
}
