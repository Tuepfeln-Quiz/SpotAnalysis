@page "/"

<PageTitle>Tüpfeln Digital</PageTitle>

<div class="container py-4 flex-grow-1">
    <div class="row g-4 justify-content-center">
        <div class="col-sm-6 col-lg-4">
            <div class="card card-interactive h-100" @onclick='() => Navigate("/sandbox")'>
                <div class="card-body text-center p-4">
                    <div class="card-icon mb-3" style="background-color: #dbeafe;">
                        <i class="bi bi-moisture" style="color: #2563eb; font-size: 2rem;"></i>
                    </div>
                    <h5 class="card-title fw-bold">Sandbox</h5>
                    <p class="card-text text-muted">Frei experimentieren – Stoffe mischen und Reaktionen entdecken</p>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="card card-interactive h-100" @onclick='() => Navigate("/reverse")'>
                <div class="card-body text-center p-4">
                    <div class="card-icon mb-3" style="background-color: #fef3c7;">
                        <i class="bi bi-shuffle" style="color: #d97706; font-size: 2rem;"></i>
                    </div>
                    <h5 class="card-title fw-bold">Reverse</h5>
                    <p class="card-text text-muted">Reaktion erraten – Edukte sind vorgegeben</p>
                </div>
            </div>
        </div>
        <AuthorizeView>
            <Authorized>
                <div class="col-sm-6 col-lg-4">
                    <div class="card card-interactive h-100" @onclick='() => Navigate("/my-quizzes")'>
                        <div class="card-body text-center p-4">
                            <div class="card-icon mb-3" style="background-color: #ede9fe;">
                                <i class="bi bi-journal-check" style="color: #6b21a8; font-size: 2rem;"></i>
                            </div>
                            <h5 class="card-title fw-bold">Meine Quizzes</h5>
                            <p class="card-text text-muted">Von deinen Lehrern zugewiesene Quizzes starten</p>
                        </div>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@code {
    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private void Navigate(string url) => Navigation.NavigateTo(url);
}
