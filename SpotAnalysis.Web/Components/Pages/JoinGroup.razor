@page "/join/{Token}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using SpotAnalysis.Services.DTOs
@using SpotAnalysis.Services.Services

<PageTitle>Gruppe beitreten – Tüpfeln Digital</PageTitle>

<div class="container py-4" style="max-width: 640px;">
    @if (_state == State.Loading)
    {
        <p class="text-muted">Beitritt wird bearbeitet...</p>
    }
    else if (_state == State.Success)
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle me-2"></i>
            Du bist der Gruppe erfolgreich beigetreten.
        </div>
        <a class="btn btn-primary-purple" href="/quizzes">Zu den Quizzes</a>
    }
    else if (_state == State.AlreadyMember)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Du bist bereits Mitglied dieser Gruppe.
        </div>
        <a class="btn btn-primary-purple" href="/quizzes">Zu den Quizzes</a>
    }
    else
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @_errorMessage
        </div>
        <a class="btn btn-secondary" href="/">Zur Startseite</a>
    }
</div>

@code {
    [Parameter] public string Token { get; set; } = "";
    [Inject] private IGroupService GroupService { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private enum State { Loading, Success, AlreadyMember, Error }
    private State _state = State.Loading;
    private string _errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        var userIdClaim = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                        ?? auth.User.FindFirst("sub")?.Value;

        if (!Guid.TryParse(userIdClaim, out var userId))
        {
            _errorMessage = "Benutzerprofil konnte nicht gelesen werden. Bitte neu einloggen.";
            _state = State.Error;
            return;
        }

        var result = await GroupService.JoinGroupByToken(userId, Token);

        switch (result)
        {
            case JoinGroupResult.Success:
                _state = State.Success;
                break;
            case JoinGroupResult.AlreadyMember:
                _state = State.AlreadyMember;
                break;
            case JoinGroupResult.TokenExpired:
            case JoinGroupResult.TokenInvalid:
                _errorMessage = "Dieser Einladungslink ist ungültig oder abgelaufen. Bitte deine Lehrkraft um einen neuen Link.";
                _state = State.Error;
                break;
            case JoinGroupResult.GroupNotFound:
                _errorMessage = "Die zugehörige Gruppe existiert nicht mehr.";
                _state = State.Error;
                break;
            case JoinGroupResult.UserNotFound:
                _errorMessage = "Benutzerprofil konnte nicht gefunden werden.";
                _state = State.Error;
                break;
        }
    }
}
