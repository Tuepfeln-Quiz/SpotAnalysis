@page "/not-found"
@layout MainLayout

<PageTitle>Nicht gefunden</PageTitle>

<div class="container text-center mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">         
            <p class="lead mb-5 text-muted">
                Diese Seite wurde nicht gefunden.
            </p>

            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a href="/login" class="btn btn-outline-secondary px-3">Zum Login</a>
                <a href="/" class="btn btn-primary px-3">Zu den Quizzes</a>
                <AuthorizeView Roles="Teacher,Admin">
                    <Authorized>
                        <a href="/teacher" class="btn btn-primary px-3">Lehrerbereich</a>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</div>