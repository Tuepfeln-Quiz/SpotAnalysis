@page "/tupfeln/quiz/{QuizId:int}"
@inject NavigationManager Navigation

<PageTitle>@(quiz?.Name ?? "Quiz") – Tüpfeln Digital</PageTitle>

<PageHeader PageTitle="@(quiz?.Name ?? "Quiz")" />

@if (quiz == null)
{
    <div class="container py-4">
        <div class="alert alert-warning">Quiz nicht gefunden.</div>
    </div>
}
else if (quizCompleted)
{
    <!-- Quiz-Ergebnis -->
    <div class="container py-4 flex-grow-1">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-5 text-center">
                <i class="bi bi-trophy-fill text-warning" style="font-size: 3rem;"></i>
                <h3 class="fw-bold mt-3">Quiz abgeschlossen!</h3>
                <p class="text-muted fs-5 mb-4">Ergebnis pro Aufgabe:</p>

                <div class="d-flex flex-column gap-2 mb-4" style="max-width: 400px; margin: 0 auto;">
                    @for (int qi = 0; qi < quiz.Questions.Count; qi++)
                    {
                        var q = quiz.Questions[qi];
                        var score = questionScores.GetValueOrDefault(qi);
                        <div class="d-flex justify-content-between align-items-center p-2 rounded" style="background: #f8f9fa;">
                            <span>Aufgabe @(qi + 1)</span>
                            <span class="fw-bold @(score.correct == score.total ? "text-success" : "text-warning")">
                                @score.correct / @score.total
                            </span>
                        </div>
                    }
                </div>

                <div class="d-flex gap-3 justify-content-center">
                    <button class="btn btn-primary" @onclick="RestartQuiz">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Nochmal
                    </button>
                    <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/tupfeln")'>
                        <i class="bi bi-arrow-left me-1"></i> Zurück zur Übersicht
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    var question = CurrentQuestion;

    <div class="container py-4 flex-grow-1">
        <!-- Progress -->
        <div class="mb-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="fw-bold mb-0">@quiz.Name: Aufgabe @(currentQuestionIndex + 1)</h5>
                <span class="text-muted">@(currentQuestionIndex + 1) / @quiz.Questions.Count</span>
            </div>
            <div class="progress" style="height: 8px;">
                <div class="progress-bar bg-purple" style="width: @ProgressPercent%"></div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Hauptbereich -->
            <div class="col-lg-8">
                <!-- Aufgabenstellung -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-2">
                            <i class="bi bi-question-circle me-2 text-primary"></i>Aufgabe
                        </h5>
                        <p class="mb-0 fs-5">@question.Description</p>
                    </div>
                </div>

                <!-- Unbekannte Edukte -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-eye-slash me-2"></i>Unbekannte Edukte</h5>
                        <div class="d-flex flex-wrap gap-3">
                            @for (int i = 0; i < question.UnknownEducts.Count; i++)
                            {
                                var educt = question.UnknownEducts[i];
                                var idx = i;
                                var borderColor = "#ccc";
                                if (hasChecked && answerResults.TryGetValue(idx, out var correct))
                                    borderColor = correct == true ? "#16a34a" : "#dc2626";
                                else if (showSolution)
                                    borderColor = "#2563eb";

                                <div class="text-center">
                                    <div class="d-flex align-items-center justify-content-center rounded-3 border"
                                         style="width: 80px; height: 80px; background-color: @educt.Color; border-color: @borderColor !important; border-width: 3px !important;">
                                        <span class="fw-bold fs-5">@(idx + 1)</span>
                                    </div>
                                    @if (showSolution || (hasChecked && answerResults.GetValueOrDefault(idx) == false))
                                    {
                                        <small class="text-primary fw-semibold d-block mt-1">@educt.Formula</small>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Mischen / Testen -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-shuffle me-2"></i>Mischen / Testen</h5>

                        <div class="row g-2 align-items-center mb-3">
                            <div class="col-auto">
                                <select class="form-select" @bind="selectedLeft" disabled="@(hasChecked || showSolution)">
                                    <option value="-1">– Edukt wählen –</option>
                                    @for (int i = 0; i < question.UnknownEducts.Count; i++)
                                    {
                                        <option value="@i">Edukt @(i + 1)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-auto fw-bold">+</div>
                            <div class="col-auto">
                                <select class="form-select" @bind="selectedRight" disabled="@(hasChecked || showSolution)">
                                    <option value="">– Aktion wählen –</option>
                                    <optgroup label="Edukte">
                                        @for (int i = 0; i < question.UnknownEducts.Count; i++)
                                        {
                                            <option value="e:@i">Edukt @(i + 1)</option>
                                        }
                                    </optgroup>
                                    @if (question.AvailableChemicals.Count > 0)
                                    {
                                        <optgroup label="Zusatzstoffe">
                                            @foreach (var chem in question.AvailableChemicals)
                                            {
                                                <option value="c:@chem.ChemicalID">@chem.Name</option>
                                            }
                                        </optgroup>
                                    }
                                    @if (question.AvailableMethods.Count > 0)
                                    {
                                        <optgroup label="Methoden">
                                            @foreach (var method in question.AvailableMethods)
                                            {
                                                <option value="m:@method">@method</option>
                                            }
                                        </optgroup>
                                    }
                                </select>
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-primary" @onclick="ExecuteAction"
                                        disabled="@(selectedLeft < 0 || string.IsNullOrEmpty(selectedRight) || hasChecked || showSolution)">
                                    <i class="bi bi-play-fill me-1"></i> Ausführen
                                </button>
                            </div>
                        </div>

                        @if (actionError != null)
                        {
                            <div class="alert alert-warning py-2 mb-3">@actionError</div>
                        }

                        <!-- Aktionsprotokoll -->
                        @if (actionLog.Count > 0)
                        {
                            <h6 class="fw-semibold text-muted mt-3 mb-2">Aktionsprotokoll</h6>
                            <div class="table-responsive">
                                <table class="table table-sm table-striped mb-0">
                                    <thead>
                                        <tr>
                                            <th style="width: 30%;">Links</th>
                                            <th style="width: 5%;" class="text-center">+</th>
                                            <th style="width: 30%;">Rechts</th>
                                            <th style="width: 5%;" class="text-center">→</th>
                                            <th>Ergebnis</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var log in actionLog)
                                        {
                                            <tr>
                                                <td>@log.Left</td>
                                                <td class="text-center">+</td>
                                                <td>@log.Right</td>
                                                <td class="text-center">→</td>
                                                <td class="fw-semibold">@log.Result</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small mb-0">Noch keine Aktionen durchgeführt.</p>
                        }
                    </div>
                </div>

                <!-- Antworten -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-pencil-square me-2"></i>Antworten</h5>
                        <p class="text-muted small mb-3">Trage die Formel für jedes unbekannte Edukt ein.</p>

                        @for (int i = 0; i < question.UnknownEducts.Count; i++)
                        {
                            var idx = i;
                            var educt = question.UnknownEducts[idx];
                            var resultClass = "";
                            var icon = "";
                            if (hasChecked && answerResults.TryGetValue(idx, out var isCorrect))
                            {
                                resultClass = isCorrect == true ? "border-success" : "border-danger";
                                icon = isCorrect == true ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger";
                            }

                            <div class="row g-2 align-items-center mb-2">
                                <div class="col-auto">
                                    <div class="d-flex align-items-center justify-content-center rounded-2"
                                         style="width: 40px; height: 40px; background-color: @educt.Color; border: 1px solid #ccc;">
                                        <span class="fw-bold">@(idx + 1)</span>
                                    </div>
                                </div>
                                <div class="col">
                                    <input type="text" class="form-control @resultClass"
                                           placeholder="z.B. FeCl3"
                                           value="@answers[idx]"
                                           @onchange="(e) => answers[idx] = e.Value?.ToString() ?? string.Empty"
                                           disabled="@(hasChecked || showSolution)" />
                                </div>
                                @if (!string.IsNullOrEmpty(icon))
                                {
                                    <div class="col-auto">
                                        <i class="bi @icon fs-5"></i>
                                    </div>
                                }
                                @if (hasChecked && answerResults.GetValueOrDefault(idx) == false)
                                {
                                    <div class="col-auto">
                                        <small class="text-muted">Richtig: <strong>@educt.Formula</strong></small>
                                    </div>
                                }
                            </div>
                        }

                        <div class="d-flex gap-2 mt-3">
                            @if (!hasChecked && !showSolution)
                            {
                                <button class="btn btn-primary" @onclick="CheckAnswers">
                                    <i class="bi bi-check-lg me-1"></i> Überprüfen
                                </button>
                                <button class="btn btn-outline-secondary" @onclick="ShowSolution">
                                    <i class="bi bi-lightbulb me-1"></i> Lösung anzeigen
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-primary" @onclick="NextQuestion">
                                    <i class="bi bi-arrow-right me-1"></i>
                                    @(currentQuestionIndex + 1 < quiz.Questions.Count ? "Nächste Aufgabe" : "Ergebnis anzeigen")
                                </button>
                            }
                        </div>
                    </div>
                </div>

                <!-- Fragen-Navigation -->
                @if (quiz.Questions.Count > 1)
                {
                    <nav>
                        <div class="d-flex gap-2 justify-content-center">
                            @for (int qi = 0; qi < quiz.Questions.Count; qi++)
                            {
                                var qIdx = qi;
                                var active = qIdx == currentQuestionIndex;
                                var done = questionScores.ContainsKey(qIdx);
                                var btnClass = active ? "btn-primary" : done ? "btn-outline-success" : "btn-outline-secondary";
                                <button class="btn btn-sm @btnClass" disabled="@(!done && !active)"
                                        @onclick="() => GoToQuestion(qIdx)">
                                    Aufgabe @(qIdx + 1)
                                </button>
                            }
                        </div>
                    </nav>
                }
            </div>

            <!-- Seitenleiste -->
            <div class="col-lg-4">
                <!-- Methoden -->
                @if (question.AvailableMethods.Count > 0)
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-3"><i class="bi bi-tools me-2"></i>Methoden</h5>
                            @foreach (var method in question.AvailableMethods)
                            {
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <i class="bi bi-check2-circle text-success"></i>
                                    <span>@method</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Zusatzstoffe -->
                @if (question.AvailableChemicals.Count > 0)
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-3"><i class="bi bi-beaker me-2"></i>Zusatzstoffe</h5>
                            @foreach (var chem in question.AvailableChemicals)
                            {
                                <div class="compound-card mb-2" style="background-color: @chem.Color;">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="color-dot" style="background-color: @chem.Color; border: 1px solid #ccc;"></span>
                                        <div>
                                            <strong>@chem.Name</strong>
                                            <br /><small class="text-muted">@chem.Formula</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Hinweis -->
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-2"><i class="bi bi-info-circle me-2"></i>Hinweis</h6>
                        <p class="text-muted small mb-0">
                            Die Edukte sind nur durch ihre Eigenfarbe erkennbar.
                            Nutze die verfügbaren Methoden und Zusatzstoffe, um die Edukte zu identifizieren.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int QuizId { get; set; }

    private TupfelnQuizViewModel? quiz;
    private int currentQuestionIndex;
    private bool quizCompleted;

    // Misch-Aktion
    private int selectedLeft = -1;
    private string selectedRight = "";
    private string? actionError;
    private List<ActionLogEntry> actionLog = new();

    // Antworten
    private Dictionary<int, string> answers = new();
    private Dictionary<int, bool?> answerResults = new();
    private bool hasChecked;
    private bool showSolution;

    // Ergebnisse pro Frage
    private Dictionary<int, (int correct, int total)> questionScores = new();

    private TupfelnQuestionViewModel CurrentQuestion => quiz!.Questions[currentQuestionIndex];

    private int ProgressPercent => quiz!.Questions.Count > 0
        ? (int)((double)currentQuestionIndex / quiz.Questions.Count * 100)
        : 0;

    protected override void OnInitialized()
    {
        quiz = SeedData.TupfelnQuizzes.FirstOrDefault(q => q.QuizID == QuizId);
        if (quiz != null) InitQuestion();
    }

    private void InitQuestion()
    {
        var q = CurrentQuestion;
        answers = new();
        answerResults = new();
        for (int i = 0; i < q.UnknownEducts.Count; i++)
        {
            answers[i] = "";
            answerResults[i] = null;
        }
        actionLog.Clear();
        actionError = null;
        hasChecked = false;
        showSolution = false;
        selectedLeft = -1;
        selectedRight = "";
    }

    private void ExecuteAction()
    {
        if (selectedLeft < 0 || string.IsNullOrEmpty(selectedRight)) return;

        actionError = null;
        var q = CurrentQuestion;
        var leftEduct = q.UnknownEducts[selectedLeft];
        string leftLabel = $"Edukt {selectedLeft + 1}";
        string rightLabel;
        string result;

        if (selectedRight.StartsWith("e:"))
        {
            int rightIndex = int.Parse(selectedRight[2..]);
            if (rightIndex == selectedLeft)
            {
                actionError = "Du kannst ein Edukt nicht mit sich selbst mischen.";
                return;
            }
            var rightEduct = q.UnknownEducts[rightIndex];
            rightLabel = $"Edukt {rightIndex + 1}";
            var reaction = FindReaction(leftEduct.ChemicalID, rightEduct.ChemicalID);
            result = reaction?.ObservationDescription ?? "Keine Reaktion";
        }
        else if (selectedRight.StartsWith("c:"))
        {
            int chemId = int.Parse(selectedRight[2..]);
            var chem = q.AvailableChemicals.First(c => c.ChemicalID == chemId);
            rightLabel = chem.Name;
            var reaction = FindReaction(leftEduct.ChemicalID, chem.ChemicalID);
            result = reaction?.ObservationDescription ?? "Keine Reaktion";
        }
        else // m:methodName
        {
            string methodName = selectedRight[2..];
            rightLabel = methodName;
            result = leftEduct.MethodOutputs.GetValueOrDefault(methodName, "keine");
        }

        actionLog.Add(new ActionLogEntry { Left = leftLabel, Right = rightLabel, Result = result });
    }

    private void CheckAnswers()
    {
        var q = CurrentQuestion;
        int correctCount = 0;

        for (int i = 0; i < q.UnknownEducts.Count; i++)
        {
            var actual = q.UnknownEducts[i];
            var entered = answers.GetValueOrDefault(i, "").Trim();
            var isCorrect = MatchesFormula(entered, actual);
            answerResults[i] = isCorrect;
            if (isCorrect) correctCount++;
        }

        hasChecked = true;
        questionScores[currentQuestionIndex] = (correctCount, q.UnknownEducts.Count);
    }

    private void ShowSolution()
    {
        var q = CurrentQuestion;
        for (int i = 0; i < q.UnknownEducts.Count; i++)
        {
            answers[i] = q.UnknownEducts[i].Formula;
            answerResults[i] = null;
        }
        showSolution = true;
        questionScores[currentQuestionIndex] = (0, q.UnknownEducts.Count);
    }

    private void NextQuestion()
    {
        if (currentQuestionIndex + 1 < quiz!.Questions.Count)
        {
            currentQuestionIndex++;
            InitQuestion();
        }
        else
        {
            quizCompleted = true;
        }
    }

    private void GoToQuestion(int index)
    {
        if (index == currentQuestionIndex) return;
        currentQuestionIndex = index;
        InitQuestion();
    }

    private void RestartQuiz()
    {
        currentQuestionIndex = 0;
        quizCompleted = false;
        questionScores.Clear();
        InitQuestion();
    }

    private ReactionViewModel? FindReaction(int chem1Id, int chem2Id)
    {
        return SeedData.Reactions.FirstOrDefault(r =>
            (r.Chemical1ID == chem1Id && r.Chemical2ID == chem2Id) ||
            (r.Chemical1ID == chem2Id && r.Chemical2ID == chem1Id));
    }

    /// <summary>
    /// Matches student input against a chemical's formula or name.
    /// Normalizes subscript digits and is case-insensitive.
    /// </summary>
    private static bool MatchesFormula(string input, ChemicalViewModel chemical)
    {
        if (string.IsNullOrWhiteSpace(input)) return false;
        var normalized = NormalizeFormula(input);
        return normalized == NormalizeFormula(chemical.Formula)
            || normalized == NormalizeFormula(chemical.Name);
    }

    private static string NormalizeFormula(string formula)
    {
        return formula.Trim().ToLowerInvariant()
            .Replace("₀", "0").Replace("₁", "1").Replace("₂", "2")
            .Replace("₃", "3").Replace("₄", "4").Replace("₅", "5")
            .Replace("₆", "6").Replace("₇", "7").Replace("₈", "8")
            .Replace("₉", "9");
    }

    private class ActionLogEntry
    {
        public string Left { get; set; } = "";
        public string Right { get; set; } = "";
        public string Result { get; set; } = "";
    }
}
