@page "/sandbox"

<PageTitle>Sandbox – Tüpfeln Digital</PageTitle>


<div class="container py-4 flex-grow-1"
     @ondrop="DropOutside"
     @ondrop:preventDefault
     @ondragover:preventDefault>
    <div class="row g-4">
        <!-- Workspace -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-moisture me-2"></i>Mischbereich</h5>

                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <div class="drop-zone @(_dragOverSlot == 1 ? "drag-over" : "")"
                                 @ondrop="() => Drop(1)"
                                 @ondrop:preventDefault
                                 @ondrop:stopPropagation
                                 @ondragover="() => _dragOverSlot = 1"
                                 @ondragover:preventDefault
                                 @ondragleave="() => _dragOverSlot = 0">
                                @if (_slot1 != null)
                                {
                                    <div class="compound-card chemical-@(_slot1.ChemicalTypeName.ToLowerInvariant()) h-100"
                                         style="border-color: @ColorHelper.GetBorderColor(_slot1.Color)"
                                         draggable="true"
                                         @ondragstart="() => { _draggedChemical = _slot1; _dragSource = 1; }">
                                        <SubstanceCard Chemical="_slot1" />
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted">
                                        <i class="bi bi-plus-circle fs-3 d-block mb-2"></i>
                                        Stoff hierher ziehen
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="drop-zone @(_dragOverSlot == 2 ? "drag-over" : "")"
                                 @ondrop="() => Drop(2)"
                                 @ondrop:preventDefault
                                 @ondrop:stopPropagation
                                 @ondragover="() => _dragOverSlot = 2"
                                 @ondragover:preventDefault
                                 @ondragleave="() => _dragOverSlot = 0">
                                @if (_slot2 != null)
                                {
                                    <div class="compound-card chemical-@(_slot2.ChemicalTypeName.ToLowerInvariant()) h-100"
                                         style="border-color: @ColorHelper.GetBorderColor(_slot2.Color)"
                                         draggable="true"
                                         @ondragstart="() => { _draggedChemical = _slot2; _dragSource = 2; }">
                                        <SubstanceCard Chemical="_slot2" />
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted">
                                        <i class="bi bi-plus-circle fs-3 d-block mb-2"></i>
                                        Stoff hierher ziehen
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="Mix" disabled="@(_slot1 == null || _slot2 == null)">
                            <i class="bi bi-play-fill me-1"></i> Mischen
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="ClearSlots">
                            <i class="bi bi-arrow-counterclockwise me-1"></i> Zurücksetzen
                        </button>
                    </div>
                </div>
            </div>

            <!-- Result -->
            @if (_lastResult != null)
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-lightning-fill me-2 text-warning"></i>Ergebnis</h5>
                        @if (_lastResult.Reaction != null)
                        {
                            <div class="alert alert-success d-flex align-items-center gap-3 mb-0">
                                <div class="flex-grow-1">
                                    <strong><ChemFormula Value="@_lastResult.Reaction.Formula" /></strong>
                                    <br />
                                    <span>Produkt: @_lastResult.Reaction.RelevantProduct</span>
                                    <br />
                                    <em>@_lastResult.Reaction.ObservationDescription</em>
                                </div>
                                <img src="@(_lastResult.Reaction.ImagePath ?? "images/placeholder-reaction.svg")"
                                     class="rounded flex-shrink-0"
                                     style="width: 80px; height: 80px; object-fit: cover;"
                                     alt="Reaktionsbild" />
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-secondary d-flex align-items-center gap-3 mb-0">
                                <div class="flex-grow-1">
                                    <strong>Keine bekannte Reaktion</strong> zwischen @_lastResult.Chemical1Name und @_lastResult.Chemical2Name.
                                </div>
                                <img src="images/placeholder-reaction.svg"
                                     class="rounded flex-shrink-0"
                                     style="width: 80px; height: 80px; object-fit: cover;"
                                     alt="Kein Ergebnis" />
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Mix Log -->
            @if (_mixLog.Count > 0)
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0"><i class="bi bi-clock-history me-2"></i>Verlauf</h5>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _mixLog.Clear()">
                                Leeren
                            </button>
                        </div>
                        @foreach (var log in _mixLog.AsEnumerable().Reverse())
                        {
                            var cssClass = log.Reaction != null ? "neutral" : "neutral";
                            <div class="mix-log-item @cssClass">
                                <strong>@log.Chemical1Name</strong> + <strong>@log.Chemical2Name</strong>
                                @if (log.Reaction != null)
                                {
                                    <span class="text-muted"> → @log.Reaction.RelevantProduct</span>
                                }
                                else
                                {
                                    <span class="text-muted"> → Keine Reaktion</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Chemical Sidebar -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <input type="text" class="form-control form-control-lg mb-3"
                           placeholder="Stoffe suchen..."
                           @bind="_searchTerm"
                           @bind:event="oninput" />
                    @foreach (var group in FilteredChemicals.GroupBy(c => c.Type).OrderBy(g => g.Key))
                    {
                        <h6 class="text-muted fw-semibold mt-3 mb-2">@(group.Key == ChemicalType.Educt ? "Edukte" : "Zusatzstoffe")</h6>
                        <div class="d-flex flex-column gap-2 mb-2">
                            @foreach (var chem in group)
                            {
                                <div class="compound-card chemical-@(chem.ChemicalTypeName.ToLowerInvariant())"
                                     style="border-color: @ColorHelper.GetBorderColor(chem.Color)"
                                     draggable="true"
                                     @ondragstart="() => { _draggedChemical = chem; _dragSource = 0; }">
                                    <SubstanceCard Chemical="chem" />
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@inject IChemistryDataService ChemistryData

@code {
    private List<LabChemicalDto> _chemicals = [];
    private List<LabReactionDto> _reactions = [];

    private string _searchTerm = "";
    private LabChemicalDto? _draggedChemical;
    private int _dragSource; // 0 = sidebar, 1 = slot1, 2 = slot2
    private LabChemicalDto? _slot1;
    private LabChemicalDto? _slot2;
    private int _dragOverSlot;

    private MixLogViewModel? _lastResult;
    private readonly List<MixLogViewModel> _mixLog = [];
    private int _logCounter;

    private IEnumerable<LabChemicalDto> FilteredChemicals =>
        string.IsNullOrWhiteSpace(_searchTerm)
            ? _chemicals
            : _chemicals.Where(c =>
                c.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                c.Formula.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _chemicals = await ChemistryData.GetAllChemicalsAsync();
        _reactions = await ChemistryData.GetAllReactionsAsync();
    }

    private void Drop(int slot)
    {
        _dragOverSlot = 0;
        if (_draggedChemical == null) return;

        // Remove from source slot if dragged from a slot
        if (_dragSource == 1) _slot1 = null;
        if (_dragSource == 2) _slot2 = null;

        if (slot == 1)
            _slot1 = _draggedChemical;
        else
            _slot2 = _draggedChemical;

        _draggedChemical = null;
    }

    private void DropOutside()
    {
        // Dropped outside both slots → remove from source slot
        if (_dragSource == 1) _slot1 = null;
        if (_dragSource == 2) _slot2 = null;
        _draggedChemical = null;
        _dragOverSlot = 0;
    }

    private void Mix()
    {
        if (_slot1 == null || _slot2 == null) return;

        var reaction = FindReaction(_slot1.ChemicalID, _slot2.ChemicalID);

        var log = new MixLogViewModel
        {
            LogID = ++_logCounter,
            Chemical1Name = _slot1.Name,
            Chemical2Name = _slot2.Name,
            Reaction = reaction,
            Timestamp = DateTime.UtcNow
        };

        _lastResult = log;
        _mixLog.Add(log);
    }

    private void ClearSlots()
    {
        _slot1 = null;
        _slot2 = null;
        _dragOverSlot = 0;
    }

    private LabReactionDto? FindReaction(int chem1Id, int chem2Id)
    {
        return _reactions.FirstOrDefault(r =>
            (r.Chemical1ID == chem1Id && r.Chemical2ID == chem2Id) ||
            (r.Chemical1ID == chem2Id && r.Chemical2ID == chem1Id));
    }
}
