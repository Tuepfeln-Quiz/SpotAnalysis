@page "/tuepfeln"
@inject NavigationManager Navigation
@inject IChemistryDataService ChemistryData

<PageTitle>Tüpfeln – Tüpfeln Digital</PageTitle>

<PageHeader PageTitle="Tüpfeln" />

<div class="container py-4 flex-grow-1">
    <div class="mb-4">
        <h4 class="fw-bold">Quiz auswählen</h4>
        <p class="text-muted">Identifiziere unbekannte Edukte anhand von Tüpfelproben, pH-Papier und Flammenfärbung.</p>
    </div>

    <div class="row g-4">
        @foreach (var quiz in quizzes)
        {
            var totalEducts = quiz.Questions.Sum(q => q.UnknownEducts.Count);
            <div class="col-sm-6 col-lg-4">
                <div class="card card-interactive h-100" @onclick="() => NavigateToQuiz(quiz.QuizID)">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="badge bg-purple">Tüpfeln</span>
                            <span class="text-muted small">@quiz.Questions.Count Aufgaben</span>
                        </div>
                        <h5 class="card-title fw-bold mb-2">@quiz.Name</h5>
                        <p class="card-text text-muted small mb-0">
                            <i class="bi bi-search me-1"></i>
                            @totalEducts unbekannte Edukte identifizieren
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<SpotTestQuizDto> quizzes = new();

    protected override async Task OnInitializedAsync()
    {
        quizzes = await ChemistryData.GetSpotTestQuizzesAsync();
    }

    private void NavigateToQuiz(int quizId)
    {
        Navigation.NavigateTo($"/tuepfeln/quiz/{quizId}");
    }
}
