@page "/tuepfeln/quiz/{QuizId:int}"
@inject NavigationManager Navigation
@inject IChemistryDataService ChemistryData

<PageTitle>@(quiz?.Name ?? "Quiz") – Tüpfeln Digital</PageTitle>

@if (quiz == null)
{
    <div class="container py-4">
        <div class="alert alert-warning">Quiz nicht gefunden.</div>
    </div>
}
else if (quizCompleted)
{
    <!-- Quiz-Ergebnis -->
    <div class="container py-4 flex-grow-1">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-5 text-center">
                <i class="bi bi-trophy-fill text-warning" style="font-size: 3rem;"></i>
                <h3 class="fw-bold mt-3">Quiz abgeschlossen!</h3>
                <p class="text-muted fs-5 mb-4">Ergebnis pro Aufgabe:</p>

                <div class="d-flex flex-column gap-2 mb-4" style="max-width: 400px; margin: 0 auto;">
                    @for (int qi = 0; qi < quiz.Questions.Count; qi++)
                    {
                        var q = quiz.Questions[qi];
                        var score = questionScores.GetValueOrDefault(qi);
                        <div class="d-flex justify-content-between align-items-center p-2 rounded" style="background: #f8f9fa;">
                            <span>Aufgabe @(qi + 1)</span>
                            <span class="fw-bold @(score.correct == score.total ? "text-success" : "text-warning")">
                                @score.correct / @score.total
                            </span>
                        </div>
                    }
                </div>

                <div class="d-flex gap-3 justify-content-center">
                    <button class="btn btn-primary" @onclick="RestartQuiz">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Nochmal
                    </button>
                    <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/tuepfeln")'>
                        <i class="bi bi-arrow-left me-1"></i> Zurück zur Übersicht
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    var question = CurrentQuestion;

    <div class="container py-4 flex-grow-1"
         @ondrop="MixDropOutside"
         @ondrop:preventDefault
         @ondragover:preventDefault>
        <!-- Progress -->
        <div class="mb-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="fw-bold mb-0">@quiz.Name: Aufgabe @(currentQuestionIndex + 1)</h5>
                <span class="text-muted">@(currentQuestionIndex + 1) / @quiz.Questions.Count</span>
            </div>
            <div class="progress" style="height: 8px;">
                <div class="progress-bar bg-purple" style="width: @ProgressPercent%"></div>
            </div>
        </div>

        <!-- Aufgabenstellung -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-2">
                    <i class="bi bi-question-circle me-2 text-primary"></i>Aufgabe
                </h5>
                <p class="mb-0 fs-5">@question.Description</p>
            </div>
        </div>

        <!-- Unbekannte Edukte -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-eye-slash me-2"></i>Unbekannte Edukte</h5>
                <div class="d-flex flex-wrap gap-3">
                    @for (int i = 0; i < question.UnknownEducts.Count; i++)
                    {
                        var educt = question.UnknownEducts[i];
                        var idx = i;
                        var eigenfarbe = string.IsNullOrWhiteSpace(educt.Color) ? null : educt.Color;
                        var phPaper = educt.MethodOutputs.GetValueOrDefault("pH-Papier");
                        var flame = educt.MethodOutputs.GetValueOrDefault("Flammenfärbung");

                        var borderColor = ColorHelper.GetBorderColor(eigenfarbe);
                        if (hasChecked && answerResults.TryGetValue(idx, out var correct))
                            borderColor = correct == true ? "#16a34a" : "#dc2626";
                        else if (dragOverEductIndex == idx)
                            borderColor = "#6b21a8";

                        <div class="educt-box chemical-@(educt.ChemicalTypeName.ToLowerInvariant()) @(dragOverEductIndex == idx ? "drag-over" : "")"
                             style="border-color: @borderColor;"
                             draggable="true"
                             @ondragstart="() => StartDragEduct(idx)"
                             @ondrop="() => HandleDropOnEduct(idx)"
                             @ondrop:preventDefault
                             @ondrop:stopPropagation
                             @ondragover="() => dragOverEductIndex = idx"
                             @ondragover:preventDefault
                             @ondragleave="() => { if (dragOverEductIndex == idx) dragOverEductIndex = -1; }">
                            <!-- Zeile 1: Nummer + Formel-Input -->
                            <div class="d-flex align-items-baseline gap-2">
                                <span class="fw-bold fs-5">@(idx + 1)</span>
                                <input type="text" class="form-control form-control-sm flex-grow-1 @GetAnswerResultClass(idx)"
                                       placeholder="Formel"
                                       value="@answers[idx]"
                                       @onchange="(e) => answers[idx] = e.Value?.ToString() ?? string.Empty"
                                       disabled="@(hasChecked || showSolution)" />
                                @if (hasChecked && answerResults.TryGetValue(idx, out var isCorrect) && isCorrect != null)
                                {
                                    <i class="bi @(isCorrect == true ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger")"></i>
                                }
                            </div>
                            @if (hasChecked && answerResults.GetValueOrDefault(idx) == false)
                            {
                                <small class="text-muted">Richtig: <strong><ChemFormula Value="@educt.Formula" /></strong></small>
                            }
                            <!-- Zeile 2: Färbungen -->
                            <div class="d-flex flex-wrap gap-2 mt-1">
                                @if (eigenfarbe != null)
                                {
                                    <small title="Eigenfarbe" style="color: @ColorHelper.GetCssColor(eigenfarbe);"><strong><TestTubeIcon /> @eigenfarbe</strong></small>
                                }
                                @if (revealedMethods.GetValueOrDefault(idx)?.Contains("Flammenfärbung") == true && flame != null)
                                {
                                    <small title="Flammenfärbung" style="color: @ColorHelper.GetCssColor(flame);"><strong><FlameIcon /> @flame</strong></small>
                                }
                                @if (revealedMethods.GetValueOrDefault(idx)?.Contains("pH-Papier") == true && phPaper != null)
                                {
                                    <small title="pH-Papier Färbung" style="color: @ColorHelper.GetCssColor(phPaper);"><strong><PhPaperIcon /> @phPaper</strong></small>
                                }
                            </div>
                        </div>
                    }
                </div>

                <!-- Buttons -->
                <div class="d-flex gap-2 mt-4">
                    @if (!hasChecked)
                    {
                        <button class="btn btn-primary" @onclick="CheckAnswers"
                                disabled="@(answers.Values.Any(a => string.IsNullOrWhiteSpace(a)))">
                            <i class="bi bi-check-lg me-1"></i> Überprüfen
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary" @onclick="NextQuestion">
                            <i class="bi bi-arrow-right me-1"></i>
                            @(currentQuestionIndex + 1 < quiz.Questions.Count ? "Nächste Aufgabe" : "Ergebnis anzeigen")
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Mischbereich -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-moisture me-2"></i>Mischbereich</h5>

                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="drop-zone @(mixSlot1Label != null ? "" : "") @(mixDragOverSlot == 1 ? "drag-over" : "")"
                             @ondrop="() => MixDrop(1)"
                             @ondrop:preventDefault
                             @ondrop:stopPropagation
                             @ondragover="() => mixDragOverSlot = 1"
                             @ondragover:preventDefault
                             @ondragleave="() => mixDragOverSlot = 0">
                            @if (mixSlot1Label != null)
                            {
                                <div class="compound-card chemical-edukt d-flex align-items-center justify-content-center"
                                     draggable="true"
                                     @ondragstart="() => { mixDragSource = 1; }">
                                    <strong>@mixSlot1Label</strong>
                                </div>
                            }
                            else
                            {
                                <div class="text-muted">
                                    <i class="bi bi-plus-circle fs-3 d-block mb-2"></i>
                                    Hierher ziehen
                                </div>
                            }
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="drop-zone @(mixSlot2Label != null ? "" : "") @(mixDragOverSlot == 2 ? "drag-over" : "")"
                             @ondrop="() => MixDrop(2)"
                             @ondrop:preventDefault
                             @ondrop:stopPropagation
                             @ondragover="() => mixDragOverSlot = 2"
                             @ondragover:preventDefault
                             @ondragleave="() => mixDragOverSlot = 0">
                            @if (mixSlot2Label != null)
                            {
                                <div class="compound-card d-flex align-items-center justify-content-center @(mixSlot2Type == "chemical" ? "chemical-zusatzstoff" : "chemical-edukt")"
                                     draggable="true"
                                     @ondragstart="() => { mixDragSource = 2; }">
                                    <strong>@mixSlot2Label</strong>
                                </div>
                            }
                            else
                            {
                                <div class="text-muted">
                                    <i class="bi bi-plus-circle fs-3 d-block mb-2"></i>
                                    Hierher ziehen
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary" @onclick="ExecuteMix" disabled="@(mixSlot1Type == null || mixSlot2Type == null || hasChecked || showSolution)">
                        <i class="bi bi-play-fill me-1"></i> Mischen
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="ClearMixSlots">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Zurücksetzen
                    </button>
                </div>

                @if (mixError != null)
                {
                    <div class="alert alert-warning py-2 mt-3 mb-0">@mixError</div>
                }
            </div>
        </div>

        <!-- Aktionsprotokoll -->
        @if (actionLog.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-clock-history me-2"></i>Aktionsprotokoll</h5>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 30%;">Links</th>
                                    <th style="width: 5%;" class="text-center">+</th>
                                    <th style="width: 30%;">Rechts</th>
                                    <th style="width: 5%;" class="text-center">→</th>
                                    <th>Ergebnis</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in actionLog)
                                {
                                    <tr>
                                        <td>@log.Left</td>
                                        <td class="text-center">+</td>
                                        <td>@log.Right</td>
                                        <td class="text-center">→</td>
                                        <td class="fw-semibold">@log.Result</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Fragen-Navigation -->
        @if (quiz.Questions.Count > 1)
        {
            <nav>
                <div class="d-flex gap-2 justify-content-center">
                    @for (int qi = 0; qi < quiz.Questions.Count; qi++)
                    {
                        var qIdx = qi;
                        var active = qIdx == currentQuestionIndex;
                        var done = questionScores.ContainsKey(qIdx);
                        var btnClass = active ? "btn-primary" : done ? "btn-outline-success" : "btn-outline-secondary";
                        <button class="btn btn-sm @btnClass" disabled="@(!done && !active)"
                                @onclick="() => GoToQuestion(qIdx)">
                            Aufgabe @(qIdx + 1)
                        </button>
                    }
                </div>
            </nav>
        }
    </div>

    <!-- Slide-Out Toggle Button -->
    <button class="tools-panel-toggle" @onclick="() => toolsPanelOpen = !toolsPanelOpen">
        <i class="bi @(toolsPanelOpen ? "bi-x-lg" : "bi-tools")"></i>
    </button>

    <!-- Slide-Out Tools Panel -->
    <div class="tools-panel @(toolsPanelOpen ? "open" : "")">
        <h5 class="fw-bold mb-3"><i class="bi bi-tools me-2"></i>Werkzeuge</h5>

        <!-- Methoden -->
        @if (question.AvailableMethods.Count > 0)
        {
            <h6 class="text-muted fw-semibold mt-3 mb-2">Methoden</h6>
            <div class="d-flex flex-column gap-2 mb-3">
                @foreach (var method in question.AvailableMethods)
                {
                    <div class="compound-card compound-card-static chemical-edukt"
                         draggable="true"
                         style="cursor: grab;"
                         @ondragstart="() => StartDragMethod(method)">
                        @if (method == "pH-Papier")
                        {
                            <strong><PhPaperIcon Size="16" /> @method</strong>
                        }
                        else if (method == "Flammenfärbung")
                        {
                            <strong><FlameIcon Size="16" /> @method</strong>
                        }
                        else
                        {
                            <strong>@method</strong>
                        }
                    </div>
                }
            </div>
        }

        <!-- Zusatzstoffe -->
        @if (question.AvailableChemicals.Count > 0)
        {
            <h6 class="text-muted fw-semibold mt-3 mb-2">Zusatzstoffe</h6>
            <div class="d-flex flex-column gap-2 mb-3">
                @foreach (var chem in question.AvailableChemicals)
                {
                    <div class="compound-card chemical-@(chem.ChemicalTypeName.ToLowerInvariant())"
                         style="border-color: @ColorHelper.GetBorderColor(chem.Color); cursor: grab;"
                         draggable="true"
                         @ondragstart="() => StartDragChemical(chem)">
                        <SubstanceCard Chemical="chem" />
                    </div>
                }
            </div>
        }

    </div>
}

@code {
    [Parameter]
    public int QuizId { get; set; }

    private SpotTestQuizDto? quiz;
    private List<LabReactionDto> allReactions = new();
    private int currentQuestionIndex;
    private bool quizCompleted;

    // Antworten
    private Dictionary<int, string> answers = new();
    private Dictionary<int, bool?> answerResults = new();
    private bool hasChecked;
    private bool showSolution;

    // Ergebnisse pro Frage
    private Dictionary<int, (int correct, int total)> questionScores = new();

    // Aktionsprotokoll
    private List<ActionLogEntry> actionLog = new();

    // Slide-Out Panel
    private bool toolsPanelOpen = false;

    // Drag-and-Drop State
    private string? dragType;
    private string? dragMethodName;
    private LabChemicalDto? dragChemical;
    private int dragEductIndex = -1;
    private int dragOverEductIndex = -1;

    // Mischbereich Slots
    private string? mixSlot1Type;  // "educt", "method"
    private int mixSlot1EductIdx = -1;
    private string? mixSlot1MethodName;
    private string? mixSlot1Label;

    private string? mixSlot2Type;  // "educt", "chemical", "method"
    private int mixSlot2EductIdx = -1;
    private LabChemicalDto? mixSlot2Chemical;
    private string? mixSlot2MethodName;
    private string? mixSlot2Label;

    private int mixDragOverSlot;
    private int mixDragSource; // 0 = none, 1 = slot1, 2 = slot2
    private string? mixError;

    // Tracking enthüllter Methoden pro Edukt
    private Dictionary<int, HashSet<string>> revealedMethods = new();

    private SpotTestQuestionDto CurrentQuestion => quiz!.Questions[currentQuestionIndex];

    private int ProgressPercent => quiz!.Questions.Count > 0
        ? (int)((double)currentQuestionIndex / quiz.Questions.Count * 100)
        : 0;

    protected override async Task OnInitializedAsync()
    {
        quiz = await ChemistryData.GetSpotTestQuizAsync(QuizId);
        allReactions = await ChemistryData.GetAllReactionsAsync();
        if (quiz != null) InitQuestion();
    }

    private void InitQuestion()
    {
        var q = CurrentQuestion;
        answers = new();
        answerResults = new();
        revealedMethods = new();
        for (int i = 0; i < q.UnknownEducts.Count; i++)
        {
            answers[i] = "";
            answerResults[i] = null;
            revealedMethods[i] = new HashSet<string>();
        }
        actionLog.Clear();
        hasChecked = false;
        showSolution = false;
        toolsPanelOpen = false;
        mixError = null;
        ClearMixSlots();
        ResetDragState();
    }

    // ── Drag-and-Drop ────────────────────────────────────────────────

    private void StartDragMethod(string methodName)
    {
        dragType = "method";
        dragMethodName = methodName;
        dragChemical = null;
        dragEductIndex = -1;
    }

    private void StartDragChemical(LabChemicalDto chem)
    {
        dragType = "chemical";
        dragChemical = chem;
        dragMethodName = null;
        dragEductIndex = -1;
    }

    private void StartDragEduct(int index)
    {
        dragType = "educt";
        dragEductIndex = index;
        dragMethodName = null;
        dragChemical = null;
    }

    private void HandleDropOnEduct(int targetIndex)
    {
        dragOverEductIndex = -1;
        if (hasChecked || showSolution) return;

        var q = CurrentQuestion;

        if (dragType == "method" && dragMethodName != null)
        {
            revealedMethods[targetIndex].Add(dragMethodName);
            var educt = q.UnknownEducts[targetIndex];
            var result = educt.MethodOutputs.GetValueOrDefault(dragMethodName, "keine");
            actionLog.Add(new ActionLogEntry
            {
                Left = $"Edukt {targetIndex + 1}",
                Right = dragMethodName,
                Result = result
            });
        }
        else if (dragType == "chemical" && dragChemical != null)
        {
            var educt = q.UnknownEducts[targetIndex];
            var reaction = FindReaction(educt.ChemicalID, dragChemical.ChemicalID);
            actionLog.Add(new ActionLogEntry
            {
                Left = $"Edukt {targetIndex + 1}",
                Right = dragChemical.Name,
                Result = reaction?.ObservationDescription ?? "Keine Reaktion"
            });
        }
        else if (dragType == "educt" && dragEductIndex >= 0)
        {
            if (dragEductIndex == targetIndex) { ResetDragState(); return; }
            var leftEduct = q.UnknownEducts[dragEductIndex];
            var rightEduct = q.UnknownEducts[targetIndex];
            var reaction = FindReaction(leftEduct.ChemicalID, rightEduct.ChemicalID);
            actionLog.Add(new ActionLogEntry
            {
                Left = $"Edukt {dragEductIndex + 1}",
                Right = $"Edukt {targetIndex + 1}",
                Result = reaction?.ObservationDescription ?? "Keine Reaktion"
            });
        }

        ResetDragState();
    }

    private void ResetDragState()
    {
        dragType = null;
        dragMethodName = null;
        dragChemical = null;
        dragEductIndex = -1;
        dragOverEductIndex = -1;
    }

    // ── Mischbereich ──────────────────────────────────────────────────

    private void MixDropOutside()
    {
        if (mixDragSource == 1) { mixSlot1Type = null; mixSlot1Label = null; mixSlot1EductIdx = -1; mixSlot1MethodName = null; }
        if (mixDragSource == 2) { mixSlot2Type = null; mixSlot2Label = null; mixSlot2EductIdx = -1; mixSlot2Chemical = null; mixSlot2MethodName = null; }
        mixDragSource = 0;
        mixDragOverSlot = 0;
    }

    private void MixDrop(int slot)
    {
        mixDragOverSlot = 0;

        // If dragged from another mix slot, clear source
        if (mixDragSource == 1) { mixSlot1Type = null; mixSlot1Label = null; mixSlot1EductIdx = -1; mixSlot1MethodName = null; }
        if (mixDragSource == 2) { mixSlot2Type = null; mixSlot2Label = null; mixSlot2EductIdx = -1; mixSlot2Chemical = null; mixSlot2MethodName = null; }
        mixDragSource = 0;

        if (dragType == null) return;

        if (slot == 1)
        {
            // Slot 1 akzeptiert: Edukt oder Methode
            if (dragType == "educt" && dragEductIndex >= 0)
            {
                mixSlot1Type = "educt";
                mixSlot1EductIdx = dragEductIndex;
                mixSlot1Label = $"Edukt {dragEductIndex + 1}";
            }
            else if (dragType == "method" && dragMethodName != null)
            {
                mixSlot1Type = "method";
                mixSlot1MethodName = dragMethodName;
                mixSlot1Label = dragMethodName;
            }
            else return;
        }
        else
        {
            // Slot 2 akzeptiert: Edukt, Zusatzstoff oder Methode
            if (dragType == "educt" && dragEductIndex >= 0)
            {
                mixSlot2Type = "educt";
                mixSlot2EductIdx = dragEductIndex;
                mixSlot2Label = $"Edukt {dragEductIndex + 1}";
            }
            else if (dragType == "chemical" && dragChemical != null)
            {
                mixSlot2Type = "chemical";
                mixSlot2Chemical = dragChemical;
                mixSlot2Label = dragChemical.Name;
            }
            else if (dragType == "method" && dragMethodName != null)
            {
                mixSlot2Type = "method";
                mixSlot2MethodName = dragMethodName;
                mixSlot2Label = dragMethodName;
            }
            else return;
        }

        ResetDragState();
    }

    private void ExecuteMix()
    {
        if (mixSlot1Type == null || mixSlot2Type == null) return;
        mixError = null;

        var q = CurrentQuestion;

        // Edukt + Edukt
        if (mixSlot1Type == "educt" && mixSlot2Type == "educt")
        {
            if (mixSlot1EductIdx == mixSlot2EductIdx)
            {
                mixError = "Du kannst ein Edukt nicht mit sich selbst mischen.";
                return;
            }
            var left = q.UnknownEducts[mixSlot1EductIdx];
            var right = q.UnknownEducts[mixSlot2EductIdx];
            var reaction = FindReaction(left.ChemicalID, right.ChemicalID);
            actionLog.Add(new ActionLogEntry
            {
                Left = $"Edukt {mixSlot1EductIdx + 1}",
                Right = $"Edukt {mixSlot2EductIdx + 1}",
                Result = reaction?.ObservationDescription ?? "Keine Reaktion"
            });
        }
        // Edukt + Zusatzstoff
        else if (mixSlot1Type == "educt" && mixSlot2Type == "chemical" && mixSlot2Chemical != null)
        {
            var educt = q.UnknownEducts[mixSlot1EductIdx];
            var reaction = FindReaction(educt.ChemicalID, mixSlot2Chemical.ChemicalID);
            actionLog.Add(new ActionLogEntry
            {
                Left = $"Edukt {mixSlot1EductIdx + 1}",
                Right = mixSlot2Chemical.Name,
                Result = reaction?.ObservationDescription ?? "Keine Reaktion"
            });
        }
        // Edukt + Methode (in beliebiger Slot-Reihenfolge)
        else if (mixSlot1Type == "educt" && mixSlot2Type == "method" && mixSlot2MethodName != null)
        {
            ApplyMethodToEduct(mixSlot1EductIdx, mixSlot2MethodName);
        }
        else if (mixSlot1Type == "method" && mixSlot2Type == "educt" && mixSlot1MethodName != null)
        {
            ApplyMethodToEduct(mixSlot2EductIdx, mixSlot1MethodName);
        }
        else
        {
            mixError = "Diese Kombination ist nicht möglich.";
            return;
        }
    }

    private void ApplyMethodToEduct(int eductIdx, string methodName)
    {
        var q = CurrentQuestion;
        revealedMethods[eductIdx].Add(methodName);
        var educt = q.UnknownEducts[eductIdx];
        var result = educt.MethodOutputs.GetValueOrDefault(methodName, "keine");
        actionLog.Add(new ActionLogEntry
        {
            Left = $"Edukt {eductIdx + 1}",
            Right = methodName,
            Result = result
        });
    }

    private void ClearMixSlots()
    {
        mixSlot1Type = null;
        mixSlot1EductIdx = -1;
        mixSlot1MethodName = null;
        mixSlot1Label = null;
        mixSlot2Type = null;
        mixSlot2EductIdx = -1;
        mixSlot2Chemical = null;
        mixSlot2MethodName = null;
        mixSlot2Label = null;
        mixDragOverSlot = 0;
        mixError = null;
    }

    // ── Antworten ────────────────────────────────────────────────────

    private string GetAnswerResultClass(int idx)
    {
        if (hasChecked && answerResults.TryGetValue(idx, out var isCorrect) && isCorrect != null)
            return isCorrect == true ? "border-success" : "border-danger";
        return "";
    }

    private void CheckAnswers()
    {
        var q = CurrentQuestion;
        int correctCount = 0;

        for (int i = 0; i < q.UnknownEducts.Count; i++)
        {
            var actual = q.UnknownEducts[i];
            var entered = answers.GetValueOrDefault(i, "").Trim();
            var isCorrect = MatchesFormula(entered, actual);
            answerResults[i] = isCorrect;
            if (isCorrect) correctCount++;
        }

        hasChecked = true;
        questionScores[currentQuestionIndex] = (correctCount, q.UnknownEducts.Count);
    }

    private void ShowSolution()
    {
        var q = CurrentQuestion;
        for (int i = 0; i < q.UnknownEducts.Count; i++)
        {
            answers[i] = q.UnknownEducts[i].Formula;
            answerResults[i] = null;
        }
        showSolution = true;
        questionScores[currentQuestionIndex] = (0, q.UnknownEducts.Count);
    }

    // ── Navigation ───────────────────────────────────────────────────

    private void NextQuestion()
    {
        if (currentQuestionIndex + 1 < quiz!.Questions.Count)
        {
            currentQuestionIndex++;
            InitQuestion();
        }
        else
        {
            quizCompleted = true;
        }
    }

    private void GoToQuestion(int index)
    {
        if (index == currentQuestionIndex) return;
        currentQuestionIndex = index;
        InitQuestion();
    }

    private void RestartQuiz()
    {
        currentQuestionIndex = 0;
        quizCompleted = false;
        questionScores.Clear();
        InitQuestion();
    }

    // ── Helpers ──────────────────────────────────────────────────────

    private LabReactionDto? FindReaction(int chem1Id, int chem2Id)
    {
        return allReactions.FirstOrDefault(r =>
            (r.Chemical1ID == chem1Id && r.Chemical2ID == chem2Id) ||
            (r.Chemical1ID == chem2Id && r.Chemical2ID == chem1Id));
    }

    private static bool MatchesFormula(string input, LabChemicalDto chemical)
    {
        if (string.IsNullOrWhiteSpace(input)) return false;
        var normalized = NormalizeFormula(input);
        return normalized == NormalizeFormula(chemical.Formula)
            || normalized == NormalizeFormula(chemical.Name);
    }

    private static string NormalizeFormula(string formula)
    {
        return formula.Trim().ToLowerInvariant()
            .Replace("₀", "0").Replace("₁", "1").Replace("₂", "2")
            .Replace("₃", "3").Replace("₄", "4").Replace("₅", "5")
            .Replace("₆", "6").Replace("₇", "7").Replace("₈", "8")
            .Replace("₉", "9");
    }

    private class ActionLogEntry
    {
        public string Left { get; set; } = "";
        public string Right { get; set; } = "";
        public string Result { get; set; } = "";
    }
}
