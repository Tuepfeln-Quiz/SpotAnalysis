@page "/teacher/groups/new"
@page "/teacher/groups/{Id:int}/edit"
@rendermode InteractiveServer

@attribute [Authorize(Roles = "Teacher, Admin")]

<PageTitle>@(Id.HasValue ? "Gruppe bearbeiten" : "Neue Gruppe") – Tüpfeln Digital</PageTitle>

@if (_userId != Guid.Empty)
{
    <GroupEditorForm UserId="_userId" BaseRoute="/teacher/groups" GroupId="Id" />
}

@code {
    [Parameter] public int? Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;
    private Guid _userId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        _userId = Guid.Parse(auth.User.FindFirst(ClaimTypes.NameIdentifier)!.Value);
    }
}
