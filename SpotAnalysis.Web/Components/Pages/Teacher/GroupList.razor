@page "/teacher/groups"
@rendermode InteractiveServer

@attribute [Authorize(Roles = "Teacher, Admin")]

<PageTitle>Gruppen – Tüpfeln Digital</PageTitle>

@if (_userId != Guid.Empty)
{
    <GroupListPanel UserId="_userId" BaseRoute="/teacher/groups" />
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;
    private Guid _userId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        _userId = Guid.Parse(auth.User.FindFirst(ClaimTypes.NameIdentifier)!.Value);
    }
}
