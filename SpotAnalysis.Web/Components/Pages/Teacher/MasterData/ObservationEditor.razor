@inject IMasterDataService MasterData

<div class="modal-backdrop show"></div>
<div class="modal d-block" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: var(--card-radius);">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">@(Dto.Id == 0 ? "Neue Beobachtung" : "Beobachtung bearbeiten")</h5>
            </div>
            <div class="modal-body">
                <EditForm Model="Dto" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label-custom">Beschreibung</label>
                        <InputTextArea class="form-control input-custom" rows="3" @bind-Value="Dto.Description" />
                        <ValidationMessage For="() => Dto.Description" />
                    </div>

                    @if (!string.IsNullOrEmpty(_saveError))
                    {
                        <div class="alert alert-danger">@_saveError</div>
                    }

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-secondary" @onclick="OnCancel">Abbrechen</button>
                        <button type="submit" class="btn btn-primary-purple" disabled="@_saving">
                            @(_saving ? "Speichern..." : "Speichern")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public ObservationDetailDto Dto { get; set; } = default!;
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private string? _saveError;
    private bool _saving;

    private async Task SaveAsync()
    {
        _saveError = null;
        _saving = true;
        try
        {
            if (Dto.Id == 0)
                Dto.Id = await MasterData.CreateObservationAsync(Dto);
            else
                await MasterData.UpdateObservationAsync(Dto);

            await OnSaved.InvokeAsync();
        }
        catch (InvalidOperationException ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
