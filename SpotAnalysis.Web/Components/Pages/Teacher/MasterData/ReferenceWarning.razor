@if (IsVisible)
{
    <div class="modal-backdrop show"></div>
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content" style="border-radius: var(--card-radius);">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">@Title</h5>
                </div>
                <div class="modal-body">
                    @if (Report is null || Report.Total == 0)
                    {
                        <p>@ConfirmQuestion</p>
                    }
                    else
                    {
                        <p class="text-danger">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Dieser Eintrag wird noch verwendet und kann daher nicht gelöscht werden.
                        </p>
                        <ul class="small">
                            @foreach (var item in Report.Items)
                            {
                                <li>
                                    <span class="text-muted">@item.Kind:</span>
                                    @if (!string.IsNullOrEmpty(item.RouteTemplate))
                                    {
                                        var href = string.Format(item.RouteTemplate, item.Id);
                                        <a href="@href" target="_blank">@item.Description</a>
                                    }
                                    else
                                    {
                                        @item.Description
                                    }
                                </li>
                            }
                        </ul>
                    }
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-secondary" @onclick="OnCancel">Abbrechen</button>
                    @if (Report is null || Report.Total == 0)
                    {
                        <button class="btn btn-danger" @onclick="OnConfirm">Löschen</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Title { get; set; } = "Eintrag löschen?";
    [Parameter] public string ConfirmQuestion { get; set; } = "Möchtest du diesen Eintrag wirklich löschen?";
    [Parameter] public ReferenceReport? Report { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
}
