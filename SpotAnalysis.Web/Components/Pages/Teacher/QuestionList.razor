@page "/teacher/questions"
@rendermode InteractiveServer
@using SpotAnalysis.Web.Services

@attribute [Authorize(Roles = "Teacher, Admin")]

<PageTitle>Fragen-Pool – Tüpfeln Digital</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0">Fragen-Pool</h4>
        <button class="btn btn-primary-purple" @onclick="CreateQuestion">
            <i class="bi bi-plus-lg me-1"></i> Neue Frage
        </button>
    </div>

    @* Filter Bar *@
    <div class="d-flex gap-2 mb-3 align-items-center flex-wrap">
        <input type="text" class="form-control input-custom flex-grow-1" placeholder="Suchen (Titel oder Beschreibung)..."
               @bind="_searchTerm" @bind:event="oninput" />
        <select class="form-select input-custom" style="width: auto;" @bind="_teacherFilter">
            <option value="">Alle Lehrer</option>
            @foreach (var teacher in AvailableTeachers)
            {
                <option value="@teacher.Id">@teacher.Name</option>
            }
        </select>
        <button class="btn btn-pill @(_typeFilter is null ? "active" : "")"
                @onclick="() => _typeFilter = null">Alle</button>
        <button class="btn btn-pill @(_typeFilter == QuestionType.SpotTest ? "active" : "")"
                @onclick="() => _typeFilter = QuestionType.SpotTest">SpotTest</button>
        <button class="btn btn-pill @(_typeFilter == QuestionType.SpotTestLight ? "active" : "")"
                @onclick="() => _typeFilter = QuestionType.SpotTestLight">Light</button>
    </div>

    @if (_questions is null)
    {
        <p class="text-muted">Laden...</p>
    }
    else if (_questions.Count == 0)
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-question-circle" style="font-size: 2.5rem;"></i>
            <p class="mt-2">Noch keine Fragen erstellt.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-2">
            @foreach (var q in FilteredQuestions)
            {
                <div class="question-row">
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <span class="badge-type @(q.Type == QuestionType.SpotTest ? "badge-st" : "badge-stl")">
                                @(q.Type == QuestionType.SpotTest ? "SpotTest" : "Light")
                            </span>
                            @if (!string.IsNullOrEmpty(q.CreatedByName))
                            {
                                <small class="text-muted">von @q.CreatedByName</small>
                            }
                        </div>
                        <div class="fw-semibold">@ChemicalStringFormatter.FormatText(q.Title)</div>
                        <div class="text-muted small mb-1">@q.Description</div>
                        <small class="text-muted">
                            @if (q.Type == QuestionType.SpotTest)
                            {
                                @($"{q.ChemicalCount} Chemikalien · {q.MethodCount} Methoden · in {q.QuizCount} Quizzes")
                            }
                            else
                            {
                                @($"{q.ReactionCount} Reaktionen · in {q.QuizCount} Quizzes")
                            }
                        </small>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-edit" @onclick="() => EditQuestion(q)">Bearbeiten</button>
                        <button class="btn btn-sm btn-delete" @onclick="() => ConfirmDelete(q)">Löschen</button>
                    </div>
                </div>
            }
        </div>
    }

    @* Delete Confirmation Modal *@
    @if (_questionToDelete is not null)
    {
        <div class="modal-backdrop show"></div>
        <div class="modal d-block" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="border-radius: var(--card-radius);">
                    <div class="modal-header border-0">
                        <h5 class="modal-title fw-bold">Frage löschen?</h5>
                    </div>
                    <div class="modal-body">
                        @if (_questionToDelete.QuizCount > 0)
                        {
                            <p class="text-danger">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                Diese Frage wird in @_questionToDelete.QuizCount Quiz(zes) verwendet und kann nicht gelöscht werden.
                                Entferne sie zuerst aus allen Quizzes.
                            </p>
                        }
                        else
                        {
                            <p>Möchtest du die Frage <strong>"@_questionToDelete.Title"</strong> wirklich löschen?</p>
                        }
                    </div>
                    <div class="modal-footer border-0">
                        <button class="btn btn-secondary" @onclick="CancelDelete">Abbrechen</button>
                        @if (_questionToDelete.QuizCount == 0)
                        {
                            <button class="btn btn-danger" @onclick="DeleteQuestion">Löschen</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_deleteError is not null)
    {
        <div class="alert alert-danger mt-3">@_deleteError</div>
    }
</div>

@code {
    [Inject] private IQuizService QuizService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private Guid _teacherId;
    private List<QuestionOverviewDto>? _questions;
    private string _searchTerm = "";
    private QuestionType? _typeFilter;
    private string _teacherFilter = "";
    private QuestionOverviewDto? _questionToDelete;
    private string? _deleteError;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        _teacherId = Guid.Parse(auth.User.FindFirst(ClaimTypes.NameIdentifier)!.Value);
        _questions = await QuizService.GetQuestions();
    }

    private record TeacherOption(string Id, string Name);

    private IEnumerable<TeacherOption> AvailableTeachers =>
        _questions is null
            ? []
            : _questions
                .Where(q => q.CreatedById.HasValue && !string.IsNullOrEmpty(q.CreatedByName))
                .Select(q => new TeacherOption(q.CreatedById!.Value.ToString(), q.CreatedByName!))
                .DistinctBy(t => t.Id)
                .OrderBy(t => t.Name);

    private IEnumerable<QuestionOverviewDto> FilteredQuestions =>
        _questions?.Where(q =>
            (_typeFilter is null || q.Type == _typeFilter) &&
            (string.IsNullOrEmpty(_teacherFilter) ||
             q.CreatedById?.ToString() == _teacherFilter) &&
            (string.IsNullOrEmpty(_searchTerm) ||
             q.Title.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
             q.Description.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
        ) ?? [];

    private void CreateQuestion() => Navigation.NavigateTo("/teacher/questions/create");

    private void EditQuestion(QuestionOverviewDto q) =>
        Navigation.NavigateTo($"/teacher/questions/{q.Id}/edit?type={q.Type}");

    private void ConfirmDelete(QuestionOverviewDto q) => _questionToDelete = q;
    private void CancelDelete() => _questionToDelete = null;

    private async Task DeleteQuestion()
    {
        if (_questionToDelete is null) return;
        _deleteError = null;
        try
        {
            await QuizService.DeleteQuestion(_teacherId, _questionToDelete.Id);
            _questionToDelete = null;
            _questions = await QuizService.GetQuestions();
        }
        catch (InvalidOperationException ex)
        {
            _deleteError = ex.Message;
            _questionToDelete = null;
        }
    }
}
