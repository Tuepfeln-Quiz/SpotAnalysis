@using SpotAnalysis.Services.DTOs;

@page "/teacher/groups"

<div class="h-100">
    <div class="card card-body h-30 mb-2 border border-2">
        <form class="row" method="get" asp-page="/Search">
            <div class="search-container col-12">
                <div class="row">
@*                     <button class="btn btn-primary col-2">Add</button>
 *@                    <input type="text"
                           asp-for="SearchQuery"
                           placeholder="Search..."
                           class="search-input col-8" />
                    <button type="submit" class="search-btn col-2">&#128269</button>
                </div>
            </div>
        </form>
    </div>
    <div class="card card-body h-70 mb-2 border border-2">
        <table class="table table-dark table-striped table-hover">
            <thead>
                <tr>
                    <th>Groups</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    @foreach (var a in grouplist)
                    {
                        <td class="text-center">@a.Name</td>
@*                         <td>@a.Roles</td>
                        <td>
                            <button class="btn btn-secondary">Edit</button>
                            <button class="btn btn-danger">Remove</button>
                        </td> *@
                    }
                </tr>
            </tbody>
        </table>
            
    </div>
</div>  




