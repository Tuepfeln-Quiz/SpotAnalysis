@page "/test"
@using Microsoft.AspNetCore.Mvc
@using SpotAnalysis.Data.Enums
@inject IAdminService AdminService

<h1>Admin Service Test</h1>

<!-- Benutzer nach Rolle laden -->
<h3>Admin Test</h3>

<div style="display:flex; gap:12px; align-items:center; margin-bottom:1rem;">
    <select @bind="selectedRole">
        @foreach (var role in Enum.GetValues<Role>())
        {
            <option value="@role">@role</option>
        }
    </select>
    <button @onclick="LoadUsers">Benutzer laden</button>
</div>

@if (users is not null)
{
    @if (users.Count == 0)
    {
        <p>Keine Benutzer mit dieser Rolle.</p>
    }
    else
    {
        <table style="width:100%; border-collapse:collapse; margin-bottom:1.5rem;">
            <thead>
                <tr style="text-align:left; border-bottom:1px solid var(--color-border-tertiary);">
                    <th>ID</th>
                    <th>Name</th>
                    <th>Rollen</th>
                    <th>Gruppen</th>
                    <th>Aktionen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users)
                {
                    <tr style="border-bottom:0.5px solid var(--color-border-tertiary); padding:4px 0;">
                        <td style="font-size:12px; color:var(--color-text-secondary);">@user.Id.ToString()[..8]...</td>
                        <td>@user.UserName</td>
                        <td>@string.Join(", ", user.Roles)</td>
                        <td>@string.Join(", ", user.AssignedGroups.Select(g => g.Name))</td>
                        <td style="display:flex; gap:6px;">
                            <button @onclick="() => SelectUser(user)">Auswählen</button>
                            <button @onclick="() => DeleteUserConfirm(user)"
                                    style="color:var(--color-text-danger);">
                                Löschen
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

<!-- Rolle hinzufügen / entfernen -->
@if (selectedUser is not null)
{
    <div style="background:var(--color-background-secondary); border:0.5px solid var(--color-border-tertiary); border-radius:var(--border-radius-lg); padding:1rem; margin-bottom:1rem;">
        <p><strong>Ausgewählt:</strong> @selectedUser.UserName (@selectedUser.Id)</p>
        <div style="display:flex; gap:8px; align-items:center;">
            <select @bind="roleToModify">
                @foreach (var role in Enum.GetValues<Role>())
                {
                    <option value="@role">@role</option>
                }
            </select>
            <button @onclick="AddRole">+ Hinzufügen</button>
            <button @onclick="RemoveRole">– Entfernen</button>
        </div>
    </div>
}

<!-- Bestätigungsdialog löschen -->
@if (userToDelete is not null)
{
    <div style="background:var(--color-background-danger); border:0.5px solid var(--color-border-danger); border-radius:var(--border-radius-md); padding:1rem;">
        <p style="color:var(--color-text-danger);">
            Benutzer <strong>@userToDelete.UserName</strong> wirklich löschen?
        </p>
        <div style="display:flex; gap:8px;">
            <button @onclick="ConfirmDelete"
                    style="color:var(--color-text-danger);">
                Ja, löschen
            </button>
            <button @onclick="() => userToDelete = null">Abbrechen</button>
        </div>
    </div>
}

<!-- Statusmeldungen -->
@if (!string.IsNullOrEmpty(statusMessage))
{
    <p style="margin-top:1rem; color:@(isError ? "var(--color-text-danger)" : "var(--color-text-success)");">
        @statusMessage
    </p>
}

@code {
    private Role selectedRole = Role.Student; // Standardwert anpassen
    private Role roleToModify = Role.Admin;
    private List<UserDto>? users;
    private UserDto? selectedUser;
    private UserDto? userToDelete;
    private string? statusMessage;
    private bool isError;

    private async Task LoadUsers()
    {
        statusMessage = null;
        users = await AdminService.GetUsersByRole(selectedRole);
    }

    private void SelectUser(UserDto user) => selectedUser = user;

    private async Task AddRole()
    {
        if (selectedUser is null) return;
        try
        {
            await AdminService.AddRoleToUser(selectedUser.Id, roleToModify);
            SetStatus($"Rolle '{roleToModify}' zu {selectedUser.UserName} hinzugefügt.");
            await LoadUsers();
        }
        catch (Exception ex) { SetStatus(ex.Message, error: true); }
    }

    private async Task RemoveRole()
    {
        if (selectedUser is null) return;
        try
        {
            await AdminService.RemoveRoleFromUser(selectedUser.Id, roleToModify);
            SetStatus($"Rolle '{roleToModify}' von {selectedUser.UserName} entfernt.");
            await LoadUsers();
        }
        catch (Exception ex) { SetStatus(ex.Message, error: true); }
    }

    private void DeleteUserConfirm(UserDto user) => userToDelete = user;

    private async Task ConfirmDelete()
    {
        if (userToDelete is null) return;
        try
        {
            await AdminService.DeleteUser(userToDelete.Id);
            SetStatus($"Benutzer '{userToDelete.UserName}' wurde gelöscht.");
            userToDelete = null;
            selectedUser = null;
            await LoadUsers();
        }
        catch (Exception ex) { SetStatus(ex.Message, error: true); }
    }

    private void SetStatus(string msg, bool error = false)
    {
        statusMessage = msg;
        isError = error;
    }
}