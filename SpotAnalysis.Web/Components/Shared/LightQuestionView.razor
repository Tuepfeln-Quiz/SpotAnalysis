@using SpotAnalysis.Services.DTOs
@using SpotAnalysis.Web.Helpers

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <h5 class="fw-bold mb-3">
            <i class="bi bi-question-circle me-2 text-primary"></i>@Description
        </h5>

        <div class="task-row">
            <div class="compound-card compound-card-static chemical-edukt task-educt"
                 style="border-color: @ColorHelper.GetBorderColor(Question.ShownEduct.Color)">
                <div class="p-2">
                    <strong>@Question.ShownEduct.Name</strong>
                    <br /><small><ChemFormula Value="@Question.ShownEduct.Formula" /></small>
                </div>
            </div>
            <span class="fs-4 text-muted fw-bold task-operator">+</span>
            @if (_hasChecked)
            {
                var correct = Question.AvailableReactions.First(r => r.ReactionID == Question.CorrectReactionID);
                var otherId = correct.Chemical1ID == Question.ShownEduct.Id ? correct.Chemical2ID : correct.Chemical1ID;
                var otherName = correct.Chemical1ID == Question.ShownEduct.Id ? correct.Chemical2Name : correct.Chemical1Name;
                <div class="compound-card compound-card-static chemical-edukt task-educt">
                    <div class="p-2"><strong>@otherName</strong></div>
                </div>
            }
            else
            {
                <div class="task-educt d-flex align-items-center justify-content-center rounded px-3"
                     style="background-color: #e9ecef; border: 2px dashed #adb5bd;">
                    <strong class="fs-4 text-muted">???</strong>
                </div>
            }
            <span class="task-operator"><i class="bi bi-arrow-right fs-4 text-muted"></i></span>
            <div class="task-observation p-3 rounded"
                 style="background-color: #f8f9fa; border: 1px solid #dee2e6;">
                <i class="bi bi-eye me-2"></i>@Question.Observation
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-list-check me-2"></i>Welche Reaktion passt?</h5>
        <div class="d-flex flex-column gap-2">
            @foreach (var reaction in Question.AvailableReactions)
            {
                var isSelected = _selectedReactionId == reaction.ReactionID;
                var btnClass = "btn btn-outline-secondary text-start w-100";
                if (_hasChecked && reaction.ReactionID == Question.CorrectReactionID)
                    btnClass = "btn btn-success text-start w-100";
                else if (_hasChecked && isSelected && reaction.ReactionID != Question.CorrectReactionID)
                    btnClass = "btn btn-danger text-start w-100";
                else if (isSelected)
                    btnClass = "btn btn-primary text-start w-100";

                <button class="@btnClass"
                        @onclick="() => SelectReaction(reaction.ReactionID)"
                        disabled="@_hasChecked">
                    <strong>@reaction.Chemical1Name + @reaction.Chemical2Name</strong>
                    <br /><small>→ @reaction.RelevantProduct (<ChemFormula Value="@reaction.Formula" />)</small>
                </button>
            }
        </div>

        <div class="mt-3 d-flex gap-2">
            @if (!_hasChecked)
            {
                <button class="btn btn-primary" @onclick="Check" disabled="@(_selectedReactionId == 0)">
                    <i class="bi bi-check-lg me-1"></i> Prüfen
                </button>
            }
            else
            {
                <button class="btn btn-primary" @onclick="Continue">
                    <i class="bi bi-arrow-right me-1"></i> Weiter
                </button>
            }
        </div>
    </div>
</div>

@if (_hasChecked)
{
    <div class="alert @(_lastCorrect ? "alert-success" : "alert-danger")">
        @if (_lastCorrect)
        {
            <i class="bi bi-check-circle-fill me-2"></i><strong>Richtig!</strong>
        }
        else
        {
            var correct = Question.AvailableReactions.First(r => r.ReactionID == Question.CorrectReactionID);
            <i class="bi bi-x-circle-fill me-2"></i><strong>Leider falsch.</strong>
            <br /><span>Richtig wäre: <strong>@correct.Chemical1Name + @correct.Chemical2Name → @correct.RelevantProduct</strong></span>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public LightPayloadDto Question { get; set; } = null!;
    [Parameter, EditorRequired] public string Description { get; set; } = "";
    [Parameter, EditorRequired] public EventCallback<LightAnswered> OnAnswered { get; set; }

    private int _selectedReactionId;
    private bool _hasChecked;
    private bool _lastCorrect;

    protected override void OnParametersSet()
    {
        _selectedReactionId = 0;
        _hasChecked = false;
        _lastCorrect = false;
    }

    private void SelectReaction(int reactionId)
    {
        if (!_hasChecked) _selectedReactionId = reactionId;
    }

    private void Check()
    {
        if (_selectedReactionId == 0) return;
        _hasChecked = true;
        _lastCorrect = _selectedReactionId == Question.CorrectReactionID;
    }

    private Task Continue() => OnAnswered.InvokeAsync(new LightAnswered
    {
        ChosenReactionId = _selectedReactionId,
        IsCorrect = _lastCorrect
    });

    public class LightAnswered
    {
        public int ChosenReactionId { get; init; }
        public bool IsCorrect { get; init; }
    }
}
