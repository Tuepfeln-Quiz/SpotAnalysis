@code {
    [Parameter]
    public string? PageTitle { get; set; }

    private void GoHome()
    {
        Navigation.NavigateTo("/");
    }

    private void GoQuestions()
    {
        Navigation.NavigateTo("teacher/questions");
    }
    private void GoQuizzes()
    {
        Navigation.NavigateTo("teacher/quizzes");
    }
    private void GoGroups()
    {
        Navigation.NavigateTo("teacher/groups");
    }
}
