@page "/admin/uebungen"
@rendermode InteractiveServer
@inject SpotAnalysisV2.Web.Services.QuizDataService QuizService
@using SpotAnalysisV2.Web.Models

<div class="size-full flex flex-col bg-gray-50">
    <header class="bg-white shadow-sm px-6 py-4 flex items-center justify-between">
        <NavLink href="/uebungen" class="p-2 hover:bg-gray-100 rounded-lg transition-colors" style="display: flex; align-items: center;" aria-label="Zurück zu Übungen">
            <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 19l-7-7 7-7" />
            </svg>
        </NavLink>

        <h1 class="absolute left-1/2 -translate-x-1/2 text-lg font-semibold text-gray-800">Admin · Übungen</h1>

        <NavLink href="/uebungen" class="px-4 py-2 rounded-lg bg-teal-50 text-teal-700 border border-teal-200 text-sm font-medium" style="text-decoration: none;">
            Zur Nutzeransicht
        </NavLink>
    </header>

    <main class="flex-1 overflow-y-auto p-8">
        <div class="max-w-7xl mx-auto space-y-8">
            <div class="bg-white rounded-2xl shadow-md p-6 space-y-4">
                <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
                    <div>
                        <h2 class="text-xl font-semibold text-gray-800">Neue Übung erstellen</h2>
                        <p class="text-sm text-gray-500">Wähle vorhandene Light- und Tüpfeln-Quiz aus dem JSON-Katalog aus. Die gewählte Reihenfolge wird für die Nutzer gespeichert.</p>
                    </div>
                    <div class="flex gap-2 text-sm">
                        <span class="px-3 py-1 rounded-lg bg-yellow-50 border border-yellow-200 text-yellow-700">🔦 @DraftLightCount Light</span>
                        <span class="px-3 py-1 rounded-lg bg-teal-50 border border-teal-200 text-teal-700">🧪 @DraftTuepfelnCount Tüpfeln</span>
                        <span class="px-3 py-1 rounded-lg bg-gray-50 border border-gray-200 text-gray-700">@draftAufgaben.Count Aufgaben</span>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@errorMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(successMessage))
                {
                    <div class="rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">@successMessage</div>
                }

                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Titel</label>
                        <input @bind="title"
                               class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-400"
                               placeholder="z. B. Übung Säuren und Salze" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Beschreibung</label>
                        <input @bind="description"
                               class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-400"
                               placeholder="Optional – sonst automatisch erzeugt" />
                    </div>
                </div>
            </div>

            <div class="grid gap-6 xl:grid-cols-[1.2fr_1.2fr_1fr]">
                <section class="bg-white rounded-2xl shadow-md p-6 space-y-4">
                    <div class="flex items-center justify-between">
                        <h3 class="text-lg font-semibold text-gray-800">Verfügbare Light-Quiz</h3>
                        <span class="text-sm text-yellow-700 bg-yellow-50 border border-yellow-200 rounded-lg px-3 py-1">@lightQuizzes.Count Stück</span>
                    </div>

                    <div class="space-y-3">
                        @foreach (var quiz in lightQuizzes)
                        {
                            var isSelected = IsSelected(AufgabeTyp.Light, quiz.Id);
                            <div class="rounded-xl border p-4 flex items-start justify-between gap-4 @(isSelected ? "border-yellow-300 bg-yellow-50/40" : "border-gray-200")">
                                <div>
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="text-xs px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-700">🔦 Light</span>
                                        <span class="text-xs text-gray-400">ID @quiz.Id</span>
                                    </div>
                                    <h4 class="font-medium text-gray-800">@quiz.Title</h4>
                                    <p class="text-sm text-gray-500">@quiz.Fragen.Count Fragen</p>
                                </div>
                                <button @onclick="() => ToggleQuiz(AufgabeTyp.Light, quiz.Id)"
                                        class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(isSelected ? "bg-red-50 text-red-700 border border-red-200 hover:bg-red-100" : "bg-yellow-500 text-white hover:bg-yellow-600")">
                                    @(isSelected ? "Entfernen" : "Hinzufügen")
                                </button>
                            </div>
                        }
                    </div>
                </section>

                <section class="bg-white rounded-2xl shadow-md p-6 space-y-4">
                    <div class="flex items-center justify-between">
                        <h3 class="text-lg font-semibold text-gray-800">Verfügbare Tüpfeln-Quiz</h3>
                        <span class="text-sm text-teal-700 bg-teal-50 border border-teal-200 rounded-lg px-3 py-1">@tuepfelnQuizzes.Count Stück</span>
                    </div>

                    <div class="space-y-3">
                        @foreach (var quiz in tuepfelnQuizzes)
                        {
                            var isSelected = IsSelected(AufgabeTyp.Tuepfeln, quiz.Id);
                            <div class="rounded-xl border p-4 flex items-start justify-between gap-4 @(isSelected ? "border-teal-300 bg-teal-50/40" : "border-gray-200")">
                                <div>
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="text-xs px-2 py-0.5 rounded-full bg-teal-100 text-teal-700">🧪 Tüpfeln</span>
                                        <span class="text-xs text-gray-400">ID @quiz.Id</span>
                                    </div>
                                    <h4 class="font-medium text-gray-800">@quiz.Title</h4>
                                    <p class="text-sm text-gray-500">@quiz.Unbekannte.Count Unbekannte</p>
                                </div>
                                <button @onclick="() => ToggleQuiz(AufgabeTyp.Tuepfeln, quiz.Id)"
                                        class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(isSelected ? "bg-red-50 text-red-700 border border-red-200 hover:bg-red-100" : "bg-teal-500 text-white hover:bg-teal-600")">
                                    @(isSelected ? "Entfernen" : "Hinzufügen")
                                </button>
                            </div>
                        }
                    </div>
                </section>

                <section class="bg-white rounded-2xl shadow-md p-6 space-y-4 h-fit xl:sticky xl:top-8">
                    <div class="flex items-center justify-between gap-3">
                        <h3 class="text-lg font-semibold text-gray-800">Aktuelle Reihenfolge</h3>
                        <button @onclick="ClearDraft"
                                disabled="@(!draftAufgaben.Any())"
                                class="px-3 py-2 rounded-lg text-sm font-medium transition-colors @(!draftAufgaben.Any() ? "bg-gray-100 text-gray-400 cursor-not-allowed" : "bg-gray-100 text-gray-700 hover:bg-gray-200")">
                            Leeren
                        </button>
                    </div>

                    @if (!draftAufgaben.Any())
                    {
                        <div class="rounded-xl border-2 border-dashed border-gray-200 p-6 text-sm text-gray-500 text-center">
                            Noch keine Quiz ausgewählt.
                        </div>
                    }
                    else
                    {
                        var draftSnapshot = draftAufgaben.Select((aufgabe, index) => new { Aufgabe = aufgabe, Index = index }).ToList();

                        <div class="space-y-3">
                            @foreach (var entry in draftSnapshot)
                            {
                                <div class="rounded-xl border border-gray-200 p-4 space-y-3">
                                    <div class="flex items-start justify-between gap-3">
                                        <div>
                                            <div class="flex items-center gap-2 mb-1">
                                                <span class="text-xs px-2 py-0.5 rounded-full @(entry.Aufgabe.Typ == AufgabeTyp.Light ? "bg-yellow-100 text-yellow-700" : "bg-teal-100 text-teal-700")">
                                                    @(entry.Aufgabe.Typ == AufgabeTyp.Light ? "🔦 Light" : "🧪 Tüpfeln")
                                                </span>
                                                <span class="text-xs text-gray-400">Aufgabe @(entry.Index + 1)</span>
                                            </div>
                                            <h4 class="font-medium text-gray-800">@GetQuizTitle(entry.Aufgabe)</h4>
                                        </div>
                                        <button @onclick="() => RemoveAt(entry.Index)" class="text-sm text-red-600 hover:text-red-700">Entfernen</button>
                                    </div>

                                    <div class="flex gap-2">
                                        <button @onclick="() => MoveUp(entry.Index)"
                                                disabled="@(entry.Index == 0)"
                                                class="flex-1 px-3 py-2 rounded-lg text-sm font-medium transition-colors @(entry.Index == 0 ? "bg-gray-100 text-gray-400 cursor-not-allowed" : "bg-gray-100 text-gray-700 hover:bg-gray-200")">
                                            ↑ Hoch
                                        </button>
                                        <button @onclick="() => MoveDown(entry.Index)"
                                                disabled="@(entry.Index == draftSnapshot.Count - 1)"
                                                class="flex-1 px-3 py-2 rounded-lg text-sm font-medium transition-colors @(entry.Index == draftSnapshot.Count - 1 ? "bg-gray-100 text-gray-400 cursor-not-allowed" : "bg-gray-100 text-gray-700 hover:bg-gray-200")">
                                            ↓ Runter
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <button @onclick="SaveUebung"
                            disabled="@(!CanSave)"
                            class="w-full py-3 rounded-xl font-medium transition-colors @(!CanSave ? "bg-gray-200 text-gray-400 cursor-not-allowed" : "bg-teal-500 text-white hover:bg-teal-600")">
                        Übung speichern
                    </button>
                </section>
            </div>

            <section class="bg-white rounded-2xl shadow-md p-6 space-y-4">
                <div class="flex items-center justify-between">
                    <h2 class="text-xl font-semibold text-gray-800">Bereits erstellte Übungen</h2>
                    <span class="text-sm text-gray-500">@createdUebungen.Count gespeichert</span>
                </div>

                @if (!createdUebungen.Any())
                {
                    <div class="rounded-xl border-2 border-dashed border-gray-200 p-6 text-sm text-gray-500 text-center">
                        Noch keine Übung gespeichert.
                    </div>
                }
                else
                {
                    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                        @foreach (var uebung in createdUebungen)
                        {
                            <div class="rounded-xl border border-gray-200 p-5 space-y-3">
                                <div class="flex items-start justify-between">
                                    <div>
                                        <h3 class="font-semibold text-gray-800">@uebung.Title</h3>
                                        <p class="text-sm text-gray-500">@uebung.Description</p>
                                    </div>
                                    <button @onclick="() => DeleteUebung(uebung.Id)" class="ml-2 px-3 py-1.5 rounded-lg bg-red-50 text-red-700 border border-red-200 hover:bg-red-100 transition-colors text-sm font-medium">🗑️ Löschen</button>
                                </div>
                                <div class="flex flex-wrap gap-2 text-sm">
                                    <span class="px-3 py-1 rounded-lg bg-gray-50 border border-gray-200 text-gray-700">@uebung.AufgabenCount Aufgaben</span>
                                    <span class="px-3 py-1 rounded-lg bg-yellow-50 border border-yellow-200 text-yellow-700">🔦 @uebung.LightCount</span>
                                    <span class="px-3 py-1 rounded-lg bg-teal-50 border border-teal-200 text-teal-700">🧪 @uebung.TupfelnCount</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>
        </div>
    </main>
</div>

@code {
    private List<LightQuizData> lightQuizzes = new();
    private List<TuepfelnQuizData> tuepfelnQuizzes = new();
    private List<UebungItem> createdUebungen = new();
    private List<AufgabeInfo> draftAufgaben = new();
    private string title = string.Empty;
    private string description = string.Empty;
    private string? errorMessage;
    private string? successMessage;

    private int DraftLightCount => draftAufgaben.Count(a => a.Typ == AufgabeTyp.Light);
    private int DraftTuepfelnCount => draftAufgaben.Count(a => a.Typ == AufgabeTyp.Tuepfeln);
    private bool CanSave => !string.IsNullOrWhiteSpace(title) && draftAufgaben.Any();

    protected override void OnInitialized()
    {
        LoadPageData();
    }

    private void LoadPageData()
    {
        lightQuizzes = QuizService.GetLightQuizzes();
        tuepfelnQuizzes = QuizService.GetTuepfelnQuizzes();
        createdUebungen = QuizService.GetUebungen();
    }

    private void ToggleQuiz(AufgabeTyp typ, int quizId)
    {
        if (IsSelected(typ, quizId))
        {
            var index = draftAufgaben.FindIndex(a => a.Typ == typ && a.QuizId == quizId);
            if (index >= 0)
            {
                RemoveAt(index);
            }
            return;
        }

        AddQuiz(typ, quizId);
    }

    private bool IsSelected(AufgabeTyp typ, int quizId) =>
        draftAufgaben.Any(a => a.Typ == typ && a.QuizId == quizId);

    private void AddQuiz(AufgabeTyp typ, int quizId)
    {
        ClearMessages();

        if (draftAufgaben.Any(a => a.Typ == typ && a.QuizId == quizId))
        {
            errorMessage = "Dieses Quiz ist bereits in der aktuellen Übung enthalten.";
            return;
        }

        draftAufgaben.Add(new AufgabeInfo
        {
            Typ = typ,
            QuizId = quizId
        });

        ReindexDraft();
    }

    private void RemoveAt(int index)
    {
        if (index < 0 || index >= draftAufgaben.Count) return;
        draftAufgaben.RemoveAt(index);
        ReindexDraft();
        ClearMessages();
    }

    private void MoveUp(int index)
    {
        if (index <= 0 || index >= draftAufgaben.Count) return;
        (draftAufgaben[index - 1], draftAufgaben[index]) = (draftAufgaben[index], draftAufgaben[index - 1]);
        ReindexDraft();
        ClearMessages();
    }

    private void MoveDown(int index)
    {
        if (index < 0 || index >= draftAufgaben.Count - 1) return;
        (draftAufgaben[index + 1], draftAufgaben[index]) = (draftAufgaben[index], draftAufgaben[index + 1]);
        ReindexDraft();
        ClearMessages();
    }

    private void ClearDraft()
    {
        draftAufgaben.Clear();
        ClearMessages();
    }

    private void SaveUebung()
    {
        ClearMessages();

        try
        {
            var saved = QuizService.CreateUebung(title, description, draftAufgaben);
            successMessage = $"Übung '{saved.Title}' wurde gespeichert.";
            title = string.Empty;
            description = string.Empty;
            draftAufgaben.Clear();
            LoadPageData();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void ReindexDraft()
    {
        for (var i = 0; i < draftAufgaben.Count; i++)
        {
            draftAufgaben[i].AufgabeId = i + 1;
        }
    }

    private void ClearMessages()
    {
        errorMessage = null;
        successMessage = null;
    }

    private string GetQuizTitle(AufgabeInfo aufgabe) =>
        aufgabe.Typ == AufgabeTyp.Light
            ? lightQuizzes.FirstOrDefault(q => q.Id == aufgabe.QuizId)?.Title ?? $"Light {aufgabe.QuizId}"
            : tuepfelnQuizzes.FirstOrDefault(q => q.Id == aufgabe.QuizId)?.Title ?? $"Tüpfeln {aufgabe.QuizId}";

    private void DeleteUebung(int id)
    {
        QuizService.DeleteUebung(id);
        LoadPageData();
    }
}
