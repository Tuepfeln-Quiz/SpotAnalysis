@page "/uebungen/{UebungId:int}/aufgabe/{AufgabeId:int}"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject SpotAnalysisV2.Web.Services.QuizDataService QuizService
@inject SpotAnalysisV2.Web.Services.AufgabeProgressService ProgressService

<div class="size-full flex items-center justify-center bg-gray-50">
    <div class="text-sm text-gray-500">Quiz wird geöffnet…</div>
</div>

@code {
    [Parameter] public int UebungId { get; set; }
    [Parameter] public int AufgabeId { get; set; }

    protected override void OnParametersSet()
    {
        var total = QuizService.GetAufgabenCount(UebungId);
        var clamped = Math.Clamp(AufgabeId, 1, total);

        var aufgabe = QuizService.GetAufgabe(UebungId, clamped);
        if (aufgabe == null)
        {
            Navigation.NavigateTo("/uebungen", replace: true);
            return;
        }

        ProgressService.SetUebungContext(UebungId, clamped, total);

        var target = aufgabe.Typ == SpotAnalysisV2.Web.Models.AufgabeTyp.Tuepfeln
            ? $"/tupfeln/quiz/{aufgabe.QuizId}"
            : $"/light/quiz/{aufgabe.QuizId}";

        Navigation.NavigateTo($"{target}?from=uebung&uebungId={UebungId}&aufgabeId={clamped}&total={total}", replace: true);
    }
}
