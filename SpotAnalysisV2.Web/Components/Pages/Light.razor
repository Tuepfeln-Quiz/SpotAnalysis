@page "/light"
@rendermode InteractiveServer

<div class="size-full flex flex-col bg-gray-50">
    <header class="bg-white shadow-sm px-6 py-4 flex items-center justify-between">
        <NavLink href="/" class="p-2 hover:bg-gray-100 rounded-lg transition-colors" style="display: flex; align-items: center;" aria-label="Home">
            <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
        </NavLink>

        <div class="absolute left-1/2 -translate-x-1/2 flex gap-3 z-10">
            <NavLink href="/sandbox" class="bg-gray-100 text-gray-700 px-6 py-2 rounded-lg font-medium hover:bg-gray-200 transition-colors" style="text-decoration: none;">Sandbox</NavLink>
            <NavLink href="/reverse" class="bg-gray-100 text-gray-700 px-6 py-2 rounded-lg font-medium hover:bg-gray-200 transition-colors" style="text-decoration: none;">Reverse</NavLink>
            <div class="bg-yellow-500 text-white px-6 py-2 rounded-lg font-medium">Light</div>
            <NavLink href="/tupfeln" class="bg-gray-100 text-gray-700 px-6 py-2 rounded-lg font-medium hover:bg-gray-200 transition-colors" style="text-decoration: none;">Tüpfeln</NavLink>
        </div>

        <img src="https://images.unsplash.com/photo-1655249493799-9cee4fe983bb?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxwcm9maWxlJTIwcG9ydHJhaXR8ZW58MXx8fHwxNzczNjY1OTA5fDA&ixlib=rb-4.1.0&q=80&w=1080&utm_source=figma&utm_medium=referral"
             alt="Profil"
             class="w-10 h-10 rounded-full object-cover ml-auto" />
    </header>

    <main class="flex-1 overflow-y-auto p-8">
        <div class="max-w-3xl mx-auto">
            <h1 class="text-3xl font-semibold mb-8">Light Quizze</h1>
            <div class="space-y-4">
                @foreach (var quiz in quizList)
                {
                    <NavLink href="@($"/light/quiz/{quiz.Id}")"
                             class="w-full block bg-white hover:bg-gray-50 shadow-md rounded-xl p-6 transition-all hover:shadow-lg text-left group"
                             style="text-decoration: none;">
                        <div class="flex items-center justify-between">
                            <div>
                                <h2 class="text-xl font-medium group-hover:text-yellow-600 transition-colors">@quiz.Title</h2>
                                <p class="text-gray-600 mt-1">@quiz.Description</p>
                            </div>
                            <svg class="w-6 h-6 text-gray-400 group-hover:text-yellow-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 5l7 7-7 7" />
                            </svg>
                        </div>
                    </NavLink>
                }
            </div>
        </div>
    </main>
</div>

@code {
    private class QuizListItem
    {
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
    }

    private readonly List<QuizListItem> quizList = new()
    {
        new() { Id = "1", Title = "Quiz 1", Description = "Grundlegende Chemie-Konzepte" },
        new() { Id = "2", Title = "Quiz 2", Description = "Organische Verbindungen" },
        new() { Id = "3", Title = "Quiz 3", Description = "Chemische Reaktionen" },
        new() { Id = "4", Title = "Quiz 4", Description = "Laborsicherheit" },
        new() { Id = "5", Title = "Quiz 5", Description = "Molekulare Struktur" },
        new() { Id = "6", Title = "Quiz 6", Description = "Fortgeschrittene Chemie" }
    };
}
