@page "/light/quiz/{QuizId}"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<div class="size-full flex flex-col bg-gray-50">
    <header class="bg-white shadow-sm px-6 py-4 flex items-center justify-between">
        <NavLink href="/light" class="p-2 hover:bg-gray-100 rounded-lg transition-colors" style="display: flex; align-items: center;" aria-label="Zurück">
            <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 19l-7-7 7-7" />
            </svg>
        </NavLink>

        <div class="absolute left-1/2 -translate-x-1/2 flex gap-3 z-10">
            <NavLink href="/sandbox" class="bg-gray-100 text-gray-700 px-6 py-2 rounded-lg font-medium hover:bg-gray-200 transition-colors" style="text-decoration: none;">Sandbox</NavLink>
            <NavLink href="/reverse" class="bg-gray-100 text-gray-700 px-6 py-2 rounded-lg font-medium hover:bg-gray-200 transition-colors" style="text-decoration: none;">Reverse</NavLink>
            <div class="bg-yellow-500 text-white px-6 py-2 rounded-lg font-medium">Light</div>
            <NavLink href="/tupfeln" class="bg-gray-100 text-gray-700 px-6 py-2 rounded-lg font-medium hover:bg-gray-200 transition-colors" style="text-decoration: none;">Tüpfeln</NavLink>
        </div>

        <img src="https://images.unsplash.com/photo-1655249493799-9cee4fe983bb?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxwcm9maWxlJTIwcG9ydHJhaXR8ZW58MXx8fHwxNzczNjY1OTA5fDA&ixlib=rb-4.1.0&q=80&w=1080&utm_source=figma&utm_medium=referral"
             alt="Profil"
             class="w-10 h-10 rounded-full object-cover ml-auto" />
    </header>

    @if (finished)
    {
        <div class="flex-1 flex items-center justify-center p-4">
            <div class="bg-white rounded-xl shadow-md p-8 text-center max-w-md w-full">
                <div class="w-14 h-14 rounded-full bg-yellow-100 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-7 h-7 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M8 2v8l3 6v6h2v-6l3-6V2H8z" />
                    </svg>
                </div>
                <h2 class="text-xl font-semibold mb-2">Quiz abgeschlossen!</h2>
                <p class="text-gray-600 mb-4">
                    Sie haben <span class="font-bold text-yellow-600">@score</span> von <span class="font-bold">@questions.Count</span> Fragen richtig beantwortet.
                </p>
                <div class="w-full bg-gray-200 rounded-full h-3 mb-6">
                    <div class="bg-yellow-500 h-3 rounded-full transition-all" style="width: @GetProgressWidth()"></div>
                </div>
                <div class="flex gap-3">
                    <button @onclick="HandleRestart" class="flex-1 py-3 rounded-lg font-medium bg-yellow-500 text-white hover:bg-yellow-600 transition-colors">Nochmal</button>
                    <NavLink href="/light" class="flex-1 py-3 rounded-lg font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors text-center" style="text-decoration: none;">Zurück</NavLink>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="flex-1 flex overflow-hidden">
            <div class="flex-1 p-4 flex flex-col gap-4 overflow-y-auto">
                @if (question != null)
                {
                    <div class="bg-white rounded-xl shadow-md p-4">
                        <div class="flex items-center justify-between mb-3">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-yellow-100 flex items-center justify-center">
                                    <svg class="w-4 h-4 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M8 2v8l3 6v6h2v-6l3-6V2H8z" />
                                    </svg>
                                </div>
                                <div>
                                    <h2 class="text-base font-semibold text-gray-800">Light Quiz @QuizId</h2>
                                    <p class="text-xs text-gray-500">Finden Sie das fehlende Element und Ergebnis</p>
                                </div>
                            </div>
                        </div>

                        <div class="bg-yellow-50 border border-yellow-200 rounded-lg px-4 py-3 mb-4">
                            <p class="text-sm text-yellow-800 font-medium">@question.Frage</p>
                        </div>

                        <div class="grid grid-cols-3 gap-4 mb-4 items-stretch">
                            <div class="flex flex-col">
                                <h3 class="text-xs font-medium text-gray-600 mb-1">Element 1 (gegeben)</h3>
                                <div class="@question.Edukt1.Color border-2 rounded-lg p-3 min-h-[120px] flex-1 flex flex-col justify-center">
                                    <p class="font-bold text-base">@question.Edukt1.Name</p>
                                    <p class="text-xs text-gray-700 mb-2">@question.Edukt1.Type</p>
                                    <div class="flex gap-2">
                                        <div class="flex-1 flex flex-col gap-0.5 bg-white/70 px-2 py-1.5 rounded border border-gray-300">
                                            <div class="flex items-center gap-1">
                                                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" style="color: @GetPhColorHex(question.Edukt1.PhLevel)">
                                                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/>
                                                </svg>
                                                <span class="text-[10px] text-gray-700">pH: @GetPhDisplayColor(question.Edukt1.PhLevel)</span>
                                            </div>
                                            <div class="@GetPhColor(question.Edukt1.PhLevel) h-2 rounded border border-gray-400"></div>
                                        </div>
                                        <div class="flex-1 flex flex-col gap-0.5 bg-white/70 px-2 py-1.5 rounded border border-gray-300">
                                            <div class="flex items-center gap-1">
                                                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" style="color: @GetFlameColorHex(question.Edukt1.FlameColor)">
                                                    <path d="M12 2C12 2 6 8 6 13c0 3.3 2.7 6 6 6s6-2.7 6-6c0-5-6-11-6-11zm0 16c-1.6 0-3-1.4-3-3 0-1.8 1.5-3.5 3-5.1 1.5 1.6 3 3.3 3 5.1 0 1.6-1.4 3-3 3z"/>
                                                </svg>
                                                <span class="text-[10px] text-gray-700">Feuer: @selectedOrQuestionFlameQuestion()</span>
                                            </div>
                                            <div class="@GetFlameColor(question.Edukt1.FlameColor) h-2 rounded border border-gray-400"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="flex flex-col">
                                <h3 class="text-xs font-medium text-gray-600 mb-1">Element 2 (gesucht)</h3>
                                <div class="@(answered ? "min-h-[120px] flex-1 flex items-stretch" : $"{GetHiddenElementContainerClass()} border-2 border-dashed rounded-lg p-3 min-h-[120px] flex-1 flex items-center justify-center")">
                                    @if (answered)
                                    {
                                        var selectedEdukt = GetSelectedEdukt();
                                        if (selectedEdukt != null)
                                        {
                                            <div class="w-full border-2 rounded-lg p-3 @(selectedOption == correctOptionId ? "border-green-400 bg-green-50" : "border-red-400 bg-red-50")">
                                                <div class="flex items-start justify-between gap-2">
                                                    <div>
                                                        <p class="font-bold text-base">@selectedEdukt.Name</p>
                                                        <p class="text-xs text-gray-700 mb-2">@selectedEdukt.Type</p>
                                                    </div>
                                                    @if (selectedOption == correctOptionId)
                                                    {
                                                        <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" />
                                                        </svg>
                                                    }
                                                    else
                                                    {
                                                        <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z" />
                                                        </svg>
                                                    }
                                                </div>
                                                <div class="flex gap-2">
                                                    <div class="flex-1 flex flex-col gap-0.5 bg-white/70 px-2 py-1.5 rounded border border-gray-300">
                                                        <div class="flex items-center gap-1">
                                                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" style="color: @GetPhColorHex(selectedEdukt.PhLevel)">
                                                                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/>
                                                            </svg>
                                                            <span class="text-[10px] text-gray-700">pH: @GetPhDisplayColor(selectedEdukt.PhLevel)</span>
                                                        </div>
                                                        <div class="@GetPhColor(selectedEdukt.PhLevel) h-2 rounded border border-gray-400"></div>
                                                    </div>
                                                    <div class="flex-1 flex flex-col gap-0.5 bg-white/70 px-2 py-1.5 rounded border border-gray-300">
                                                        <div class="flex items-center gap-1">
                                                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" style="color: @GetFlameColorHex(selectedEdukt.FlameColor)">
                                                                <path d="M12 2C12 2 6 8 6 13c0 3.3 2.7 6 6 6s6-2.7 6-6c0-5-6-11-6-11zm0 16c-1.6 0-3-1.4-3-3 0-1.8 1.5-3.5 3-5.1 1.5 1.6 3 3.3 3 5.1 0 1.6-1.4 3-3 3z"/>
                                                            </svg>
                                                            <span class="text-[10px] text-gray-700">Feuer: @selectedEdukt.FlameColor</span>
                                                        </div>
                                                        <div class="@GetFlameColor(selectedEdukt.FlameColor) h-2 rounded border border-gray-400"></div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="text-center text-yellow-400">
                                            <svg class="w-10 h-10 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <circle cx="12" cy="12" r="10"></circle>
                                                <path d="M12 16h.01M12 8a2.5 2.5 0 0 1 2.5 2.5c0 1.5-1.5 2-2.2 2.7-.2.2-.3.4-.3.8"></path>
                                            </svg>
                                            <p class="text-sm">???</p>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="flex flex-col">
                                <h3 class="text-xs font-medium text-gray-600 mb-1 flex items-center gap-1.5">
                                    <svg class="w-3.5 h-3.5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M12 2C12 2 6 8 6 13c0 3.3 2.7 6 6 6s6-2.7 6-6c0-5-6-11-6-11z" />
                                        <path d="M9 14c0 1.7 1.3 3 3 3" />
                                    </svg>
                                    <span>Niederschlag (gegeben)</span>
                                </h3>
                                <div class="@GetResultContainerClass() border-2 border-dashed rounded-lg p-4 min-h-[110px] flex-1 flex items-center justify-center">
                                    <div class="text-center">
                                        <svg class="w-7 h-7 text-amber-600 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M12 2C12 2 6 8 6 13c0 3.3 2.7 6 6 6s6-2.7 6-6c0-5-6-11-6-11zm0 16c-1.6 0-3-1.4-3-3 0-1.8 1.5-3.5 3-5.1 1.5 1.6 3 3.3 3 5.1 0 1.6-1.4 3-3 3z" />
                                            <path d="M9 14c0 1.7 1.3 3 3 3" />
                                        </svg>
                                        <p class="font-bold text-xl text-amber-800">@GetNiederschlagText(question.Produkt)</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-3 mb-4">
                            @foreach (var opt in question.Options)
                            {
                                var isCorrectOpt = opt.Edukt2.Id == question.CorrectEdukt2.Id;
                                var isSelected = selectedOption == opt.Id;

                                <button @onclick="@(() => HandleSelect(opt.Id))"
                                        disabled="@answered"
                                        class="border-2 rounded-lg p-4 text-left transition-all @GetOptionClass(isCorrectOpt, isSelected)">
                                    <div class="space-y-1">
                                        <p class="text-xl font-semibold text-slate-600 leading-tight">
                                            @question.Edukt1.Type + @opt.Edukt2.Type
                                        </p>
                                        <p class="text-lg text-slate-500 leading-tight">
                                            → @GetNiederschlagText(opt.Produkt) (@opt.Formel)
                                        </p>
                                    </div>
                                </button>
                            }
                        </div>

                        @if (!answered)
                        {
                            <button @onclick="HandleCheck"
                                    disabled="@(string.IsNullOrEmpty(selectedOption))"
                                    class="@(string.IsNullOrEmpty(selectedOption) ? "w-full py-3 rounded-lg font-medium bg-gray-200 text-gray-400 cursor-not-allowed" : "w-full py-3 rounded-lg font-medium bg-yellow-500 text-white hover:bg-yellow-600 transition-colors")">
                                Überprüfen
                            </button>
                        }
                        else
                        {
                            <button @onclick="HandleNext"
                                    class="w-full py-3 rounded-lg font-medium bg-yellow-500 text-white hover:bg-yellow-600 transition-colors flex items-center justify-center gap-2">
                                @if (currentIdx < questions.Count - 1)
                                {
                                    <span>Nächste Frage</span>
                                }
                                else
                                {
                                    <span>Ergebnis anzeigen</span>
                                }
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? QuizId { get; set; }
    private const string PhIconPath = "/icons/ph-icon.svg";

    private class Edukt
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string Type { get; set; } = "";
        public string Color { get; set; } = "";
        public string PhLevel { get; set; } = "";
        public string FlameColor { get; set; } = "";
    }

    private class Option
    {
        public string Id { get; set; } = "";
        public Edukt Edukt2 { get; set; } = new();
        public string Produkt { get; set; } = "";
        public string Formel { get; set; } = "";
    }

    private class Question
    {
        public Edukt Edukt1 { get; set; } = new();
        public Edukt CorrectEdukt2 { get; set; } = new();
        public string Produkt { get; set; } = "";
        public string Formel { get; set; } = "";
        public string Frage { get; set; } = "";
        public List<Option> Options { get; set; } = new();
    }

    private readonly List<Edukt> edukte = new()
    {
        new() { Id = "1", Name = "H₂", Type = "Wasserstoff", Color = "bg-blue-100 border-blue-300", PhLevel = "7", FlameColor = "Blassblau" },
        new() { Id = "2", Name = "O₂", Type = "Sauerstoff", Color = "bg-red-100 border-red-300", PhLevel = "7", FlameColor = "Keine" },
        new() { Id = "3", Name = "NaCl", Type = "Salz", Color = "bg-gray-100 border-gray-300", PhLevel = "7", FlameColor = "Gelb" },
        new() { Id = "4", Name = "N₂", Type = "Stickstoff", Color = "bg-purple-100 border-purple-300", PhLevel = "7", FlameColor = "Keine" },
        new() { Id = "5", Name = "C", Type = "Kohlenstoff", Color = "bg-slate-200 border-slate-400", PhLevel = "-", FlameColor = "Rot-Orange" },
        new() { Id = "6", Name = "S", Type = "Schwefel", Color = "bg-yellow-100 border-yellow-300", PhLevel = "-", FlameColor = "Blau" },
        new() { Id = "7", Name = "Fe", Type = "Eisen", Color = "bg-gray-200 border-gray-400", PhLevel = "-", FlameColor = "Orangefunken" },
        new() { Id = "8", Name = "Cu", Type = "Kupfer", Color = "bg-orange-200 border-orange-400", PhLevel = "-", FlameColor = "Grün" },
        new() { Id = "9", Name = "Cl₂", Type = "Chlor", Color = "bg-green-200 border-green-400", PhLevel = "-", FlameColor = "Keine" },
        new() { Id = "10", Name = "CO₂", Type = "Kohlendioxid", Color = "bg-gray-100 border-gray-300", PhLevel = "5.6", FlameColor = "Keine" },
        new() { Id = "11", Name = "H₂O", Type = "Wasser", Color = "bg-cyan-100 border-cyan-300", PhLevel = "7", FlameColor = "Keine" },
        new() { Id = "12", Name = "NH₃", Type = "Ammoniak", Color = "bg-blue-200 border-blue-400", PhLevel = "11", FlameColor = "Keine" }
    };

    private readonly Dictionary<string, List<Question>> allQuizQuestions = new();
    private List<Question> questions = new();
    private Question? question;
    private int currentIdx;
    private string? selectedOption;
    private bool answered;
    private int score;
    private bool finished;
    private string? correctOptionId;

    protected override void OnInitialized()
    {
        SeedQuestions();
        LoadQuiz(QuizId ?? "1");
    }

    private void SeedQuestions()
    {
        allQuizQuestions["1"] = new()
        {
            new() { Edukt1 = edukte[0], CorrectEdukt2 = edukte[1], Produkt = "H₂O", Formel = "2H₂ + O₂ → 2H₂O", Frage = "Welche Reaktion erzeugt Wasser durch eine Knallgasreaktion?", Options = new() { new() { Id = "a", Edukt2 = edukte[1], Produkt = "H₂O", Formel = "2H₂ + O₂ → 2H₂O" }, new() { Id = "b", Edukt2 = edukte[3], Produkt = "N₂H₂", Formel = "H₂ + N₂ → N₂H₂" }, new() { Id = "c", Edukt2 = edukte[5], Produkt = "H₂S", Formel = "H₂ + S → H₂S" }, new() { Id = "d", Edukt2 = edukte[8], Produkt = "HCl", Formel = "H₂ + Cl₂ → 2HCl" } } },
            new() { Edukt1 = edukte[4], CorrectEdukt2 = edukte[1], Produkt = "CO₂", Formel = "C + O₂ → CO₂", Frage = "Welches Element verbrennt mit Kohlenstoff zu einem farblosen Gas?", Options = new() { new() { Id = "a", Edukt2 = edukte[5], Produkt = "CS₂", Formel = "C + 2S → CS₂" }, new() { Id = "b", Edukt2 = edukte[1], Produkt = "CO₂", Formel = "C + O₂ → CO₂" }, new() { Id = "c", Edukt2 = edukte[0], Produkt = "CH₄", Formel = "C + 2H₂ → CH₄" }, new() { Id = "d", Edukt2 = edukte[3], Produkt = "CN₂", Formel = "C + N₂ → CN₂" } } },
            new() { Edukt1 = edukte[6], CorrectEdukt2 = edukte[5], Produkt = "FeS", Formel = "Fe + S → FeS", Frage = "Welches Element reagiert mit Eisen zu einem schwarzen Feststoff unter Glühen?", Options = new() { new() { Id = "a", Edukt2 = edukte[1], Produkt = "Fe₂O₃", Formel = "4Fe + 3O₂ → 2Fe₂O₃" }, new() { Id = "b", Edukt2 = edukte[4], Produkt = "FeC", Formel = "Fe + C → FeC" }, new() { Id = "c", Edukt2 = edukte[5], Produkt = "FeS", Formel = "Fe + S → FeS" }, new() { Id = "d", Edukt2 = edukte[8], Produkt = "FeCl₃", Formel = "2Fe + 3Cl₂ → 2FeCl₃" } } }
        };

        allQuizQuestions["2"] = new()
        {
            new() { Edukt1 = edukte[6], CorrectEdukt2 = edukte[1], Produkt = "Fe₂O₃", Formel = "4Fe + 3O₂ → 2Fe₂O₃", Frage = "Welches Element lässt Eisen rosten und einen rötlich-braunen Feststoff bilden?", Options = new() { new() { Id = "a", Edukt2 = edukte[5], Produkt = "FeS", Formel = "Fe + S → FeS" }, new() { Id = "b", Edukt2 = edukte[1], Produkt = "Fe₂O₃", Formel = "4Fe + 3O₂ → 2Fe₂O₃" }, new() { Id = "c", Edukt2 = edukte[8], Produkt = "FeCl₃", Formel = "2Fe + 3Cl₂ → 2FeCl₃" }, new() { Id = "d", Edukt2 = edukte[4], Produkt = "FeC", Formel = "Fe + C → FeC" } } },
            new() { Edukt1 = edukte[7], CorrectEdukt2 = edukte[5], Produkt = "CuS", Formel = "Cu + S → CuS", Frage = "Welches Element bildet mit Kupfer einen schwarzen Niederschlag?", Options = new() { new() { Id = "a", Edukt2 = edukte[1], Produkt = "CuO", Formel = "2Cu + O₂ → 2CuO" }, new() { Id = "b", Edukt2 = edukte[8], Produkt = "CuCl₂", Formel = "Cu + Cl₂ → CuCl₂" }, new() { Id = "c", Edukt2 = edukte[5], Produkt = "CuS", Formel = "Cu + S → CuS" }, new() { Id = "d", Edukt2 = edukte[0], Produkt = "CuH₂", Formel = "Cu + H₂ → CuH₂" } } },
            new() { Edukt1 = edukte[3], CorrectEdukt2 = edukte[0], Produkt = "NH₃", Formel = "N₂ + 3H₂ → 2NH₃", Frage = "Welches Element reagiert mit Stickstoff zu einem stechend riechenden Gas?", Options = new() { new() { Id = "a", Edukt2 = edukte[0], Produkt = "NH₃", Formel = "N₂ + 3H₂ → 2NH₃" }, new() { Id = "b", Edukt2 = edukte[1], Produkt = "NO₂", Formel = "N₂ + 2O₂ → 2NO₂" }, new() { Id = "c", Edukt2 = edukte[5], Produkt = "NS", Formel = "N₂ + S → NS" }, new() { Id = "d", Edukt2 = edukte[8], Produkt = "NCl₃", Formel = "N₂ + 3Cl₂ → 2NCl₃" } } }
        };

        allQuizQuestions["3"] = new()
        {
            new() { Edukt1 = edukte[5], CorrectEdukt2 = edukte[1], Produkt = "SO₂", Formel = "S + O₂ → SO₂", Frage = "Welches Element erzeugt mit Schwefel eine blaue Flamme und stechenden Geruch?", Options = new() { new() { Id = "a", Edukt2 = edukte[0], Produkt = "H₂S", Formel = "H₂ + S → H₂S" }, new() { Id = "b", Edukt2 = edukte[1], Produkt = "SO₂", Formel = "S + O₂ → SO₂" }, new() { Id = "c", Edukt2 = edukte[6], Produkt = "FeS", Formel = "Fe + S → FeS" }, new() { Id = "d", Edukt2 = edukte[4], Produkt = "CS₂", Formel = "C + 2S → CS₂" } } },
            new() { Edukt1 = edukte[7], CorrectEdukt2 = edukte[8], Produkt = "CuCl₂", Formel = "Cu + Cl₂ → CuCl₂", Frage = "Welches Element bildet mit Kupfer eine grünlich-braune Lösung?", Options = new() { new() { Id = "a", Edukt2 = edukte[5], Produkt = "CuS", Formel = "Cu + S → CuS" }, new() { Id = "b", Edukt2 = edukte[1], Produkt = "CuO", Formel = "2Cu + O₂ → 2CuO" }, new() { Id = "c", Edukt2 = edukte[8], Produkt = "CuCl₂", Formel = "Cu + Cl₂ → CuCl₂" }, new() { Id = "d", Edukt2 = edukte[0], Produkt = "CuH₂", Formel = "Cu + H₂ → CuH₂" } } },
            new() { Edukt1 = edukte[11], CorrectEdukt2 = edukte[10], Produkt = "NH₄OH", Formel = "NH₃ + H₂O → NH₄OH", Frage = "Welches Element löst Ammoniak zu einer basischen Lösung?", Options = new() { new() { Id = "a", Edukt2 = edukte[1], Produkt = "NO₂", Formel = "NH₃ + O₂ → NO₂" }, new() { Id = "b", Edukt2 = edukte[10], Produkt = "NH₄OH", Formel = "NH₃ + H₂O → NH₄OH" }, new() { Id = "c", Edukt2 = edukte[8], Produkt = "NH₃Cl₂", Formel = "NH₃ + Cl₂ → NH₃Cl₂" }, new() { Id = "d", Edukt2 = edukte[5], Produkt = "NH₃S", Formel = "NH₃ + S → NH₃S" } } }
        };
    }

    private void LoadQuiz(string quizId)
    {
        if (!allQuizQuestions.TryGetValue(quizId, out var quizQuestions))
        {
            quizQuestions = allQuizQuestions["1"];
        }

        questions = quizQuestions;
        currentIdx = 0;
        selectedOption = null;
        answered = false;
        score = 0;
        finished = false;
        SetCurrentQuestion();
    }

    private void SetCurrentQuestion()
    {
        question = questions.Count == 0 ? null : questions[currentIdx];
        correctOptionId = question?.Options.FirstOrDefault(o => o.Edukt2.Id == question.CorrectEdukt2.Id)?.Id;
    }

    private void HandleSelect(string optionId)
    {
        if (answered) return;
        selectedOption = optionId;
    }

    private void HandleCheck()
    {
        if (answered || string.IsNullOrEmpty(selectedOption) || question == null) return;

        answered = true;
        var opt = question.Options.FirstOrDefault(o => o.Id == selectedOption);
        if (opt != null && opt.Edukt2.Id == question.CorrectEdukt2.Id)
        {
            score++;
        }
    }

    private void HandleNext()
    {
        if (currentIdx < questions.Count - 1)
        {
            currentIdx++;
            selectedOption = null;
            answered = false;
            SetCurrentQuestion();
        }
        else
        {
            finished = true;
        }
    }

    private void HandleRestart()
    {
        currentIdx = 0;
        selectedOption = null;
        answered = false;
        score = 0;
        finished = false;
        SetCurrentQuestion();
    }

    private string GetOptionClass(bool isCorrectOpt, bool isSelected)
    {
        if (answered)
        {
            if (isCorrectOpt) return "border-green-400 bg-green-50";
            if (isSelected) return "border-red-400 bg-red-50";
            return "border-gray-200 bg-gray-50 opacity-60";
        }

        return isSelected
            ? "border-yellow-500 bg-yellow-50 ring-2 ring-yellow-300 cursor-pointer"
            : "border-gray-200 bg-white hover:border-yellow-400 hover:bg-yellow-50 cursor-pointer";
    }

    private string GetHiddenElementContainerClass()
    {
        if (!answered) return "border-yellow-300 bg-yellow-50";
        return selectedOption == correctOptionId ? "border-green-400 bg-green-50" : "border-red-400 bg-red-50";
    }

    private string GetResultContainerClass()
    {
        return "border-yellow-400 bg-yellow-50 border-solid";
    }

    private string GetProgressWidth()
    {
        if (questions.Count == 0) return "0%";
        return $"{(score * 100.0 / questions.Count):0.##}%";
    }

    private Edukt? GetSelectedEdukt()
    {
        return question?.Options.FirstOrDefault(o => o.Id == selectedOption)?.Edukt2;
    }

