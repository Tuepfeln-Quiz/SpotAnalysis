@page "/light/quiz/{QuizId}"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject SpotAnalysisV2.Web.Services.AufgabeProgressService ProgressService
@inject SpotAnalysisV2.Web.Services.QuizDataService QuizService
@using Microsoft.AspNetCore.WebUtilities
@using SpotAnalysisV2.Web.Models

<div class="size-full flex flex-col bg-gray-50">
    <header class="bg-white shadow-sm px-6 py-4 flex items-center justify-between">
        <NavLink href="/Uebungen" class="p-2 hover:bg-gray-100 rounded-lg transition-colors" style="display: flex; align-items: center;" aria-label="Zurück">
            <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 19l-7-7 7-7" />
            </svg>
        </NavLink>

        <div class="absolute left-1/2 -translate-x-1/2 flex gap-3 z-10">
            <NavLink href="/sandbox" class="bg-gray-100 text-gray-700 px-6 py-2 rounded-lg font-medium hover:bg-gray-200 transition-colors" style="text-decoration: none;">Sandbox</NavLink>
            <NavLink href="/reverse" class="bg-gray-100 text-gray-700 px-6 py-2 rounded-lg font-medium hover:bg-gray-200 transition-colors" style="text-decoration: none;">Reverse</NavLink>
            <NavLink href="/uebungen" class="bg-gray-100 text-gray-700 px-6 py-2 rounded-lg font-medium hover:bg-gray-200 transition-colors" style="text-decoration: none;">Übungen</NavLink>
        </div>

        <img src="https://images.unsplash.com/photo-1655249493799-9cee4fe983bb?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxwcm9maWxlJTIwcG9ydHJhaXR8ZW58MXx8fHwxNzczNjY1OTA5fDA&ixlib=rb-4.1.0&q=80&w=1080&utm_source=figma&utm_medium=referral"
             alt="Profil"
             class="w-10 h-10 rounded-full object-cover ml-auto" />
    </header>

    <!-- Aufgaben Navigator Toggle Button -->
    <button @onclick="() => showNavigatorPopup = true"
            class="fixed bottom-6 right-6 z-20 w-14 h-14 rounded-full bg-rose-500 text-white shadow-lg hover:bg-rose-600 transition-colors flex items-center justify-center"
            title="Aufgaben anzeigen">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
        </svg>
    </button>

    @if (showNavigatorPopup)
    {
        <!-- Backdrop -->
        <div class="fixed inset-0 bg-black/40 z-30" @onclick="() => showNavigatorPopup = false"></div>

        <!-- Popup Panel -->
        <div class="fixed inset-0 z-40 flex items-center justify-center pointer-events-none">
            <div class="pointer-events-auto bg-white rounded-2xl shadow-2xl w-80 max-h-[90vh] flex flex-col overflow-hidden">
                <!-- Header -->
                <div class="flex items-center justify-between px-4 pt-4 pb-2">
                    <div class="flex items-center gap-2">
                        <h3 class="text-base font-semibold text-gray-800">Aufgaben</h3>
                        <span class="text-[11px] px-2 py-0.5 rounded-full @(IsTupfelnAufgabe(CurrentAufgabeIdSafe) ? "bg-teal-100 text-teal-700" : "bg-yellow-100 text-yellow-700")">
                            @(IsTupfelnAufgabe(CurrentAufgabeIdSafe) ? "🧪 Tüpfeln" : "🔦 Light")
                        </span>
                    </div>
                    <button @onclick="() => showNavigatorPopup = false" class="p-1.5 rounded-lg hover:bg-gray-100 text-gray-500">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>

                <!-- Aufgaben Liste -->
                <div class="overflow-y-auto flex-1 px-4 pb-2 space-y-2">
                    @for (var i = 1; i <= TotalAufgabenSafe; i++)
                    {
                        var isCurrent = i == CurrentAufgabeIdSafe;
                        var isTupfeln = IsTupfelnAufgabe(i);
                        var result = ProgressService.GetResult(ResolvedUebungId, i);
                        <button @onclick="(() => { NavigateToAufgabe(i); showNavigatorPopup = false; })"
                                class="w-full text-left rounded-xl border p-3 transition-colors @(isCurrent ? (isTupfeln ? "border-teal-400 bg-teal-50 ring-2 ring-teal-200" : "border-yellow-400 bg-yellow-50 ring-2 ring-yellow-200") : result == true ? "border-green-300 bg-green-50 hover:bg-green-100" : result == false ? "border-red-300 bg-red-50 hover:bg-red-100" : "border-gray-200 bg-white hover:bg-gray-50")">
                            <div class="flex items-center justify-between gap-2">
                                <div class="flex items-center gap-2">
                                    @if (isCurrent)
                                    {
                                        <span class="w-5 h-5 rounded-full bg-yellow-400 flex items-center justify-center flex-shrink-0">
                                            <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="6"/></svg>
                                        </span>
                                    }
                                    else if (result == true)
                                    {
                                        <span class="w-5 h-5 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0">
                                            <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                                        </span>
                                    }
                                    else if (result == false)
                                    {
                                        <span class="w-5 h-5 rounded-full bg-red-500 flex items-center justify-center flex-shrink-0">
                                            <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="w-5 h-5 rounded-full border-2 border-gray-300 flex-shrink-0"></span>
                                    }
                                    <span class="text-sm font-medium @(isCurrent ? "text-gray-900" : "text-gray-700")">Aufgabe @i</span>
                                </div>
                                <span class="text-[11px] px-2 py-0.5 rounded-full @(isTupfeln ? "bg-teal-100 text-teal-700" : "bg-yellow-100 text-yellow-700")">
                                    @(isTupfeln ? "🧪 Tüpfeln" : "🔦 Light")
                                </span>
                            </div>
                        </button>
                    }
                </div>

                <!-- Footer Buttons -->
                <div class="flex gap-2 px-4 py-3 border-t border-gray-100">
                    <button @onclick="() => { NavigateToPreviousAufgabe(); showNavigatorPopup = false; }" class="flex-1 px-2 py-2 rounded-xl bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200 transition-colors">← Zurück</button>
                    <button @onclick="() => { NavigateToNextAufgabe(); showNavigatorPopup = false; }" class="flex-1 px-2 py-2 rounded-xl bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200 transition-colors">Überspringen →</button>
                </div>
            </div>
        </div>
    }

    @if (finished)
    {
        <div class="flex-1 flex items-center justify-center p-4">
            <div class="bg-white rounded-xl shadow-md p-8 text-center max-w-md w-full">
                <div class="w-14 h-14 rounded-full bg-yellow-100 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-7 h-7 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M8 2v8l3 6v6h2v-6l3-6V2H8z" />
                    </svg>
                </div>
                <h2 class="text-xl font-semibold mb-2">Quiz abgeschlossen!</h2>
                <p class="text-gray-600 mb-4">
                    Sie haben <span class="font-bold text-yellow-600">@score</span> von <span class="font-bold">@questions.Count</span> Fragen richtig beantwortet.
                </p>
                <div class="w-full bg-gray-200 rounded-full h-3 mb-6">
                    <div class="bg-yellow-500 h-3 rounded-full transition-all" style="width: @GetProgressWidth()"></div>
                </div>
                <div class="flex gap-3">
                    <button @onclick="HandleRestart" class="flex-1 py-3 rounded-lg font-medium bg-yellow-500 text-white hover:bg-yellow-600 transition-colors">Nochmal</button>
                    @if (IsInUebungContext && CurrentAufgabeIdSafe < TotalAufgabenSafe)
                    {
                        <button @onclick="NavigateToNextAufgabe" class="flex-1 py-3 rounded-lg font-medium bg-teal-500 text-white hover:bg-teal-600 transition-colors">Nächste Aufgabe →</button>
                    }
                    else if (IsInUebungContext)
                    {
                        <NavLink href="/uebungen" class="flex-1 py-3 rounded-lg font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors text-center" style="text-decoration: none;">Fertig ✓</NavLink>
                    }
                    else if (!string.IsNullOrWhiteSpace(Next))
                    {
                        <button @onclick="HandleContinue" class="flex-1 py-3 rounded-lg font-medium bg-teal-500 text-white hover:bg-teal-600 transition-colors">Weiter zu Tüpfeln</button>
                    }
                    else
                    {
                        <NavLink href="/light" class="flex-1 py-3 rounded-lg font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors text-center" style="text-decoration: none;">Zurück</NavLink>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="flex-1 flex overflow-hidden">
            <div class="flex-1 p-4 flex flex-col gap-4 overflow-y-auto">
                @if (question != null)
                {
                    <div class="bg-white rounded-xl shadow-md p-4">
                        <div class="flex items-center justify-between mb-3">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-yellow-100 flex items-center justify-center">
                                    <svg class="w-4 h-4 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M8 2v8l3 6v6h2v-6l3-6V2H8z" />
                                    </svg>
                                </div>
                                <div>
                                    <h2 class="text-base font-semibold text-gray-800">Light Quiz @QuizId</h2>
                                    <p class="text-xs text-gray-500">Finden Sie das fehlende Element und Ergebnis</p>
                                </div>
                            </div>
                        </div>

                        <div class="bg-yellow-50 border border-yellow-200 rounded-lg px-4 py-3 mb-4">
                            <p class="text-sm text-yellow-800 font-medium">@question.Frage</p>
                        </div>

                        <div class="grid grid-cols-3 gap-4 mb-4 items-stretch">
                            <div class="flex flex-col">
                                <h3 class="text-xs font-medium text-gray-600 mb-1">Element 1 (gegeben)</h3>
                                <div class="@question.Edukt1.Color border-2 rounded-lg p-3 min-h-[120px] flex-1 flex flex-col justify-center">
                                    <p class="font-bold text-base">@question.Edukt1.Name</p>
                                    <p class="text-xs text-gray-700 mb-2">@question.Edukt1.Type</p>
                                    <div class="flex gap-2">
                                        <div class="flex-1 flex flex-col gap-0.5 bg-white/70 px-2 py-1.5 rounded border border-gray-300">
                                            <div class="flex items-center gap-1">
                                                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" style="color: @GetPhColorHex(question.Edukt1.PhLevel)">
                                                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/>
                                                </svg>
                                                <span class="text-[10px] text-gray-700">pH: @GetPhDisplayColor(question.Edukt1.PhLevel)</span>
                                            </div>
                                            <div class="@GetPhColor(question.Edukt1.PhLevel) h-2 rounded border border-gray-400"></div>
                                        </div>
                                        <div class="flex-1 flex flex-col gap-0.5 bg-white/70 px-2 py-1.5 rounded border border-gray-300">
                                            <div class="flex items-center gap-1">
                                                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" style="color: @GetFlameColorHex(question.Edukt1.FlameColor)">
                                                    <path d="M12 2C12 2 6 8 6 13c0 3.3 2.7 6 6 6s6-2.7 6-6c0-5-6-11-6-11zm0 16c-1.6 0-3-1.4-3-3 0-1.8 1.5-3.5 3-5.1 1.5 1.6 3 3.3 3 5.1 0 1.6-1.4 3-3 3z"/>
                                                </svg>
                                                <span class="text-[10px] text-gray-700">Feuer: @selectedOrQuestionFlameQuestion()</span>
                                            </div>
                                            <div class="@GetFlameColor(question.Edukt1.FlameColor) h-2 rounded border border-gray-400"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="flex flex-col">
                                <h3 class="text-xs font-medium text-gray-600 mb-1">Element 2 (gesucht)</h3>
                                <div class="@(answered ? "min-h-[120px] flex-1 flex items-stretch" : $"{GetHiddenElementContainerClass()} border-2 border-dashed rounded-lg p-3 min-h-[120px] flex-1 flex items-center justify-center")">
                                    @if (answered)
                                    {
                                        var selectedEdukt = GetSelectedEdukt();
                                        if (selectedEdukt != null)
                                        {
                                            <div class="w-full border-2 rounded-lg p-3 @(selectedOption == correctOptionId ? "border-green-400 bg-green-50" : "border-red-400 bg-red-50")">
                                                <div class="flex items-start justify-between gap-2">
                                                    <div>
                                                        <p class="font-bold text-base">@selectedEdukt.Name</p>
                                                        <p class="text-xs text-gray-700 mb-2">@selectedEdukt.Type</p>
                                                    </div>
                                                    @if (selectedOption == correctOptionId)
                                                    {
                                                        <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" />
                                                        </svg>
                                                    }
                                                    else
                                                    {
                                                        <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z" />
                                                        </svg>
                                                    }
                                                </div>
                                                <div class="flex gap-2">
                                                    <div class="flex-1 flex flex-col gap-0.5 bg-white/70 px-2 py-1.5 rounded border border-gray-300">
                                                        <div class="flex items-center gap-1">
                                                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" style="color: @GetPhColorHex(selectedEdukt.PhLevel)">
                                                                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/>
                                                            </svg>
                                                            <span class="text-[10px] text-gray-700">pH: @GetPhDisplayColor(selectedEdukt.PhLevel)</span>
                                                        </div>
                                                        <div class="@GetPhColor(selectedEdukt.PhLevel) h-2 rounded border border-gray-400"></div>
                                                    </div>
                                                    <div class="flex-1 flex flex-col gap-0.5 bg-white/70 px-2 py-1.5 rounded border border-gray-300">
                                                        <div class="flex items-center gap-1">
                                                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" style="color: @GetFlameColorHex(selectedEdukt.FlameColor)">
                                                                <path d="M12 2C12 2 6 8 6 13c0 3.3 2.7 6 6 6s6-2.7 6-6c0-5-6-11-6-11zm0 16c-1.6 0-3-1.4-3-3 0-1.8 1.5-3.5 3-5.1 1.5 1.6 3 3.3 3 5.1 0 1.6-1.4 3-3 3z"/>
                                                            </svg>
                                                            <span class="text-[10px] text-gray-700">Feuer: @selectedEdukt.FlameColor</span>
                                                        </div>
                                                        <div class="@GetFlameColor(selectedEdukt.FlameColor) h-2 rounded border border-gray-400"></div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="text-center text-yellow-400">
                                            <svg class="w-10 h-10 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <circle cx="12" cy="12" r="10"></circle>
                                                <path d="M12 16h.01M12 8a2.5 2.5 0 0 1 2.5 2.5c0 1.5-1.5 2-2.2 2.7-.2.2-.3.4-.3.8"></path>
                                            </svg>
                                            <p class="text-sm">???</p>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="flex flex-col">
                                <h3 class="text-xs font-medium text-gray-600 mb-1 flex items-center gap-1.5">
                                    <svg class="w-3.5 h-3.5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M12 2C12 2 6 8 6 13c0 3.3 2.7 6 6 6s6-2.7 6-6c0-5-6-11-6-11z" />
                                        <path d="M9 14c0 1.7 1.3 3 3 3" />
                                    </svg>
                                    <span>Niederschlag (gegeben)</span>
                                </h3>
                                <div class="@GetResultContainerClass() border-2 border-dashed rounded-lg p-4 min-h-[110px] flex-1 flex items-center justify-center">
                                    <div class="text-center">
                                        <svg class="w-7 h-7 text-amber-600 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M12 2C12 2 6 8 6 13c0 3.3 2.7 6 6 6s6-2.7 6-6c0-5-6-11-6-11zm0 16c-1.6 0-3-1.4-3-3 0-1.8 1.5-3.5 3-5.1 1.5 1.6 3 3.3 3 5.1 0 1.6-1.4 3-3 3z" />
                                            <path d="M9 14c0 1.7 1.3 3 3 3" />
                                        </svg>
                                        <p class="font-bold text-xl text-amber-800">@GetNiederschlagText(question.Produkt)</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-3 mb-4">
                            @foreach (var opt in question.Options)
                            {
                                var isCorrectOpt = opt.Edukt2.Id == question.CorrectEdukt2.Id;
                                var isSelected = selectedOption == opt.Id;

                                <button @onclick="@(() => HandleSelect(opt.Id))"
                                        disabled="@answered"
                                        class="border-2 rounded-lg p-4 text-left transition-all @GetOptionClass(isCorrectOpt, isSelected)">
                                    <div class="space-y-1">
                                        <p class="text-xl font-semibold text-slate-600 leading-tight">
                                            @question.Edukt1.Type + @opt.Edukt2.Type
                                        </p>
                                        <p class="text-lg text-slate-500 leading-tight">
                                            → @GetNiederschlagText(opt.Produkt) (@opt.Formel)
                                        </p>
                                    </div>
                                </button>
                            }
                        </div>

                        @if (!answered)
                        {
                            <button @onclick="HandleCheck"
                                    disabled="@(string.IsNullOrEmpty(selectedOption))"
                                    class="@(string.IsNullOrEmpty(selectedOption) ? "w-full py-3 rounded-lg font-medium bg-gray-200 text-gray-400 cursor-not-allowed" : "w-full py-3 rounded-lg font-medium bg-yellow-500 text-white hover:bg-yellow-600 transition-colors")">
                                Überprüfen
                            </button>
                        }
                        else
                        {
                            <button @onclick="HandleNext"
                                    class="w-full py-3 rounded-lg font-medium bg-yellow-500 text-white hover:bg-yellow-600 transition-colors flex items-center justify-center gap-2">
                                @if (currentIdx < questions.Count - 1)
                                {
                                    <span>Nächste Frage</span>
                                }
                                else
                                {
                                    <span>Ergebnis anzeigen</span>
                                }
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string? QuizId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? Next { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "from")]
    public string? From { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "uebungId")]
    public int? UebungContextId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "aufgabeId")]
    public int? AufgabeContextId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "total")]
    public int? TotalAufgaben { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "phase")]
    public string? Phase { get; set; }

    private readonly Dictionary<string, List<LightFrage>> allQuizQuestions = new();
    private List<LightFrage> questions = new();
    private LightFrage? question;
    private int currentIdx;
    private string? selectedOption;
    private bool answered;
    private int score;
    private bool finished;
    private string? correctOptionId;
    private bool showNavigatorPopup;

    protected override void OnInitialized()
    {
        SeedQuestions();
    }

    protected override void OnParametersSet()
    {
        EnsureUebungContext();
        var id = QuizId ?? "1";
        LoadQuiz(id);
    }

    private void SeedQuestions()
    {
        foreach (var data in QuizService.GetLightQuizzes())
        {
            allQuizQuestions[data.Id.ToString()] = data.Fragen;
        }
    }

    private void LoadQuiz(string quizId)
    {
        if (!allQuizQuestions.TryGetValue(quizId, out var quizQuestions) || quizQuestions.Count == 0)
        {
            questions = new();
            question = null;
            correctOptionId = null;
            finished = false;
            return;
        }

        questions = quizQuestions;
        currentIdx = 0;
        selectedOption = null;
        answered = false;
        score = 0;
        finished = false;
        SetCurrentQuestion();
    }

    private void SetCurrentQuestion()
    {
        if (questions.Count == 0)
        {
            question = null;
            correctOptionId = null;
            return;
        }

        currentIdx = Math.Clamp(currentIdx, 0, questions.Count - 1);
        question = questions[currentIdx];
        correctOptionId = question.Options.FirstOrDefault(o => o.Edukt2.Id == question.CorrectEdukt2.Id)?.Id;
    }

    private void HandleSelect(string optionId)
    {
        if (answered) return;
        selectedOption = optionId;
    }

    private void HandleCheck()
    {
        if (answered || string.IsNullOrEmpty(selectedOption) || question == null) return;

        answered = true;
        var opt = question.Options.FirstOrDefault(o => o.Id == selectedOption);
        if (opt != null && opt.Edukt2.Id == question.CorrectEdukt2.Id)
        {
            score++;
        }
    }

    private void HandleNext()
    {
        if (currentIdx < questions.Count - 1)
        {
            currentIdx++;
            selectedOption = null;
            answered = false;
            SetCurrentQuestion();
        }
        else
        {
            ProgressService.RecordResult(ResolvedUebungId, CurrentAufgabeIdSafe, score == questions.Count);

            if (IsInUebungContext && CurrentAufgabeIdSafe < TotalAufgabenSafe)
            {
                NavigateToAufgabe(CurrentAufgabeIdSafe + 1);
                return;
            }

            finished = true;
        }
    }

    private void HandleRestart()
    {
        currentIdx = 0;
        selectedOption = null;
        answered = false;
        score = 0;
        finished = false;
        SetCurrentQuestion();
    }

    private void HandleContinue()
    {
        if (string.IsNullOrWhiteSpace(Next)) return;
        Navigation.NavigateTo(Uri.UnescapeDataString(Next));
    }

    private bool ShowAufgabenNavigator => true;

    private bool IsInUebungContext => ProgressService.IsInUebung
        || string.Equals(From, "uebung", StringComparison.OrdinalIgnoreCase)
        || string.Equals(TryGetQueryString("from"), "uebung", StringComparison.OrdinalIgnoreCase)
        || UebungContextId.HasValue
        || TryGetQueryInt("uebungId").HasValue;

    private int TotalAufgabenSafe => Math.Max(1, TotalAufgaben ?? TryGetQueryInt("total") ?? (ProgressService.IsInUebung ? ProgressService.CurrentTotal : 1));
    private int CurrentAufgabeIdSafe => Math.Clamp(AufgabeContextId ?? TryGetQueryInt("aufgabeId") ?? (ProgressService.IsInUebung ? ProgressService.CurrentAufgabeId : 1), 1, TotalAufgabenSafe);
    private int ResolvedUebungId => UebungContextId ?? TryGetQueryInt("uebungId") ?? (ProgressService.IsInUebung ? ProgressService.CurrentUebungId : ParseQuizIdOrDefault());

    private void EnsureUebungContext()
    {
        var uebungId = UebungContextId ?? TryGetQueryInt("uebungId");
        if (!uebungId.HasValue) return;

        var total = Math.Max(1, TotalAufgaben ?? TryGetQueryInt("total") ?? QuizService.GetAufgabenCount(uebungId.Value));
        var aufgabeId = Math.Clamp(AufgabeContextId ?? TryGetQueryInt("aufgabeId") ?? 1, 1, total);
        ProgressService.SetUebungContext(uebungId.Value, aufgabeId, total);
    }

    private int ParseQuizIdOrDefault()
    {
        return int.TryParse(QuizId, out var parsed) && parsed > 0 ? parsed : 1;
    }

    private bool IsTupfelnAufgabe(int aufgabeId)
    {
        if (!IsInUebungContext) return false;
        return QuizService.GetAufgabe(ResolvedUebungId, aufgabeId)?.Typ == AufgabeTyp.Tuepfeln;
    }

    private int? TryGetQueryInt(string key)
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (!query.TryGetValue(key, out var value)) return null;
        return int.TryParse(value.ToString(), out var parsed) ? parsed : null;
    }

    private string? TryGetQueryString(string key)
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue(key, out var value) ? value.ToString() : null;
    }

    private void NavigateToAufgabe(int targetAufgabe)
    {
        var clamped = Math.Clamp(targetAufgabe, 1, TotalAufgabenSafe);
        Navigation.NavigateTo($"/uebungen/{ResolvedUebungId}/aufgabe/{clamped}");
    }

    private void NavigateToPreviousAufgabe()
    {
        var previous = CurrentAufgabeIdSafe > 1 ? CurrentAufgabeIdSafe - 1 : TotalAufgabenSafe;
        NavigateToAufgabe(previous);
    }

    private void NavigateToNextAufgabe()
    {
        var next = CurrentAufgabeIdSafe < TotalAufgabenSafe ? CurrentAufgabeIdSafe + 1 : 1;
        NavigateToAufgabe(next);
    }

    private string GetOptionClass(bool isCorrectOpt, bool isSelected)
    {
        if (answered)
        {
            if (isCorrectOpt) return "border-green-400 bg-green-50";
            if (isSelected) return "border-red-400 bg-red-50";
            return "border-gray-200 bg-gray-50 opacity-60";
        }

        return isSelected
            ? "border-yellow-500 bg-yellow-50 ring-2 ring-yellow-300 cursor-pointer"
            : "border-gray-200 bg-white hover:border-yellow-400 hover:bg-yellow-50 cursor-pointer";
    }

    private string GetHiddenElementContainerClass()
    {
        if (!answered) return "border-yellow-300 bg-yellow-50";
        return selectedOption == correctOptionId ? "border-green-400 bg-green-50" : "border-red-400 bg-red-50";
    }

    private string GetResultContainerClass()
    {
        return "border-yellow-400 bg-yellow-50 border-solid";
    }

    private string GetProgressWidth()
    {
        if (questions.Count == 0) return "0%";
        return $"{(score * 100.0 / questions.Count):0.##}%";
    }

    private Edukt? GetSelectedEdukt()
    {
        return question?.Options.FirstOrDefault(o => o.Id == selectedOption)?.Edukt2;
    }

