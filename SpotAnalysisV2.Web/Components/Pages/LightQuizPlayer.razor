        public string Type { get; set; } = string.Empty;
        public string Color { get; set; } = string.Empty;
        public string PhLevel { get; set; } = "-";
        public string FlameColor { get; set; } = "Keine";
        public string ElementColor { get; set; } = "Farblos";
