    private string GetFlameDisplayText(string flameColor)
    {
        return string.Equals(flameColor, "None", StringComparison.OrdinalIgnoreCase)
            || string.Equals(flameColor, "Keine", StringComparison.OrdinalIgnoreCase)
            ? "Keine"
            : flameColor;
    }

    private string GetElementColorDisplayText(string elementColor)
    {
        return string.IsNullOrWhiteSpace(elementColor)
            || string.Equals(elementColor, "Farblos", StringComparison.OrdinalIgnoreCase)
            ? "Keine"
            : elementColor;
    }

    private bool ShouldShowPhStrip(string phLevel)
    {
        return !string.IsNullOrWhiteSpace(phLevel);
    }

    private string GetPhDisplayText(string phLevel)
    {
        return phLevel switch
        {
            "1" or "2" or "3" or "4" => "Rot",
            "5" => "Orange",
            "6" => "Gelb",
            "7" or "8" or "9" or "10" => "Grün",
            "11" or "12" => "Blau",
            _ => "Keine"
        };
    }

    private bool ShouldShowFlameStrip(string flameColor)
    {
        return !string.IsNullOrWhiteSpace(flameColor);
    }

    private bool ShouldShowElementColorStrip(string elementColor)
    {
        return !string.IsNullOrWhiteSpace(elementColor);
    }

    private void ToggleHistory()
