@page "/teacher/groups"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Teacher")]
@inject IGroupService GroupService
@inject NavigationManager Navigation

<PageTitle>Gruppen – SpotAnalysis</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-gray-50 via-white to-amber-50 p-8">
    <div class="mx-auto max-w-5xl">
        <TeacherPageHeader SectionTextClass="text-amber-600"
                           Title="Gruppen"
                           Description="Verwalte Klassen, Beschreibungen und Quiz-Zuweisungen zentral an einem Ort.">
            <Actions>
                <AppButton Variant="AppButton.ButtonVariant.Secondary"
                           OnClick='() => Navigation.NavigateTo("/teacher")'
                           Class="font-medium">
                    Zurück
                </AppButton>
                <AppButton Variant="AppButton.ButtonVariant.Custom"
                           CustomVariantClass="bg-amber-500 text-white shadow-lg shadow-amber-200 hover:bg-amber-600"
                           OnClick="CreateGroup">
                    Neue Gruppe
                </AppButton>
            </Actions>
        </TeacherPageHeader>

        @if (_groups is null)
        {
            <div class="rounded-3xl bg-white p-10 text-center shadow-lg text-gray-500">Laden…</div>
        }
        else if (_groups.Count == 0)
        {
            <div class="rounded-3xl border border-dashed border-amber-200 bg-white p-10 text-center shadow-lg">
                <h2 class="text-xl font-semibold text-gray-800">Noch keine Gruppen erstellt</h2>
                <p class="mt-2 text-sm text-gray-500">Lege deine erste Gruppe an, um Schüler und Quizzes zuzuweisen.</p>
            </div>
        }
        else
        {
            <div class="space-y-4">
                @foreach (var group in _groups)
                {
                    <div class="relative overflow-hidden rounded-3xl border border-gray-200 bg-white p-6 shadow-lg transition duration-200 hover:-translate-y-0.5 hover:border-amber-300 hover:shadow-xl">
                        <div class="absolute left-0 top-0 h-full w-1.5 bg-gradient-to-b from-amber-400 to-orange-500"></div>
                        <div class="flex items-start justify-between gap-4 pl-1">
                            <button type="button" @onclick='() => OpenGroup(group.Id)' class="flex min-w-0 flex-1 items-start gap-3 text-left">
                                <span class="mt-0.5 inline-flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-amber-100 to-orange-100 text-lg">👥</span>
                                <div class="min-w-0 flex-1">
                                    <h2 class="truncate text-xl font-semibold text-gray-800">@group.Name</h2>
                                    <p class="mt-1 text-sm text-gray-500">@(string.IsNullOrWhiteSpace(group.Description) ? "Keine Beschreibung" : group.Description)</p>
                                </div>
                             </button>
                             <div class="flex gap-2">
                                <AppButton Variant="AppButton.ButtonVariant.Secondary"
                                           OnClick='() => OpenGroup(group.Id)'>
                                    Öffnen
                                </AppButton>
                                <AppButton Variant="AppButton.ButtonVariant.Danger"
                                           OnClick='() => ConfirmDelete(group)'>
                                    Löschen
                                </AppButton>
                             </div>
                         </div>
                     </div>
                 }
             </div>
         }

        @if (_groupToDelete is not null)
        {
            <ConfirmDialog Title="Gruppe löschen?"
                           Message="@GetDeleteGroupMessage(_groupToDelete)"
                           OnCancel="CancelDelete"
                           OnConfirm="DeleteGroup" />
        }
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private List<GroupDto>? _groups;
    private GroupDto? _groupToDelete;
    private Guid _teacherId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        _teacherId = Guid.Parse(auth.User.FindFirst(ClaimTypes.NameIdentifier)!.Value);
        _groups = await GroupService.GetGroups(_teacherId);
    }

    private void CreateGroup() => Navigation.NavigateTo("/teacher/groups/new");
    private void OpenGroup(int id) => Navigation.NavigateTo($"/teacher/groups/{id}");
    private void ConfirmDelete(GroupDto group) => _groupToDelete = group;
    private void CancelDelete() => _groupToDelete = null;

    private async Task DeleteGroup()
    {
        if (_groupToDelete is null) return;
        await GroupService.DeleteGroup(_teacherId, _groupToDelete.Id);
        _groupToDelete = null;
        _groups = await GroupService.GetGroups(_teacherId);
    }

    private static string GetDeleteGroupMessage(GroupDto group)
        => $"Gruppe {group.Name} endgültig löschen? Schüler- und Quiz-Zuordnungen werden entfernt.";
}
