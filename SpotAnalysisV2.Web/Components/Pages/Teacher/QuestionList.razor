@page "/teacher/questions"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Teacher")]
@inject IQuizService QuizService
@inject NavigationManager Navigation

<PageTitle>Fragenpool – SpotAnalysis</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-gray-50 via-white to-blue-50 p-8">
    <div class="mx-auto max-w-6xl">
        <div class="mb-6 flex items-center justify-between gap-4">
            <div>
                <p class="text-sm font-medium text-blue-600">Lehrerbereich</p>
                <h1 class="text-3xl font-bold text-gray-800">Fragenpool</h1>
                <p class="mt-2 text-sm text-gray-500">Erstelle und bearbeite SpotTest- und Light-Fragen mit echten Datenbankdaten.</p>
            </div>
            <div class="flex gap-3">
                <button type="button" @onclick='() => Navigation.NavigateTo("/teacher")' class="rounded-2xl border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">Zurück</button>
                <button type="button" @onclick="CreateQuestion" class="rounded-2xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-blue-200 hover:bg-blue-700">Neue Frage</button>
            </div>
        </div>

        <div class="mb-5 grid gap-3 rounded-3xl border border-gray-200 bg-white p-4 shadow-lg md:grid-cols-[1fr_auto_auto_auto]">
             <input type="text"
                    class="w-full rounded-2xl border border-gray-300 px-4 py-3 outline-none focus:border-blue-400 focus:ring-4 focus:ring-blue-100"
                    placeholder="Titel oder Beschreibung suchen..."
                    @bind="_searchTerm" @bind:event="oninput" />

             <select class="rounded-2xl border border-gray-300 px-4 py-3 outline-none focus:border-blue-400" @bind="_teacherFilter">
                 <option value="">Alle Lehrer</option>
                 @foreach (var teacher in AvailableTeachers)
                 {
                     <option value="@teacher.Id">@teacher.Name</option>
                 }
             </select>

             <button type="button" @onclick='() => _typeFilter = null' class="rounded-2xl px-4 py-3 text-sm font-semibold transition @(_typeFilter is null ? "bg-blue-600 text-white shadow" : "border border-gray-200 bg-white text-gray-700 hover:bg-gray-50")">Alle</button>
             <div class="flex gap-2">
                <button type="button" @onclick='() => _typeFilter = QuestionType.SpotTest' class="rounded-2xl px-4 py-3 text-sm font-semibold transition @(_typeFilter == QuestionType.SpotTest ? "bg-purple-600 text-white shadow" : "border border-gray-200 bg-white text-gray-700 hover:bg-gray-50")">SpotTest</button>
                <button type="button" @onclick='() => _typeFilter = QuestionType.SpotTestLight' class="rounded-2xl px-4 py-3 text-sm font-semibold transition @(_typeFilter == QuestionType.SpotTestLight ? "bg-blue-600 text-white shadow" : "border border-gray-200 bg-white text-gray-700 hover:bg-gray-50")">Light</button>
             </div>
         </div>

        @if (_questions is null)
        {
            <div class="rounded-3xl bg-white p-10 text-center shadow-lg text-gray-500">Laden…</div>
        }
        else if (_questions.Count == 0)
        {
            <div class="rounded-3xl border border-dashed border-blue-200 bg-white p-10 text-center shadow-lg">
                <h2 class="text-xl font-semibold text-gray-800">Noch keine Fragen erstellt</h2>
                <p class="mt-2 text-sm text-gray-500">Lege deine erste Frage an.</p>
            </div>
        }
        else
        {
            <div class="space-y-4">
                 @foreach (var q in FilteredQuestions)
                 {
                    <div class="relative overflow-hidden rounded-3xl border border-gray-200 bg-white p-6 shadow-lg transition duration-200 hover:-translate-y-0.5 hover:shadow-xl">
                        <div class="absolute left-0 top-0 h-full w-1.5 @GetQuestionAccentClass(q.Type)"></div>
                        <div class="flex items-start justify-between gap-4 pl-1">
                            <div class="flex min-w-0 flex-1 items-start gap-3">
                                <span class="mt-0.5 inline-flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl @GetQuestionAccentSoftClass(q.Type) text-lg">
                                    @(q.Type == QuestionType.SpotTest ? "🧪" : "🔦")
                                </span>
                                <div class="min-w-0 flex-1">
                                    <div class="mb-2 flex flex-wrap items-center gap-2">
                                     <span class="rounded-full px-3 py-1 text-xs font-semibold @(q.Type == QuestionType.SpotTest ? "bg-purple-100 text-purple-700" : "bg-blue-100 text-blue-700")">
                                         @(q.Type == QuestionType.SpotTest ? "SpotTest" : "Light")
                                     </span>
                                     @if (!string.IsNullOrWhiteSpace(q.CreatedByName))
                                     {
                                         <span class="text-xs text-gray-400">von @q.CreatedByName</span>
                                     }
                                 </div>
                                <h2 class="truncate text-lg font-semibold text-gray-800">@q.Title</h2>
                                <p class="mt-1 text-sm text-gray-500">@q.Description</p>
                                <p class="mt-2 text-xs text-gray-400">
                                     @if (q.Type == QuestionType.SpotTest)
                                     {
                                         <span>@q.ChemicalCount Chemikalien · @q.MethodCount Methoden · in @q.QuizCount Quizzes</span>
                                     }
                                     else
                                     {
                                         <span>@q.ReactionCount Reaktionen · in @q.QuizCount Quizzes</span>
                                     }
                                </p>
                                </div>
                             </div>
                             <div class="flex gap-2">
                                <button type="button" @onclick='() => EditQuestion(q)' class="rounded-2xl border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-700 transition hover:bg-gray-50">Bearbeiten</button>
                                <button type="button" @onclick='() => ConfirmDelete(q)' class="rounded-2xl border border-red-200 bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 transition hover:bg-red-100">Löschen</button>
                             </div>
                         </div>
                     </div>
                 }
             </div>
         }

        @if (_questionToDelete is not null)
        {
            <div class="fixed inset-0 z-40 flex items-center justify-center bg-black/30 p-4">
                <div class="w-full max-w-lg rounded-3xl bg-white p-6 shadow-2xl">
                    <h3 class="text-xl font-semibold text-gray-800">Frage löschen?</h3>
                    @if (_questionToDelete.QuizCount > 0)
                    {
                        <p class="mt-3 text-sm text-red-600">Diese Frage wird in @_questionToDelete.QuizCount Quiz(zes) verwendet und kann nicht gelöscht werden.</p>
                    }
                    else
                    {
                        <p class="mt-3 text-sm text-gray-500">Möchtest du die Frage <strong>@_questionToDelete.Title</strong> wirklich löschen?</p>
                    }
                    <div class="mt-6 flex justify-end gap-3">
                        <button type="button" @onclick="CancelDelete" class="rounded-2xl border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Abbrechen</button>
                        @if (_questionToDelete.QuizCount == 0)
                        {
                            <button type="button" @onclick="DeleteQuestion" class="rounded-2xl bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700">Löschen</button>
                        }
                    </div>
                </div>
            </div>
        }

        @if (_deleteError is not null)
        {
            <div class="mt-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@_deleteError</div>
        }
    </div>
</div>

@code {
    private List<QuestionOverviewDto>? _questions;
    private string _searchTerm = string.Empty;
    private QuestionType? _typeFilter;
    private string _teacherFilter = string.Empty;
    private QuestionOverviewDto? _questionToDelete;
    private string? _deleteError;

    protected override async Task OnInitializedAsync()
    {
        _questions = await QuizService.GetQuestions();
    }

    private record TeacherOption(string Id, string Name);

    private IEnumerable<TeacherOption> AvailableTeachers =>
        _questions is null
            ? []
            : _questions.Where(q => q.CreatedById.HasValue && !string.IsNullOrEmpty(q.CreatedByName))
                .Select(q => new TeacherOption(q.CreatedById!.Value.ToString(), q.CreatedByName!))
                .DistinctBy(t => t.Id)
                .OrderBy(t => t.Name);

    private IEnumerable<QuestionOverviewDto> FilteredQuestions =>
        _questions?.Where(q =>
            (_typeFilter is null || q.Type == _typeFilter) &&
            (string.IsNullOrEmpty(_teacherFilter) || q.CreatedById?.ToString() == _teacherFilter) &&
            (string.IsNullOrEmpty(_searchTerm) ||
             q.Title.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
             q.Description.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))) ?? [];

    private void CreateQuestion() => Navigation.NavigateTo("/teacher/questions/create");
    private void EditQuestion(QuestionOverviewDto q) => Navigation.NavigateTo($"/teacher/questions/{q.Id}/edit?type={q.Type}");
    private void ConfirmDelete(QuestionOverviewDto q) => _questionToDelete = q;
    private void CancelDelete() => _questionToDelete = null;

    private async Task DeleteQuestion()
    {
        if (_questionToDelete is null) return;
        _deleteError = null;
        try
        {
            await QuizService.DeleteQuestion(_questionToDelete.Id);
            _questionToDelete = null;
            _questions = await QuizService.GetQuestions();
        }
        catch (InvalidOperationException ex)
        {
            _deleteError = ex.Message;
            _questionToDelete = null;
        }
    }

    private static string GetQuestionAccentClass(QuestionType type)
        => type == QuestionType.SpotTest
            ? "bg-gradient-to-b from-purple-500 to-fuchsia-500"
            : "bg-gradient-to-b from-blue-500 to-cyan-500";

    private static string GetQuestionAccentSoftClass(QuestionType type)
        => type == QuestionType.SpotTest
            ? "bg-gradient-to-br from-purple-100 to-fuchsia-100"
            : "bg-gradient-to-br from-blue-100 to-cyan-100";
}
