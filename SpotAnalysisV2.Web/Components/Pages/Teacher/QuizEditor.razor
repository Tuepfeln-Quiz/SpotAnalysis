@page "/teacher/quizzes/create"
@page "/teacher/quizzes/{QuizId:int}/edit"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Teacher")]
@inject IQuizService QuizService
@inject IGroupService GroupService
@inject NavigationManager Navigation

<PageTitle>@(_isEdit ? "Quiz bearbeiten" : "Neues Quiz") – SpotAnalysis</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-gray-50 via-white to-purple-50 p-8">
    <div class="mx-auto max-w-7xl rounded-[28px] border border-white/70 bg-white/95 p-7 shadow-2xl shadow-purple-100/60">
        <div class="mb-6">
            <p class="text-sm font-medium text-purple-600">Lehrerbereich</p>
            <h1 class="text-3xl font-bold text-gray-800">@(_isEdit ? "Quiz bearbeiten" : "Quiz erstellen")</h1>
        </div>

        <div class="space-y-6">
            <div class="rounded-3xl border border-gray-200 bg-gradient-to-br from-white to-purple-50/40 p-5">
                <label class="mb-2 block text-sm font-medium text-gray-800">Quiz-Name</label>
                <input type="text"
                       class="w-full rounded-2xl border border-gray-300 bg-white px-4 py-3 outline-none transition focus:border-purple-400 focus:ring-4 focus:ring-purple-100"
                       placeholder="z.B. Säuren & Basen Grundlagen"
                       @bind="_quizName" />
            </div>

            <div class="rounded-3xl border border-gray-200 bg-white p-5 shadow-sm">
                <label class="mb-2 block text-sm font-medium text-gray-800">Fragen zuordnen</label>
                <div class="rounded-3xl border border-gray-200 bg-gray-50/50 p-3">
                    <input type="text"
                           class="mb-3 w-full rounded-2xl border border-gray-300 bg-white px-4 py-3 outline-none transition focus:border-purple-400 focus:ring-4 focus:ring-purple-100"
                           placeholder="Fragen durchsuchen..."
                           @bind="_searchTerm" @bind:event="oninput" />

                    <div class="mb-4 flex gap-2">
                        <button type="button" @onclick='() => _typeFilter = null' class="rounded-xl px-4 py-2 text-sm font-semibold transition @(_typeFilter is null ? "bg-purple-700 text-white shadow" : "bg-white border border-gray-200 text-gray-700 hover:bg-gray-50")">Alle</button>
                        <button type="button" @onclick='() => _typeFilter = QuestionType.SpotTest' class="rounded-xl px-4 py-2 text-sm font-semibold transition @(_typeFilter == QuestionType.SpotTest ? "bg-purple-700 text-white shadow" : "bg-white border border-gray-200 text-gray-700 hover:bg-gray-50")">SpotTest</button>
                        <button type="button" @onclick='() => _typeFilter = QuestionType.SpotTestLight' class="rounded-xl px-4 py-2 text-sm font-semibold transition @(_typeFilter == QuestionType.SpotTestLight ? "bg-blue-600 text-white shadow" : "bg-white border border-gray-200 text-gray-700 hover:bg-gray-50")">Light</button>
                    </div>

                    <div class="max-h-[340px] space-y-2 overflow-y-auto pr-1">
                        @if (_allQuestions is not null)
                        {
                            @foreach (var q in FilteredQuestions)
                            {
                                var isSelected = _selectedQuestionIds.Contains(q.Id);
                                <button type="button"
                                        @onclick='() => ToggleQuestion(q.Id)'
                                        class="flex w-full items-center justify-between rounded-2xl border px-4 py-3 text-left transition @(isSelected ? "border-purple-200 bg-purple-50 ring-2 ring-purple-100" : "border-transparent bg-white hover:border-gray-200 hover:bg-gray-50")">
                                    <div class="flex items-start gap-3">
                                        <span class="mt-1 inline-flex h-4 w-4 items-center justify-center rounded-full border text-[10px] font-bold @(isSelected ? "border-purple-500 bg-purple-500 text-white" : "border-gray-300 text-gray-400")">
                                            @(isSelected ? "✓" : "")
                                        </span>
                                        <div>
                                            <div class="text-sm font-medium text-gray-800">@q.Description</div>
                                            @if (!string.IsNullOrWhiteSpace(q.Title))
                                            {
                                                <div class="text-xs text-gray-400">@q.Title</div>
                                            }
                                        </div>
                                    </div>
                                    <span class="rounded-full px-3 py-1 text-xs font-semibold @(q.Type == QuestionType.SpotTest ? "bg-purple-100 text-purple-700" : "bg-blue-100 text-blue-700")">
                                        @(q.Type == QuestionType.SpotTest ? "SpotTest" : "Light")
                                    </span>
                                </button>
                            }
                        }
                    </div>
                </div>
            </div>

            @if (_orderedQuestions.Count > 0)
            {
                <div class="rounded-3xl border border-gray-200 bg-white p-5 shadow-sm">
                    <label class="mb-2 block text-sm font-medium text-gray-800">Reihenfolge</label>
                    <div class="rounded-3xl border border-gray-200 bg-gray-50/50 p-3">
                        <div class="space-y-2">
                            @for (var i = 0; i < _orderedQuestions.Count; i++)
                            {
                                var index = i;
                                var q = _orderedQuestions[i];
                                <div class="flex items-center justify-between rounded-2xl border border-gray-200 bg-white px-4 py-3">
                                    <div>
                                        <div class="text-sm font-medium text-gray-800">@(index + 1). @q.Description</div>
                                        <div class="text-xs text-gray-400">@q.Title</div>
                                    </div>
                                    <div class="flex gap-2">
                                        <button type="button" @onclick='() => MoveUp(index)' disabled="@(index == 0)" class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-xs font-semibold text-gray-700 transition hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-40">↑ Hoch</button>
                                        <button type="button" @onclick='() => MoveDown(index)' disabled="@(index == _orderedQuestions.Count - 1)" class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-xs font-semibold text-gray-700 transition hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-40">↓ Runter</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <div class="rounded-3xl border border-gray-200 bg-gradient-to-br from-white to-purple-50/30 p-5 shadow-sm">
                <div class="mb-2 flex items-center justify-between gap-4">
                    <label class="block text-sm font-medium text-gray-800">Gruppen zuweisen</label>
                    @if (_availableGroups.Any(g => !_selectedGroups.Any(sg => sg.Id == g.Id)))
                    {
                        <button type="button" @onclick='() => _showGroupDropdown = !_showGroupDropdown' class="rounded-xl bg-purple-700 px-4 py-2 text-sm font-semibold text-white hover:bg-purple-800">
                            + Hinzufügen
                        </button>
                    }
                </div>

                <p class="mb-2 text-xs text-gray-500">Schüler sehen dieses Quiz nur, wenn es ihrer Gruppe zugewiesen ist.</p>

                <div class="rounded-2xl border border-gray-300 bg-white p-4">
                    @if (_selectedGroups.Count > 0)
                    {
                        <div class="flex flex-wrap gap-2">
                            @foreach (var group in _selectedGroups)
                            {
                                <span class="inline-flex items-center gap-2 rounded-full border border-purple-200 bg-purple-50 px-3 py-2 text-sm text-purple-700">
                                    <span>@group.Name</span>
                                    <button type="button" @onclick='() => RemoveGroup(group.Id)' class="font-bold text-purple-500 hover:text-purple-700">×</button>
                                </span>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-gray-500">Keine Gruppen zugewiesen.</p>
                    }

                    @if (_showGroupDropdown)
                    {
                        <div class="mt-3 space-y-2 border-t border-gray-100 pt-3">
                            @foreach (var group in _availableGroups.Where(g => !_selectedGroups.Any(sg => sg.Id == g.Id)))
                            {
                                <button type="button" @onclick='() => AddGroup(group)' class="flex w-full items-center justify-between rounded-2xl px-4 py-3 text-left text-sm text-gray-700 transition hover:bg-gray-50 border border-transparent hover:border-gray-200">
                                    <span>@group.Name</span>
                                    <span class="text-purple-600">+ Hinzufügen</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            @if (_errorMessage is not null)
            {
                <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@_errorMessage</div>
            }

            <div class="flex justify-end gap-4 pt-2">
                <button type="button" @onclick="Cancel" class="rounded-xl border border-gray-300 bg-white px-5 py-3 text-sm font-semibold text-gray-700 transition hover:bg-gray-50">Abbrechen</button>
                <button type="button" @onclick="Save" disabled="@_saving" class="rounded-xl bg-gradient-to-r from-purple-700 to-fuchsia-600 px-5 py-3 text-sm font-semibold text-white shadow-md transition hover:from-purple-800 hover:to-fuchsia-700 disabled:cursor-not-allowed disabled:opacity-70">
                    @(_saving ? "Speichern..." : "Quiz speichern")
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? QuizId { get; set; }
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private bool _isEdit => QuizId.HasValue;
    private string _quizName = string.Empty;
    private string _searchTerm = string.Empty;
    private QuestionType? _typeFilter;
    private List<QuestionOverviewDto>? _allQuestions;
    private HashSet<int> _selectedQuestionIds = new();
    private List<QuestionOverviewDto> _orderedQuestions = new();
    private List<GroupDto> _availableGroups = new();
    private List<GroupDto> _selectedGroups = new();
    private bool _saving;
    private bool _showGroupDropdown;
    private string? _errorMessage;
    private Guid _teacherId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        _teacherId = Guid.Parse(auth.User.FindFirst(ClaimTypes.NameIdentifier)!.Value);

        _allQuestions = await QuizService.GetQuestions();
        _availableGroups = await GroupService.GetGroups(_teacherId);

        if (_isEdit)
        {
            var quizQuestions = await QuizService.GetQuestionsOfQuiz(QuizId!.Value);
            _selectedQuestionIds = quizQuestions.Select(q => q.Id).ToHashSet();
            _orderedQuestions = quizQuestions.ToList();

            var allQuizzes = await QuizService.GetAllQuizzes();
            var quiz = allQuizzes.FirstOrDefault(q => q.Id == QuizId!.Value);
            if (quiz is not null)
                _quizName = quiz.Name;

            _selectedGroups = await QuizService.GetGroupsByQuiz(QuizId!.Value);
        }
    }

    private IEnumerable<QuestionOverviewDto> FilteredQuestions =>
        _allQuestions?.Where(q =>
            (_typeFilter is null || q.Type == _typeFilter) &&
            (string.IsNullOrEmpty(_searchTerm) ||
             q.Description.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
             q.Title.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))) ?? [];

    private void ToggleQuestion(int questionId)
    {
        if (_selectedQuestionIds.Contains(questionId))
        {
            _selectedQuestionIds.Remove(questionId);
            _orderedQuestions.RemoveAll(q => q.Id == questionId);
        }
        else
        {
            _selectedQuestionIds.Add(questionId);
            var question = _allQuestions!.First(q => q.Id == questionId);
            _orderedQuestions.Add(question);
        }
    }

    private void MoveUp(int index)
    {
        if (index <= 0) return;
        var item = _orderedQuestions[index];
        _orderedQuestions.RemoveAt(index);
        _orderedQuestions.Insert(index - 1, item);
    }

    private void MoveDown(int index)
    {
        if (index >= _orderedQuestions.Count - 1) return;
        var item = _orderedQuestions[index];
        _orderedQuestions.RemoveAt(index);
        _orderedQuestions.Insert(index + 1, item);
    }

    private void AddGroup(GroupDto group)
    {
        _selectedGroups.Add(group);
        if (!_availableGroups.Any(g => !_selectedGroups.Any(sg => sg.Id == g.Id)))
            _showGroupDropdown = false;
    }

    private void RemoveGroup(int groupId) => _selectedGroups.RemoveAll(g => g.Id == groupId);

    private void Cancel() => Navigation.NavigateTo("/teacher/quizzes");

    private async Task Save()
    {
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_quizName))
        {
            _errorMessage = "Bitte einen Quiz-Namen eingeben.";
            return;
        }

        if (_orderedQuestions.Count == 0)
        {
            _errorMessage = "Bitte mindestens eine Frage zuordnen.";
            return;
        }

        _saving = true;
        try
        {
            var questions = _orderedQuestions.Select((q, i) => new QuestionDto
            {
                Id = q.Id,
                Order = i
            }).ToList();

            var selectedGroupIds = _selectedGroups.Select(g => g.Id).ToHashSet();
            int quizId;

            if (_isEdit)
            {
                quizId = QuizId!.Value;
                await QuizService.UpdateQuiz(_teacherId, new UpdateQuizDto
                {
                    Id = quizId,
                    Name = _quizName,
                    Questions = questions,
                });
            }
            else
            {
                quizId = await QuizService.CreateQuiz(_teacherId, new CreateQuizDto
                {
                    Name = _quizName,
                    Questions = questions,
                });
            }

            var existingGroups = await QuizService.GetGroupsByQuiz(quizId);
            var existingGroupIds = existingGroups.Select(g => g.Id).ToHashSet();

            foreach (var groupId in selectedGroupIds.Except(existingGroupIds))
                await QuizService.AssignGroupToQuiz(quizId, groupId);

            foreach (var groupId in existingGroupIds.Except(selectedGroupIds))
                await QuizService.RemoveGroupFromQuiz(quizId, groupId);

            Navigation.NavigateTo("/teacher/quizzes");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
