@page "/teacher/quizzes"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Teacher")]
@inject IQuizService QuizService
@inject NavigationManager Navigation

<PageTitle>Quizzes – SpotAnalysis</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-gray-50 via-white to-purple-50 p-8">
    <div class="mx-auto max-w-5xl">
        <div class="mb-6 flex items-center justify-between gap-4">
            <div>
                <p class="text-sm font-medium text-purple-600">Lehrerbereich</p>
                <h1 class="text-3xl font-bold text-gray-800">Quizzes</h1>
                <p class="mt-1 text-sm text-gray-500">Erstellen, bearbeiten und verwalten Sie Ihre Quiz-Sammlungen.</p>
            </div>
            <div class="flex gap-3">
                <button type="button" @onclick='() => Navigation.NavigateTo("/teacher")' class="rounded-2xl border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">Zurück</button>
                <button type="button" @onclick="CreateQuiz" class="rounded-2xl bg-purple-600 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-purple-200 hover:bg-purple-700">Neues Quiz</button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="mb-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@_errorMessage</div>
        }

        @if (_quizzes is null)
        {
            <div class="rounded-3xl bg-white p-10 text-center shadow-lg text-gray-500">Laden…</div>
        }
        else if (_quizzes.Count == 0)
        {
            <div class="rounded-3xl border border-dashed border-purple-200 bg-white p-10 text-center shadow-lg">
                <h2 class="text-xl font-semibold text-gray-800">Noch keine Quizzes erstellt</h2>
                <p class="mt-2 text-sm text-gray-500">Lege dein erstes Quiz mit Fragen und Gruppen-Zuordnungen an.</p>
            </div>
        }
        else
        {
            <div class="space-y-4">
                @foreach (var quiz in _quizzes)
                {
                    <div class="relative overflow-hidden rounded-3xl border border-gray-200 bg-white p-6 shadow-lg transition duration-200 hover:-translate-y-0.5 hover:border-purple-300 hover:shadow-xl">
                        <div class="absolute left-0 top-0 h-full w-1.5 @GetQuizAccentClass(quiz)"></div>
                        <div class="flex items-start justify-between gap-4 pl-1">
                            <div class="flex min-w-0 flex-1 items-start gap-3">
                                <span class="mt-0.5 inline-flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl @GetQuizAccentSoftClass(quiz) text-lg">
                                    @GetQuizIcon(quiz)
                                </span>
                                <div class="min-w-0 flex-1">
                                    <h2 class="truncate text-xl font-semibold text-gray-800">@quiz.Name</h2>
                                    <div class="mt-2 flex flex-wrap items-center gap-2">
                                        <span class="rounded-full border border-purple-200 bg-purple-100 px-3 py-1 text-xs font-semibold text-purple-700">🧪 @quiz.STCount SpotTest</span>
                                        <span class="rounded-full border border-blue-200 bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">🔦 @quiz.STLCount Light</span>
                                        <span class="rounded-full border border-gray-200 bg-gray-50 px-3 py-1 text-xs font-semibold text-gray-700">👥 @quiz.GroupCount Gruppen</span>
                                    </div>
                                </div>
                             </div>
                             <div class="flex gap-2">
                                <button type="button" @onclick='() => EditQuiz(quiz.Id)' class="rounded-2xl border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-700 transition hover:bg-gray-50">Bearbeiten</button>
                                <button type="button" @onclick='() => ConfirmDelete(quiz)' class="rounded-2xl border border-red-200 bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 transition hover:bg-red-100">Löschen</button>
                             </div>
                         </div>
                     </div>
                 }
             </div>
         }

        @if (_quizToDelete is not null)
        {
            <div class="fixed inset-0 z-40 flex items-center justify-center bg-black/30 p-4">
                <div class="w-full max-w-md rounded-3xl bg-white p-6 shadow-2xl">
                    <h3 class="text-xl font-semibold text-gray-800">Quiz löschen?</h3>
                    <p class="mt-3 text-sm text-gray-500">Möchtest du das Quiz <strong>@_quizToDelete.Name</strong> wirklich löschen?</p>
                    @if (_quizToDelete.GroupCount > 0)
                    {
                        <p class="mt-2 text-sm text-amber-700">Dieses Quiz ist @_quizToDelete.GroupCount Gruppe(n) zugewiesen.</p>
                    }
                    <div class="mt-6 flex justify-end gap-3">
                        <button type="button" @onclick="CancelDelete" class="rounded-2xl border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Abbrechen</button>
                        <button type="button" @onclick="DeleteQuiz" class="rounded-2xl bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700">Löschen</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private List<QuizOverviewDto>? _quizzes;
    private QuizOverviewDto? _quizToDelete;
    private Guid _teacherId;
    private string? _errorMessage;

    private static string GetQuizAccentClass(QuizOverviewDto quiz)
        => quiz.STCount > 0 && quiz.STLCount > 0
            ? "bg-gradient-to-b from-purple-500 to-blue-500"
            : quiz.STCount > 0
                ? "bg-gradient-to-b from-purple-500 to-fuchsia-500"
                : "bg-gradient-to-b from-blue-500 to-cyan-500";

    private static string GetQuizAccentSoftClass(QuizOverviewDto quiz)
        => quiz.STCount > 0 && quiz.STLCount > 0
            ? "bg-gradient-to-br from-purple-100 to-blue-100"
            : quiz.STCount > 0
                ? "bg-gradient-to-br from-purple-100 to-fuchsia-100"
                : "bg-gradient-to-br from-blue-100 to-cyan-100";

    private static string GetQuizIcon(QuizOverviewDto quiz)
        => quiz.STCount > 0 && quiz.STLCount > 0
            ? "🧬"
            : quiz.STCount > 0
                ? "🧪"
                : "🔦";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        _teacherId = Guid.Parse(auth.User.FindFirst(ClaimTypes.NameIdentifier)!.Value);
        _quizzes = await QuizService.GetAllQuizzes();
    }

    private void CreateQuiz() => Navigation.NavigateTo("/teacher/quizzes/create");
    private void EditQuiz(int id) => Navigation.NavigateTo($"/teacher/quizzes/{id}/edit");
    private void ConfirmDelete(QuizOverviewDto quiz)
    {
        _errorMessage = null;
        _quizToDelete = quiz;
    }

    private void CancelDelete() => _quizToDelete = null;

    private async Task DeleteQuiz()
    {
        if (_quizToDelete is null) return;

        try
        {
            await QuizService.DeleteQuiz(_teacherId, _quizToDelete.Id);
            _quizToDelete = null;
            _quizzes = await QuizService.GetAllQuizzes();
            _errorMessage = null;
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
            _quizToDelete = null;
        }
        catch (Exception)
        {
            _errorMessage = "Löschen fehlgeschlagen. Bitte erneut versuchen.";
            _quizToDelete = null;
        }
    }
}
