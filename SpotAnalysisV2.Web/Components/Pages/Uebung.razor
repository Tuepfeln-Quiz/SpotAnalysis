@page "/uebungen/{UebungId:int}"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<div class="size-full flex items-center justify-center bg-gray-50">
    <div class="text-sm text-gray-500">Weiterleitung zum Quiz…</div>
</div>

@code {
    [Parameter] public int UebungId { get; set; }

    protected override void OnParametersSet()
    {
        Navigation.NavigateTo($"/uebungen/{UebungId}/aufgabe/1", replace: true);
    }
}
