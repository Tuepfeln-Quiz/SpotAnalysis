@page "/uebungen"
@rendermode InteractiveServer
@inject SpotAnalysisV2.Web.Services.QuizDataService QuizService

<div class="size-full flex flex-col bg-gray-50">
    <header class="bg-white shadow-sm px-6 py-4 flex items-center justify-between">
        <NavLink href="/" class="p-2 hover:bg-gray-100 rounded-lg transition-colors" style="display: flex; align-items: center;" aria-label="Home">
            <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
        </NavLink>

        <h1 class="absolute left-1/2 -translate-x-1/2 text-lg font-semibold text-gray-800">Quizes</h1>

        <NavLink href="/admin/uebungen" class="px-4 py-2 rounded-lg bg-teal-50 border border-teal-200 text-teal-700 text-sm font-medium hover:bg-teal-100 transition-colors" style="text-decoration: none;">
            Admin
        </NavLink>
    </header>

    <main class="flex-1 overflow-y-auto p-8">
        <div class="max-w-3xl mx-auto">
            <div class="flex items-start justify-between gap-4 mb-8">
                <p class="text-gray-600">Wählen Sie ein Quiz aus. Beim Klick startet direkt die erste Aufgabe.</p>
                <NavLink href="/admin/uebungen" class="shrink-0 px-4 py-2 rounded-lg bg-white border border-gray-200 text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors" style="text-decoration: none;">
                    Neue Übung erstellen
                </NavLink>
            </div>

            @if (quizzes.Count == 0)
            {
                <div class="bg-white rounded-2xl border-2 border-dashed border-gray-200 p-10 text-center shadow-sm">
                    <h2 class="text-lg font-semibold text-gray-800 mb-2">Noch keine Übungen verfügbar</h2>
                    <p class="text-sm text-gray-500 mb-5">Erstellen Sie zuerst im Admin-Bereich eine Übung aus vorhandenen `Light`- und `Tüpfeln`-Quiz.</p>
                    <NavLink href="/admin/uebungen" class="inline-flex px-5 py-3 rounded-xl bg-teal-500 text-white font-medium hover:bg-teal-600 transition-colors" style="text-decoration: none;">
                        Zur Admin-Erstellung
                    </NavLink>
                </div>
            }
            else
            {
                <div class="space-y-4">
                    @foreach (var quiz in quizzes)
                    {
                        <NavLink href="@($"/uebungen/{quiz.Id}/aufgabe/1")"
                                 class="w-full block bg-white hover:bg-gray-50 shadow-md rounded-xl p-6 transition-all hover:shadow-lg group"
                                 style="text-decoration: none;">
                            <div class="flex items-center justify-between">
                                <div class="flex-1">
                                    <h2 class="text-xl font-medium text-gray-800 group-hover:text-teal-600 transition-colors mb-1">@quiz.Title</h2>
                                    <p class="text-gray-500 text-sm mb-3">@quiz.Description</p>
                                    <div class="flex gap-2">
                                        <span class="px-3 py-1 rounded-lg bg-teal-50 border border-teal-200 text-teal-700 text-sm font-medium">
                                            @quiz.AufgabenCount Aufgaben
                                        </span>
                                        <span class="px-3 py-1 rounded-lg bg-yellow-50 border border-yellow-200 text-yellow-700 text-sm">
                                            🔦 @quiz.LightCount Light
                                        </span>
                                        <span class="px-3 py-1 rounded-lg bg-teal-50 border border-teal-200 text-teal-700 text-sm">
                                            🧪 @quiz.TupfelnCount Tüpfeln
                                        </span>
                                    </div>
                                </div>
                                <svg class="w-6 h-6 text-gray-400 group-hover:text-teal-600 transition-colors ml-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M9 5l7 7-7 7" />
                                </svg>
                            </div>
                        </NavLink>
                    }
                </div>
            }
        </div>
    </main>
</div>

@code {
    private List<SpotAnalysisV2.Web.Models.UebungItem> quizzes = new();

    protected override void OnInitialized()
    {
        quizzes = QuizService.GetUebungen();
    }
}
